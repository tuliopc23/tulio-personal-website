# Sanity CMS Configuration
PUBLIC_SANITY_PROJECT_ID=61249gtj
PUBLIC_SANITY_DATASET=production

# Studio URLs
# Development: Use embedded studio at localhost
# Production: Point previews at your Cloudflare Pages site
# (Optional) Studio-only overrides if different from public site
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
PUBLIC_SANITY_STUDIO_URL=https://tulio-cunha-dev.sanity.studio
PUBLIC_SANITY_PREVIEW_URL=https://www.tuliocunha.dev

# Visual Editing (optional)
PUBLIC_SANITY_VISUAL_EDITING_ENABLED=false
SANITY_API_READ_TOKEN=
# Optional local-only fallback for intentionally offline development.
# Production and CI should leave this unset or false.
SANITY_ALLOW_BUILD_FALLBACK=false

# Webhook Integration
SANITY_API_WRITE_TOKEN=
CLOUDFLARE_DEPLOY_HOOK_URL=
SANITY_WEBHOOK_SECRET=

# GitHub activity
# The featured repo section accepts either variable name.
GITHUB_TOKEN=
# GITHUB_PERSONAL_ACCESS_TOKEN=

# Note: To enable the direct Sanity -> Cloudflare Pages rebuild webhook:
# 1. Create a Cloudflare Pages deploy hook for your production branch
# 2. Create a Sanity write token:
#    - Go to https://www.sanity.io/manage
#    - Select your project → API → Tokens
#    - Create new token with "Editor" permissions
# 3. Add the values above and run: bun run sanity:webhook

# ===== OPTIONAL CONTENT AUTOMATION =====

# If you run a separate automation service for cross-posting,
# configure one of the URLs below. The Astro site itself is static
# and no longer hosts /api/auto-publish.
SANITY_STUDIO_WEBHOOK_URL=
WEBHOOK_BASE_URL=

# Dev.to API Key (optional)
# Used by separate automation tooling, not by the static site runtime.
DEV_TO_API_KEY=

HASHNODE_ACCESS_TOKEN=
HASHNODE_PUBLICATION_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=

# Optional: Force Cloudflare image proxy base (e.g. https://www.tuliocunha.dev)
# If empty, relative /cdn-cgi/image URLs are used.
PUBLIC_CLOUDFLARE_IMAGE_BASE=
