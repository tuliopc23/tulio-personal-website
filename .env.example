# ─── Keystatic (GitHub mode on Cloudflare — required in production / Workers Builds for /keystatic)
# Official: https://keystatic.com/docs/github-mode
KEYSTATIC_SECRET=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
# Optional override if not running in CI with GITHUB_REPOSITORY_* defaults:
# KEYSTATIC_GITHUB_REPO=owner/repo

# ─── GitHub (homepage featured repos + REST API for `/api/github.json`)
GITHUB_TOKEN=
# GITHUB_PERSONAL_ACCESS_TOKEN=

# ─── Images (optional Cloudflare Images front origin)
PUBLIC_CLOUDFLARE_IMAGE_BASE=

# ─── Sentry (build-time uploads + runtime)
PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
PUBLIC_SENTRY_RELEASE=
SENTRY_RELEASE=

# ─── Newsletter (Resend + KV; Astro API routes run on Workers)
RESEND_API_KEY=
RESEND_FROM="Tulio Cunha <newsletter@tuliocunha.dev>"
RESEND_SEGMENT_ID=
NEWSLETTER_WEBHOOK_SECRET=

# ─── Cloudflare / repo automation (optional)
GITHUB_REPOSITORY_DISPATCH_TOKEN=
GITHUB_REPOSITORY_OWNER=tuliopc23
GITHUB_REPOSITORY_NAME=tulio-personal-website
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# ─── Legacy cross-post tooling (optional; not required for the site build)
DEV_TO_API_KEY=
HASHNODE_ACCESS_TOKEN=
HASHNODE_PUBLICATION_ID=
