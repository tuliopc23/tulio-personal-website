{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "moduleResolution": "bundler",
    "types": ["astro/client", "vitest/globals", "@playwright/test"],
    "skipLibCheck": true,
    "paths": {
      "astro-portabletext": ["types/astro-portabletext"],
      "@assets/*": ["./src/assets/*"]
    }
  },
  "include": ["src", "tests", "types", "astro.config.mjs", "*.config.*", "tsconfig.json"],
  "exclude": ["dist", "node_modules"]
}
