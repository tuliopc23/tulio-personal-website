{
  "name": "tulio-personal-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/with-system-certs.mjs vp exec astro dev",
    "build": "node scripts/with-system-certs.mjs vp exec astro build",
    "astro:check": "node scripts/with-system-certs.mjs vp exec astro check",
    "test": "vp run test:unit && vp run test:astro",
    "test:watch": "vitest watch tests/unit tests/dom",
    "test:unit": "vitest run tests/unit tests/dom tests/cms",
    "test:cms": "vitest run tests/cms",
    "test:astro": "vitest run -c vitest.astro.config.ts tests/astro",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage tests/unit tests/dom",
    "test:smoke": "vp run build && vitest run tests/layout-smoke.test.ts",
    "preview": "node scripts/with-system-certs.mjs vp exec astro preview",
    "cf:dev": "wrangler dev",
    "cf:secrets:push": "node scripts/wrangler-push-worker-secrets.mjs",
    "cf:api:sync": "node scripts/cloudflare-api-sync.mjs",
    "cf:deploy": "vp run deploy:preflight && wrangler deploy",
    "lint": "node scripts/lint-all.mjs",
    "lint:fix": "node scripts/lint-all.mjs --fix",
    "format": "vp fmt . --write",
    "format:check": "vp fmt . --check",
    "quality": "pnpm run format:check && pnpm run lint",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run quality && vp run astro:check && vp run test:unit && vp run build",
    "check:ci": "pnpm run quality && vp run astro:check && vp run test:unit && vp run build",
    "deploy:preflight": "vp run check:ci",
    "fonts:build": "node scripts/build-sf-fonts.mjs",
    "eslint": "node scripts/lint-all.mjs",
    "prettier": "vp fmt . --write",
    "prettier:check": "vp fmt --check .",
    "install:ci": "pnpm install --frozen-lockfile",
    "verify:prod-github-api": "node scripts/verify-prod-github-api.mjs",
    "seed:keystatic-posts": "node scripts/seed-keystatic-posts.mjs",
    "knip": "knip"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.6.1",
    "@astrojs/markdoc": "^1.0.6",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/solid-js": "^6.0.1",
    "@base-ui/react": "^1.5.0",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/simple-icons": "^1.2.86",
    "@keystatic/astro": "^5.1.0",
    "@keystatic/core": "^0.5.50",
    "@phosphor-icons/core": "^2.1.1",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.16",
    "@remotion/player": "4.0.468",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "direction": "^2.0.1",
    "dotenv": "^17.4.2",
    "easymde": "^2.21.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.5",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-directive": "^4.0.0",
    "remotion": "4.0.468",
    "resend": "^6.12.4",
    "set-cookie-parser": "^3.1.0",
    "sharp": "^0.34.5",
    "shiki": "^4.2.0",
    "solid-js": "^1.9.13",
    "styled-components": "^6.4.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260608.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "lodash": "4.18.1",
    "prettier": "^3.8.3",
    "react-compiler-runtime": "^1.0.0",
    "react-is": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vite-plus": "^0.1.24",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.1",
  "overrides": {
    "vite": "^7",
    "remotion": "4.0.454",
    "lodash": "4.18.1"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1",
      "slate-react>lodash": "4.18.1",
      "cookie": "link:vendor/cookie",
      "@braintree/sanitize-url": "link:vendor/braintree-sanitize-url",
      "is-hotkey": "link:vendor/is-hotkey"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs",
      "sharp",
      "workerd"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "astro": "6",
        "typescript": "6",
        "uuid": "13",
        "prettier": "3",
        "codemirror": "5"
      }
    },
    "patchedDependencies": {
      "@keystatic/astro": "patches/@keystatic__astro.patch"
    }
  }
}
