{
  "name": "tulio-personal-website",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "astro:check": "astro check",
    "test": "bun run test:unit && bun run test:astro",
    "test:watch": "vitest tests/unit tests/dom",
    "test:unit": "vitest run tests/unit tests/dom",
    "test:astro": "vitest run --environment node tests/astro",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage tests/unit tests/dom",
    "test:smoke": "bun run build && bun test tests/layout-smoke.test.ts",
    "preview": "astro preview",
    "cf:dev": "wrangler pages dev dist",
    "cf:deploy": "bun run build && wrangler pages deploy dist --project-name tulio-personal-website --commit-dirty=true",
    "cf:download-config": "wrangler pages download config tulio-personal-website",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "check": "biome check --write . && bun run typecheck && bun run build",
    "check:ci": "biome ci . && bun run typecheck && bun run build",
    "biome:check": "biome check .",
    "biome:fix": "biome check --write .",
    "biome:lint": "biome lint .",
    "biome:format": "biome format --write .",
    "biome:migrate": "biome migrate eslint --write && biome migrate prettier --write",
    "sanity:typegen": "sanity schema extract && sanity typegen generate",
    "sanity:deploy": "sanity deploy",
    "sanity:webhook": "node scripts/setup-webhook.js",
    "sanity:publish": "node scripts/auto-publish-to-devto.js",
    "sanity:verify": "node scripts/verify-setup.js",
    "fonts:build": "node scripts/build-sf-fonts.mjs",
    "eslint": "eslint .",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "install:ci": "bun install"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.7",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/react": "^5.0.0",
    "@astrojs/solid-js": "^6.0.0",
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.73",
    "@phosphor-icons/core": "^2.1.1",
    "@phosphor-icons/web": "^2.1.2",
    "@portabletext/toolkit": "^5.0.2",
    "@portabletext/types": "^4.0.2",
    "@remotion/light-leaks": "^4.0.435",
    "@remotion/player": "^4.0.435",
    "@sanity/astro": "^3.3.1",
    "@sanity/blueprints": "^0.13.1",
    "@sanity/client": "^7.17.0",
    "@sanity/code-input": "^7.0.11",
    "@sanity/functions": "^1.2.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.0.3",
    "@sanity/visual-editing": "^5.3.0",
    "@spotlightjs/astro": "^3.2.6",
    "astro": "^6.0.4",
    "astro-portabletext": "^0.13.0",
    "atuin": "^0.2.0",
    "cache": "^3.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "easymde": "^2.20.0",
    "marked": "^17.0.4",
    "mdast-util-from-markdown": "^2.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.435",
    "sanity": "^5.16.0",
    "sanity-plugin-markdown": "^8.0.5",
    "shiki": "^4.0.2",
    "solid-js": "^1.9.11",
    "styled-components": "^6.3.11",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "sanity-codegen": "^0.9.8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  },
  "engines": {
    "bun": "1.3.x"
  },
  "packageManager": "bun@1.3.6",
  "trustedDependencies": [
    "@sentry/cli"
  ]
}
