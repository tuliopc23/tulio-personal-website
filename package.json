{
  "name": "tulio-personal-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/with-system-certs.mjs vp exec astro dev",
    "build": "node scripts/with-system-certs.mjs vp exec astro build",
    "astro:check": "node scripts/with-system-certs.mjs vp exec astro check",
    "test": "vp run test:unit && vp run test:astro",
    "test:watch": "vp test watch tests/unit tests/dom",
    "test:unit": "vp test run tests/unit tests/dom",
    "test:astro": "vp test run -c vitest.astro.config.ts tests/astro",
    "test:e2e": "playwright test",
    "test:coverage": "vp test run --coverage tests/unit tests/dom",
    "test:smoke": "vp run build && vp test run tests/layout-smoke.test.ts",
    "preview": "node scripts/with-system-certs.mjs vp exec astro preview",
    "cf:dev": "wrangler dev",
    "cf:secrets:push": "node scripts/wrangler-push-worker-secrets.mjs",
    "cf:api:sync": "node scripts/cloudflare-api-sync.mjs",
    "cf:deploy": "vp run deploy:preflight && wrangler deploy",
    "lint": "vp lint .",
    "lint:fix": "vp lint . --fix",
    "format": "vp fmt . --write",
    "format:check": "vp fmt . --check",
    "typecheck": "tsc --noEmit",
    "check": "vp check && vp run astro:check && vp run build",
    "check:ci": "vp run sanity:health && vp check && vp run astro:check && vp run build",
    "sanity:typegen": "node scripts/with-system-certs.mjs vp exec sanity schema extract && node scripts/with-system-certs.mjs vp exec sanity typegen generate",
    "sanity:deploy": "node scripts/with-system-certs.mjs vp exec sanity deploy",
    "sanity:health": "node scripts/with-system-certs.mjs node scripts/verify-sanity-build.js",
    "deploy:preflight": "vp run check:ci",
    "sanity:webhook": "node scripts/setup-webhook.js",
    "sanity:newsletter:webhook": "node scripts/setup-newsletter-webhook.js",
    "sanity:publish": "node scripts/auto-publish-to-devto.js",
    "sanity:verify": "node scripts/verify-setup.js",
    "sanity:seed:case-studies": "node scripts/seed-projects-page-case-studies.mjs",
    "fonts:build": "node scripts/build-sf-fonts.mjs",
    "eslint": "vp lint .",
    "prettier": "vp fmt . --write",
    "prettier:check": "vp fmt --check .",
    "install:ci": "pnpm install --frozen-lockfile",
    "verify:prod-github-api": "node scripts/verify-prod-github-api.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/solid-js": "^6.0.1",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/simple-icons": "^1.2.79",
    "@phosphor-icons/core": "^2.1.1",
    "@portabletext/to-html": "^5.0.2",
    "@portabletext/types": "^4.0.2",
    "@remotion/player": "4.0.450",
    "@sanity/assist": "^6.0.4",
    "@sanity/astro": "^3.3.1",
    "@sanity/blueprints": "^0.16.0",
    "@sanity/client": "^7.21.0",
    "@sanity/code-input": "^7.1.0",
    "@sanity/functions": "^1.3.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/ui": "^3.1.14",
    "@sanity/visual-editing": "^5.3.4",
    "@sentry/astro": "^10.49.0",
    "@sentry/cloudflare": "^10.49.0",
    "astro": "^6.1.8",
    "astro-portabletext": "^0.13.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "easymde": "^2.20.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "marked": "^18.0.2",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "4.0.450",
    "resend": "^6.12.2",
    "sanity": "^5.21.0",
    "sanity-plugin-gemini-ai-images": "^1.3.0",
    "sanity-plugin-markdown": "^8.0.5",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "solid-js": "^1.9.12",
    "styled-components": "^6.4.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260421.1",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint-plugin-astro": "^1.7.0",
    "jsdom": "^29.0.2",
    "lodash": "^4.18.1",
    "prettier": "^3.8.3",
    "react-compiler-runtime": "^1.0.0",
    "react-is": "^19.2.5",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.19",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@9.15.9",
  "overrides": {
    "vite": "^7",
    "remotion": "4.0.450"
  },
  "pnpm": {
    "overrides": {
      "remotion": "4.0.450",
      "@remotion/player>remotion": "4.0.450"
    },
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "protobufjs",
      "sharp",
      "workerd"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "uuid": "13",
        "prettier": "3",
        "sanity": "5",
        "codemirror": "5"
      }
    }
  }
}
