{
  "name": "tulio-personal-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/with-system-certs.mjs vp exec astro dev",
    "build": "node scripts/with-system-certs.mjs vp exec astro build",
    "astro:check": "node scripts/with-system-certs.mjs vp exec astro check",
    "test": "vp run test:unit && vp run test:astro",
    "test:watch": "vp test watch tests/unit tests/dom",
    "test:unit": "vp test run tests/unit tests/dom tests/cms",
    "test:cms": "vp test run tests/cms",
    "test:astro": "vp test run -c vitest.astro.config.ts tests/astro",
    "test:e2e": "playwright test",
    "test:coverage": "vp test run --coverage tests/unit tests/dom",
    "test:smoke": "vp run build && vp test run tests/layout-smoke.test.ts",
    "preview": "node scripts/with-system-certs.mjs vp exec astro preview",
    "cf:dev": "wrangler dev",
    "cf:secrets:push": "node scripts/wrangler-push-worker-secrets.mjs",
    "cf:api:sync": "node scripts/cloudflare-api-sync.mjs",
    "cf:deploy": "vp run deploy:preflight && wrangler deploy",
    "lint": "node scripts/lint-all.mjs",
    "lint:fix": "node scripts/lint-all.mjs --fix",
    "format": "vp fmt . --write",
    "format:check": "vp fmt . --check",
    "quality": "pnpm run format:check && pnpm run lint",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run quality && vp run astro:check && vp run test:unit && vp run build",
    "check:ci": "pnpm run quality && vp run astro:check && vp run test:unit && vp run build",
    "deploy:preflight": "vp run check:ci",
    "fonts:build": "node scripts/build-sf-fonts.mjs",
    "eslint": "node scripts/lint-all.mjs",
    "prettier": "vp fmt . --write",
    "prettier:check": "vp fmt --check .",
    "install:ci": "pnpm install --frozen-lockfile",
    "verify:prod-github-api": "node scripts/verify-prod-github-api.mjs",
    "seed:keystatic-posts": "node scripts/seed-keystatic-posts.mjs",
    "knip": "knip"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.5.0",
    "@astrojs/markdoc": "^1.0.4",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/solid-js": "^6.0.1",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "@phosphor-icons/core": "^2.1.1",
    "@sentry/astro": "^10.52.0",
    "@sentry/cloudflare": "^10.52.0",
    "astro": "^6.3.1",
    "direction": "^2.0.1",
    "dotenv": "^17.4.2",
    "easymde": "^2.21.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "marked": "^18.0.3",
    "motion": "^12.38.0",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/simple-icons": "^1.2.81",
    "@remotion/player": "4.0.459",
    "remotion": "4.0.459",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remark-directive": "^4.0.0",
    "resend": "^6.12.3",
    "set-cookie-parser": "^3.1.0",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "solid-js": "^1.9.12",
    "styled-components": "^6.4.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint-plugin-astro": "^1.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.12.2",
    "lodash": "4.18.1",
    "prettier": "^3.8.3",
    "react-compiler-runtime": "^1.0.0",
    "react-is": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plus": "^0.1.20",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.1",
  "overrides": {
    "vite": "^7",
    "remotion": "4.0.454",
    "lodash": "4.18.1"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1",
      "slate-react>lodash": "4.18.1",
      "cookie": "link:vendor/cookie",
      "@braintree/sanitize-url": "link:vendor/braintree-sanitize-url",
      "is-hotkey": "link:vendor/is-hotkey"
    },
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "protobufjs",
      "sharp",
      "workerd"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "astro": "6",
        "typescript": "6",
        "uuid": "13",
        "prettier": "3",
        "codemirror": "5"
      }
    },
    "patchedDependencies": {
      "@keystatic/astro": "patches/@keystatic__astro.patch"
    }
  }
}
