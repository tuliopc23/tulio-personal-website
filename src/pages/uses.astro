---
import Base from "../layouts/Base.astro";

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/uses/", siteOrigin).toString();
const description =
  "Tulio Cunha's daily setup for building premium web and native product experiences.";
const _structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Uses - Tulio Cunha",
  description,
  url: canonical,
};
---

<Base
  title="Uses"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "Tools and apps Tulio Cunha uses" }}
  structuredData={_structuredData}
  sidebar={true}
>
  <section class="container blogHero" data-reveal data-reveal-type="scale">
    <div class="blogHero__copy">
      <span class="blogHero__eyebrow">Uses</span>
      <h1 class="blogHero__title">The toolchain behind my shipping rhythm.</h1>
      <p class="blogHero__lede">
        This is the practical setup I rely on for fast development, design-system
        consistency, and production-quality delivery.
      </p>
    </div>
  </section>

  <section class="container home__section uses__snapshot" data-reveal>
    <ul class="uses__chips" role="list" aria-label="Stack priorities">
      <li role="listitem">Fast local feedback loops</li>
      <li role="listitem">Native-first developer tools</li>
      <li role="listitem">Deterministic build and deploy scripts</li>
      <li role="listitem">Minimal context-switching overhead</li>
    </ul>
  </section>

  <section class="container home__section uses__columns" data-reveal>
    <article class="uses__column card card--static">
      <div class="card__inner">
        <div class="card__content">
          <h2 class="card-title">Build Environment</h2>
          <ul class="uses__list">
            <li>Ghostty + zsh as the default command surface</li>
            <li>Neovim, Xcode, and CodeEdit by project context</li>
            <li>Bun-first scripts for fast local automation</li>
            <li>Docker and Orbstack for isolated service workflows</li>
          </ul>
        </div>
      </div>
    </article>

    <article class="uses__column card card--static">
      <div class="card__inner">
        <div class="card__content">
          <h2 class="card-title">Design And Review</h2>
          <ul class="uses__list">
            <li>Figma for exploration and interaction prototypes</li>
            <li>SF Symbols and asset systems for icon consistency</li>
            <li>Kaleidoscope and structured diffs for code-quality checks</li>
            <li>Page-level motion tuning with reduced-motion safeguards</li>
          </ul>
        </div>
      </div>
    </article>
  </section>

  <section class="container home__section" data-reveal>
    <div class="home__selectedHeader">
      <h2 class="section-title">Operating Rituals</h2>
      <p class="home__selectedLede">
        The repeatable behaviors that keep quality high while still moving quickly.
      </p>
    </div>
    <div class="cardGrid uses__rituals">
      <article class="card card--static">
        <div class="card__inner">
          <div class="card__content">
            <h3 class="card-title">Ritual 01 - Start with structure</h3>
            <p class="card-body">
              I map information hierarchy and page intent before touching visual detail.
            </p>
          </div>
        </div>
      </article>
      <article class="card card--static">
        <div class="card__inner">
          <div class="card__content">
            <h3 class="card-title">Ritual 02 - Build in thin slices</h3>
            <p class="card-body">
              New work ships in small vertical increments with immediate validation.
            </p>
          </div>
        </div>
      </article>
      <article class="card card--static">
        <div class="card__inner">
          <div class="card__content">
            <h3 class="card-title">Ritual 03 - Polish with intent</h3>
            <p class="card-body">
              Final passes focus on readability, motion quality, and accessibility details.
            </p>
          </div>
        </div>
      </article>
    </div>
  </section>
</Base>
