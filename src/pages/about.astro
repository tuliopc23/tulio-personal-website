---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import PhosphorIcon from "../components/PhosphorIcon.astro";
import { getAboutPageContent } from "../lib/content/page-content";

const pageContent = await getAboutPageContent();

if (import.meta.env.PROD && !pageContent) {
  throw new Error(
    "Missing about page content for /about. Add `src/content/site/about-page/index.yaml` (Keystatic singleton) or deploy with content present.",
  );
}

const defaults = {
  seoDescription:
    "Tulio Cunha — full stack developer, Mac head, Unix enthusiast, and command line junkie. Swift, TypeScript, Go, Rust, Zig. From native apps to system internals.",
  heroEyebrow: "About",
  heroTitle:
    "Full stack developer. Mac native. Unix at heart. Obsessed with how things actually run.",
  heroLede:
    "I build software across every layer of the stack — from pixel-perfect native interfaces to bare-metal system code. I care about performance, clarity, and shipping things that hold up long after the demo is over.",
  sections: [
    {
      icon: "sparkle",
      eyebrow: "Foundation",
      title: "I start where most people skip — the internals.",
      body: "Data flow, memory layout, system boundaries. I get those right first, because once the foundation is honest the interface writes itself. Read the system before you redesign it. Ship thin vertical slices, not slide decks. Performance is a feature, not a phase. Accessibility is a constraint, not a checklist.",
    },
    {
      icon: "code",
      eyebrow: "How I Build",
      title: "Modularity, separation of concerns, speed. No exceptions.",
      body: "Independent features, independent deploys — every module owns its boundaries, its data, and its tests. Business logic never bleeds into presentation. Data flows in one direction. The UI is a projection of state, not the owner of it. Performance isn't a polish pass — it's a design constraint from line one. Lazy load, tree shake, measure everything. Clean, beautiful, engaging UI is what hooks users — they feel the difference between software that was designed and software that was assembled.",
    },
    {
      icon: "wrench",
      eyebrow: "Philosophy",
      title: "Use the best tool for the job. Don't love the hammer — it won't love you back.",
      body: "Every language, framework, and platform is a tradeoff. The skill isn't mastering one tool, it's knowing when to put it down and pick up another. Swift for native, TypeScript for the web, Go when you need speed and simplicity, Rust when correctness is non-negotiable. I'm a freelancer, indie dev, and OSS contributor because I'd rather solve problems than defend stacks.",
    },
    {
      icon: "terminal",
      eyebrow: "Happy Hacking",
      title: "The terminal is home. The craft is the point.",
      body: "I write code because I genuinely love it — the dopamine of a clean abstraction, the satisfaction of a build that compiles on the first try, the rabbit holes that start at midnight and end with something real. Open source contributor, config tweaker, dotfiles perfectionist. If it runs on Unix, I'm interested. If it ships to users, even better.",
    },
  ],
};

const content = {
  seoDescription: pageContent?.seoDescription ?? defaults.seoDescription,
  heroEyebrow: pageContent?.heroEyebrow ?? defaults.heroEyebrow,
  heroTitle: pageContent?.heroTitle ?? defaults.heroTitle,
  heroLede: pageContent?.heroLede ?? defaults.heroLede,
  sections: pageContent?.sections?.length ? pageContent.sections : defaults.sections,
};

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/about/", siteOrigin).toString();
const description = content.seoDescription;
const _structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About Tulio Cunha",
  description,
  url: canonical,
};

/* Image showcases mapped by section index */
const sectionImages: Array<Array<{ src: string; alt: string }>> = [
  [
    {
      src: "/images/about/mac-terminal-vintage.webp",
      alt: "Vintage Macintosh 128K with green CRT display and keyboard",
    },
    {
      src: "/images/about/mac-hello.webp",
      alt: "Classic Mac displaying 'hello' in handwritten script",
    },
  ],
  [
    {
      src: "/images/about/programmin.webp",
      alt: "IDE with syntax-highlighted code on dark background",
    },
    {
      src: "/images/about/code2.webp",
      alt: "Close-up of colorful syntax-highlighted source code",
    },
  ],
  [
    {
      src: "/images/about/programming.webp",
      alt: "Moody desk setup with code editor and ambient lighting",
    },
    {
      src: "/images/about/mac-classic.webp",
      alt: "Classic beige Macintosh Plus with keyboard and carrying bag",
    },
  ],
];
---

<Base
  title="About"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "About Tulio Cunha" }}
  structuredData={_structuredData}
  sidebar={true}
>
  <div class="pageBento">
    <section class="container pageHero pageWidget" data-reveal data-reveal-type="scale">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/", icon: "home" },
          { label: "About", icon: "info" },
        ]}
      />
      <div class="pageHero__copy">
        <h1 class="pageHero__title">{content.heroTitle}</h1>
        <p class="pageHero__lede">{content.heroLede}</p>
      </div>
    </section>

    {content.sections.map((section, i) => {
      const images = sectionImages[i];
      const hasImages = images && images.length > 0;
      const isClosing = !hasImages;
      return (
        <section
          class:list={["homepage-stage", isClosing && "aboutStage--closing"]}
          aria-labelledby={`about-section-${i}`}
          data-reveal
        >
          <header class="stage-intro stage-intro--single">
            <div class="stage-intro__copy">
              <h2 id={`about-section-${i}`} class="stage-intro__title">
                {section.title}
              </h2>
              <p class="stage-intro__caption">{section.body}</p>
            </div>
          </header>

          {hasImages && (
            <div class="container aboutStage__showcase pageWidget" data-reveal>
              {images.map((img, imgIdx) => (
                <figure
                  class="aboutStage__frame hover-elevate"
                  data-reveal
                  data-reveal-order={imgIdx}
                  data-parallax-card
                >
                  <div class="aboutStage__imageWrap">
                    <img
                      src={img.src}
                      alt={img.alt}
                      class="aboutStage__image"
                      loading={i === 0 && imgIdx === 0 ? "eager" : "lazy"}
                      decoding="async"
                    />
                  </div>
                </figure>
              ))}
            </div>
          )}
        </section>
      );
    })}
  </div>
</Base>
