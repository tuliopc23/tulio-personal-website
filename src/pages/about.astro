---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import PhosphorIcon from "../components/PhosphorIcon.astro";
import { getAboutPageContent } from "../sanity/lib/page-content";

const pageContent = await getAboutPageContent();

if (import.meta.env.PROD && !pageContent) {
  throw new Error("[sanity] Missing required aboutPage document for the /about route.");
}

const defaults = {
  seoDescription:
    "Tulio Cunha — full stack developer. Swift, TypeScript, Go, Rust, Zig. How I think about building software.",
  heroEyebrow: "About",
  heroTitle: "I write software across the stack and across platforms. Mostly from a Mac.",
  heroLede:
    "Swift for native, TypeScript for the web, Go and Rust for the backend, Zig when I want to think harder. I care about things that work correctly under load, not just in the demo.",
  manifestoLabel: "How I think",
  manifestoTitle: "Get the internals right. The interface follows.",
  manifestoCopy:
    "I start with data flow, structure, and the parts nobody screenshots. Once the foundation is honest, the UI gets simpler — not the other way around.",
  proofBullets: [
    "Read the system before redesigning it",
    "Ship thin vertical slices, not slide decks",
    "Performance and accessibility are not afterthoughts — they’re constraints",
  ],
  principles: [
    {
      title: "Clean boundaries",
      body: "Modules, contracts, and data flow that still make sense six months from now. If the next person needs a tour guide, the architecture failed.",
    },
    {
      title: "Small diffs, fast loops",
      body: "I’d rather ship ten small PRs than one rewrite. Tight feedback beats heroic refactors every time.",
    },
    {
      title: "Restraint over decoration",
      body: "The interface should surface the work, not compete with it. Fewer elements, more clarity.",
    },
    {
      title: "Write it down",
      body: "Tradeoffs, edge cases, decisions — if it’s not written down, it didn’t happen. Future-me will thank present-me.",
    },
  ],
  timelineHeading: "Current arc",
  timelineLede:
    "Where I’m spending cycles right now and what keeps pulling me back.",
  timelineItems: [
    {
      year: "2026",
      title: "This site, rebuilt properly",
      body: "Astro, Sanity, Cloudflare Workers. A dev portfolio that’s also a real codebase — not a template with my name on it.",
    },
    {
      year: "2025",
      title: "Native and web under one roof",
      body: "Spending more time crossing between Swift apps and modern web stacks. Same engineering standards, different runtimes.",
    },
    {
      year: "Ongoing",
      title: "Writing about the work",
      body: "Platform changes, tooling decisions, runtime tradeoffs. If I figured something out the hard way, it probably deserves a post.",
    },
  ],
};

const content = {
  seoDescription: pageContent?.seoDescription ?? defaults.seoDescription,
  heroEyebrow: pageContent?.heroEyebrow ?? defaults.heroEyebrow,
  heroTitle: pageContent?.heroTitle ?? defaults.heroTitle,
  heroLede: pageContent?.heroLede ?? defaults.heroLede,
  manifestoLabel: pageContent?.manifestoLabel ?? defaults.manifestoLabel,
  manifestoTitle: pageContent?.manifestoTitle ?? defaults.manifestoTitle,
  manifestoCopy: pageContent?.manifestoCopy ?? defaults.manifestoCopy,
  proofBullets: pageContent?.proofBullets?.length
    ? pageContent.proofBullets
    : defaults.proofBullets,
  principles: pageContent?.principles?.length ? pageContent.principles : defaults.principles,
  timelineHeading: pageContent?.timelineHeading ?? defaults.timelineHeading,
  timelineLede: pageContent?.timelineLede ?? defaults.timelineLede,
  timelineItems: pageContent?.timelineItems?.length
    ? pageContent.timelineItems
    : defaults.timelineItems,
};

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/about/", siteOrigin).toString();
const description = content.seoDescription;
const _structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About Tulio Cunha",
  description,
  url: canonical,
};
---

<Base
  title="About"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "About Tulio Cunha" }}
  structuredData={_structuredData}
  sidebar={true}
>
  <div class="pageBento">
    <section class="container pageHero pageWidget" data-reveal data-reveal-type="scale">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/", icon: "home" },
          { label: "About", icon: "info" },
        ]}
      />
      <div class="pageHero__copy">
        <span class="pageHero__eyebrow">
          <PhosphorIcon name="info" size={14} weight="regular" />
          {content.heroEyebrow}
        </span>
        <h1 class="pageHero__title">{content.heroTitle}</h1>
        <p class="pageHero__lede">{content.heroLede}</p>
      </div>
    </section>

  <section class="container home__section about__manifesto pageWidget" data-reveal>
    <article
      class="about__manifestoCard surface-panel surface-panel--nested hover-elevate motion-surface-standard"
      data-parallax-card
    >
      <p class="about__manifestoLabel surface-eyebrow">
        <PhosphorIcon name="sparkle" size={14} weight="regular" />
        {content.manifestoLabel}
      </p>
      <h2 class="pageWidget__title about__manifestoTitle">{content.manifestoTitle}</h2>
      <p class="about__manifestoCopy">{content.manifestoCopy}</p>
      <ul class="about__proof" role="list" aria-label="Working principles">
        {content.proofBullets.map((item) => (
          <li class="chip-pill" role="listitem">{item}</li>
        ))}
      </ul>
    </article>
  </section>

  <section class="container home__section pageWidget" data-reveal>
      <div class="pageWidget__header">
        <span class="pageWidget__eyebrow">
          <PhosphorIcon name="briefcase" size={14} weight="regular" />
          Operating model
        </span>
        <h2 class="pageWidget__title">How I operate</h2>
        <p class="pageWidget__caption">The constraints I actually hold myself to. Not aspirational — this is how the code ships.</p>
      </div>
    <div class="cardGrid about__principles">
      {content.principles.map((principle) => (
        <article class="card card--static hover-elevate motion-surface-standard" data-parallax-card>
          <div class="card__inner">
            <div class="card__content">
              <h2 class="card-title">{principle.title}</h2>
              <p class="card-body">{principle.body}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container home__section about__timeline pageWidget" data-reveal>
      <div class="pageWidget__header">
        <span class="pageWidget__eyebrow">
          <PhosphorIcon name="clock" size={14} weight="regular" />
          Timeline
        </span>
        <h2 class="pageWidget__title">{content.timelineHeading}</h2>
        <p class="pageWidget__caption">{content.timelineLede}</p>
      </div>
      <ol class="about__timelineList">
        {content.timelineItems.map((item) => (
          <li class="hover-elevate motion-surface-standard" data-parallax-card>
            <span class="about__timelineYear">
              <PhosphorIcon name="clock" size={14} weight="regular" />
              {item.year}
            </span>
            <div>
              <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
  </div>
</Base>
