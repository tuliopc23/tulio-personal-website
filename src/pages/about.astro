---
import Base from "../layouts/Base.astro";
import { getAboutPageContent } from "../sanity/lib/page-content";

const pageContent = await getAboutPageContent();

const defaults = {
  seoDescription: "Product engineer focused on apps, tooling, and interface quality.",
  heroEyebrow: "About",
  heroTitle: "I build products with strong internals and sharp interfaces.",
  heroLede:
    "Most of my work sits between application engineering, tooling, and UI systems. I care about reliability, fast feedback loops, and software that feels deliberate in use.",
  manifestoLabel: "Core stance",
  manifestoTitle: "Make the core path solid before polishing the edges.",
  manifestoCopy:
    "I bias toward simple architectures, readable interfaces, and delivery loops that stay close to real behavior. The goal is software that is easier to ship, debug, and extend.",
  proofBullets: [
    "Map the system before styling it",
    "Ship vertical slices, not mock progress",
    "Treat motion and accessibility as quality gates",
  ],
  principles: [
    {
      title: "Systems Thinking",
      body: "Information architecture, component contracts, and content models are designed together so interfaces stay coherent as products scale.",
    },
    {
      title: "Execution Discipline",
      body: "I keep implementation close to real behavior with pragmatic validation loops, not speculative complexity.",
    },
    {
      title: "Design Language",
      body: "Apple-inspired clarity, precise spacing, and restrained visual hierarchy shape products that feel premium without being ornamental.",
    },
    {
      title: "Editorial Communication",
      body: "I document tradeoffs and decisions in plain language so teams can move faster with shared understanding.",
    },
  ],
  timelineHeading: "Current Arc",
  timelineLede:
    "The present focus across product engineering, portfolio work, and technical writing.",
  timelineItems: [
    {
      year: "2026",
      title: "Portfolio and case-study expansion",
      body: "Rebuilding this site as a more cinematic portfolio and stronger narrative layer for project outcomes.",
    },
    {
      year: "2025",
      title: "Native + web product convergence",
      body: "Bridged workflows between Apple-platform development and modern web systems to ship faster with consistent quality.",
    },
    {
      year: "Ongoing",
      title: "Tooling, performance, and interface craft",
      body: "Investing in reliable delivery pipelines and refined interaction design that hold up under real-world constraints.",
    },
  ],
};

const content = {
  seoDescription: pageContent?.seoDescription ?? defaults.seoDescription,
  heroEyebrow: pageContent?.heroEyebrow ?? defaults.heroEyebrow,
  heroTitle: pageContent?.heroTitle ?? defaults.heroTitle,
  heroLede: pageContent?.heroLede ?? defaults.heroLede,
  manifestoLabel: pageContent?.manifestoLabel ?? defaults.manifestoLabel,
  manifestoTitle: pageContent?.manifestoTitle ?? defaults.manifestoTitle,
  manifestoCopy: pageContent?.manifestoCopy ?? defaults.manifestoCopy,
  proofBullets: pageContent?.proofBullets?.length
    ? pageContent.proofBullets
    : defaults.proofBullets,
  principles: pageContent?.principles?.length ? pageContent.principles : defaults.principles,
  timelineHeading: pageContent?.timelineHeading ?? defaults.timelineHeading,
  timelineLede: pageContent?.timelineLede ?? defaults.timelineLede,
  timelineItems: pageContent?.timelineItems?.length
    ? pageContent.timelineItems
    : defaults.timelineItems,
};

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/about/", siteOrigin).toString();
const description = content.seoDescription;
const _structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About Tulio Cunha",
  description,
  url: canonical,
};
---

<Base
  title="About"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "About Tulio Cunha" }}
  structuredData={_structuredData}
  sidebar={true}
>
  <div class="pageBento">
    <section class="container pageHero pageWidget" data-reveal data-reveal-type="scale">
      <div class="pageHero__copy">
        <span class="pageHero__eyebrow">{content.heroEyebrow}</span>
        <h1 class="pageHero__title">{content.heroTitle}</h1>
        <p class="pageHero__lede">{content.heroLede}</p>
      </div>
    </section>

  <section class="container home__section about__manifesto pageWidget" data-reveal>
    <article class="about__manifestoCard hover-elevate motion-surface-standard" data-parallax-card>
      <p class="about__manifestoLabel">{content.manifestoLabel}</p>
      <h2 class="section-title">{content.manifestoTitle}</h2>
      <p class="about__manifestoCopy">{content.manifestoCopy}</p>
      <ul class="about__proof" role="list" aria-label="Working principles">
        {content.proofBullets.map((item) => <li role="listitem">{item}</li>)}
      </ul>
    </article>
  </section>

  <section class="container home__section pageWidget" data-reveal>
    <div class="pageWidget__header">
      <span class="pageWidget__eyebrow">Operating model</span>
      <h2 class="pageWidget__title">How I work</h2>
      <p class="pageWidget__caption">Product, delivery, and interface constraints I optimize for.</p>
    </div>
    <div class="cardGrid about__principles">
      {content.principles.map((principle) => (
        <article class="card card--static hover-elevate motion-surface-standard" data-parallax-card>
          <div class="card__inner">
            <div class="card__content">
              <h2 class="card-title">{principle.title}</h2>
              <p class="card-body">{principle.body}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container home__section about__timeline pageWidget" data-reveal>
    <div class="pageWidget__header">
      <span class="pageWidget__eyebrow">Timeline</span>
      <h2 class="pageWidget__title">{content.timelineHeading}</h2>
      <p class="pageWidget__caption">{content.timelineLede}</p>
    </div>
    <ol class="about__timelineList">
      {content.timelineItems.map((item) => (
        <li class="hover-elevate motion-surface-standard" data-parallax-card>
          <span class="about__timelineYear">{item.year}</span>
          <div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
  </div>
</Base>
