---
import Base from "../layouts/Base.astro";
import { getAboutPageContent } from "../sanity/lib/page-content";

const pageContent = await getAboutPageContent();

const defaults = {
  seoDescription:
    "Developer working across Apple platform apps, full-stack web, backend systems, and tooling.",
  heroEyebrow: "About",
  heroTitle: "I’m a developer working across Apple platforms, the web, and backend systems.",
  heroLede:
    "Most of my work sits where Swift apps, web software, APIs, and developer infrastructure meet. I care about reliable internals, clear interfaces, and software that holds up once it reaches real users.",
  manifestoLabel: "Core stance",
  manifestoTitle: "Strong internals first. Clear interfaces second.",
  manifestoCopy:
    "I start with the parts that make software dependable: structure, data flow, performance, and maintenance. Once the core path is solid, the interface can be simpler, faster, and easier to trust.",
  proofBullets: [
    "Understand the system before dressing it up",
    "Ship vertical slices that touch real code",
    "Treat performance, motion, and accessibility as core engineering work",
  ],
  principles: [
    {
      title: "System boundaries",
      body: "Data flow, component contracts, and page structure should stay readable long after the first release.",
    },
    {
      title: "Delivery rhythm",
      body: "I prefer small, testable slices and fast feedback over big rewrites and presentation debt.",
    },
    {
      title: "Interface restraint",
      body: "The interface should make the work legible. Precision matters more than decoration.",
    },
    {
      title: "Technical writing",
      body: "I write down tradeoffs, behavior, and implementation details so future work starts with context instead of guesswork.",
    },
  ],
  timelineHeading: "Current arc",
  timelineLede:
    "The mix of work I keep returning to across apps, the web, systems, and public notes.",
  timelineItems: [
    {
      year: "2026",
      title: "Developer-first portfolio rebuild",
      body: "Turning this site into a cleaner record of shipped work, current programming interests, and the stack behind both.",
    },
    {
      year: "2025",
      title: "Native and web in the same practice",
      body: "More time spent moving between Swift apps, modern web stacks, and the backend pieces that support them.",
    },
    {
      year: "Ongoing",
      title: "Systems, tooling, and platform notes",
      body: "Writing about Apple platforms, programming tools, runtimes, and the tradeoffs that show up once software leaves the draft stage.",
    },
  ],
};

const content = {
  seoDescription: pageContent?.seoDescription ?? defaults.seoDescription,
  heroEyebrow: pageContent?.heroEyebrow ?? defaults.heroEyebrow,
  heroTitle: pageContent?.heroTitle ?? defaults.heroTitle,
  heroLede: pageContent?.heroLede ?? defaults.heroLede,
  manifestoLabel: pageContent?.manifestoLabel ?? defaults.manifestoLabel,
  manifestoTitle: pageContent?.manifestoTitle ?? defaults.manifestoTitle,
  manifestoCopy: pageContent?.manifestoCopy ?? defaults.manifestoCopy,
  proofBullets: pageContent?.proofBullets?.length
    ? pageContent.proofBullets
    : defaults.proofBullets,
  principles: pageContent?.principles?.length ? pageContent.principles : defaults.principles,
  timelineHeading: pageContent?.timelineHeading ?? defaults.timelineHeading,
  timelineLede: pageContent?.timelineLede ?? defaults.timelineLede,
  timelineItems: pageContent?.timelineItems?.length
    ? pageContent.timelineItems
    : defaults.timelineItems,
};

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/about/", siteOrigin).toString();
const description = content.seoDescription;
const _structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About Tulio Cunha",
  description,
  url: canonical,
};
---

<Base
  title="About"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "About Tulio Cunha" }}
  structuredData={_structuredData}
  sidebar={true}
>
  <div class="pageBento">
    <section class="container pageHero pageWidget" data-reveal data-reveal-type="scale">
      <div class="pageHero__copy">
        <span class="pageHero__eyebrow">{content.heroEyebrow}</span>
        <h1 class="pageHero__title">{content.heroTitle}</h1>
        <p class="pageHero__lede">{content.heroLede}</p>
      </div>
    </section>

  <section class="container home__section about__manifesto pageWidget" data-reveal>
    <article
      class="about__manifestoCard surface-panel surface-panel--nested hover-elevate motion-surface-standard"
      data-parallax-card
    >
      <p class="about__manifestoLabel surface-eyebrow">{content.manifestoLabel}</p>
      <h2 class="pageWidget__title about__manifestoTitle">{content.manifestoTitle}</h2>
      <p class="about__manifestoCopy">{content.manifestoCopy}</p>
      <ul class="about__proof" role="list" aria-label="Working principles">
        {content.proofBullets.map((item) => (
          <li class="chip-pill" role="listitem">{item}</li>
        ))}
      </ul>
    </article>
  </section>

  <section class="container home__section pageWidget" data-reveal>
    <div class="pageWidget__header">
      <span class="pageWidget__eyebrow">Operating model</span>
      <h2 class="pageWidget__title">How I work</h2>
      <p class="pageWidget__caption">The engineering constraints I optimize for when building software.</p>
    </div>
    <div class="cardGrid about__principles">
      {content.principles.map((principle) => (
        <article class="card card--static hover-elevate motion-surface-standard" data-parallax-card>
          <div class="card__inner">
            <div class="card__content">
              <h2 class="card-title">{principle.title}</h2>
              <p class="card-body">{principle.body}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container home__section about__timeline pageWidget" data-reveal>
    <div class="pageWidget__header">
      <span class="pageWidget__eyebrow">Timeline</span>
      <h2 class="pageWidget__title">{content.timelineHeading}</h2>
      <p class="pageWidget__caption">{content.timelineLede}</p>
    </div>
    <ol class="about__timelineList">
      {content.timelineItems.map((item) => (
        <li class="hover-elevate motion-surface-standard" data-parallax-card>
          <span class="about__timelineYear">{item.year}</span>
          <div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
  </div>
</Base>
