---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import PhosphorIcon from "../components/PhosphorIcon.astro";
import { getAboutPageContent } from "../sanity/lib/page-content";

const pageContent = await getAboutPageContent();

if (import.meta.env.PROD && !pageContent) {
  throw new Error("[sanity] Missing required aboutPage document for the /about route.");
}

const defaults = {
  seoDescription:
    "Tulio Cunha — full stack developer, Mac head, Unix enthusiast, and command line junkie. Swift, TypeScript, Go, Rust, Zig. From native apps to system internals.",
  heroEyebrow: "About",
  heroTitle:
    "Full stack developer. Mac native. Unix at heart. Obsessed with how things actually run.",
  heroLede:
    "I build software across every layer of the stack — from pixel-perfect native interfaces to bare-metal system code. I care about performance, clarity, and shipping things that hold up long after the demo is over.",
  manifestoLabel: "Foundation",
  manifestoTitle: "I start where most people skip — the internals.",
  manifestoCopy:
    "Data flow, memory layout, system boundaries. I get those right first. Once the foundation is honest, the interface writes itself. The opposite never works.",
  proofBullets: [
    "Read the system before you redesign it",
    "Ship thin vertical slices, not slide decks",
    "Performance is a feature, not a phase",
    "Accessibility is a constraint, not a checklist",
  ],
  principles: [
    {
      icon: "puzzle-piece",
      title: "Modularity or bust",
      body: "Independent features, independent deploys. Every module owns its boundaries, its data, and its tests. If touching one thing breaks something else, the architecture is lying to you.",
    },
    {
      icon: "arrows-split",
      title: "Separate concerns, separate layers",
      body: "Business logic never bleeds into presentation. Data flows in one direction. The UI is a projection of state, not the owner of it. This isn't dogma — it's how code survives contact with real requirements.",
    },
    {
      icon: "lightning",
      title: "Gotta go fast",
      body: "Performance isn't a polish pass — it's a design constraint from line one. Lazy load, tree shake, measure everything. If the profiler says it's fine, ship it. If not, fix it before you add features.",
    },
    {
      icon: "paint-brush",
      title: "Interfaces that feel right",
      body: "Precise spacing, tight typography, animations that respond to physics. Clean, beautiful, engaging UI is what hooks users — they feel the difference between software that was designed and software that was just assembled.",
    },
  ],
  timelineHeading: "Current arc",
  timelineLede:
    "Where the commits are landing right now and what keeps pulling me back to the keyboard.",
  timelineItems: [
    {
      year: "2026",
      title: "This site, rebuilt from scratch",
      body: "Astro, Sanity, Cloudflare Workers. A dev portfolio that's also a real codebase — not a template with my name on it.",
    },
    {
      year: "2025",
      title: "Native and web converging",
      body: "Spending more time crossing between Swift apps and modern web stacks. Same engineering standards, different runtimes.",
    },
    {
      year: "Ongoing",
      title: "Open source and writing",
      body: "Contributing to OSS, publishing what I learn, and writing about the decisions that only surface after you ship.",
    },
  ],
  closingTitle: "Use the best tool for the job.",
  closingBody:
    "Don't love the hammer — it won't love you back. Every language, framework, and platform is a tradeoff. The skill isn't mastering one tool, it's knowing when to put it down and pick up another. I'm a freelancer, indie dev, and OSS contributor because I'd rather solve problems than defend stacks.",
};

const content = {
  seoDescription: pageContent?.seoDescription ?? defaults.seoDescription,
  heroEyebrow: pageContent?.heroEyebrow ?? defaults.heroEyebrow,
  heroTitle: pageContent?.heroTitle ?? defaults.heroTitle,
  heroLede: pageContent?.heroLede ?? defaults.heroLede,
  manifestoLabel: pageContent?.manifestoLabel ?? defaults.manifestoLabel,
  manifestoTitle: pageContent?.manifestoTitle ?? defaults.manifestoTitle,
  manifestoCopy: pageContent?.manifestoCopy ?? defaults.manifestoCopy,
  proofBullets: pageContent?.proofBullets?.length
    ? pageContent.proofBullets
    : defaults.proofBullets,
  principles: pageContent?.principles?.length ? pageContent.principles : defaults.principles,
  timelineHeading: pageContent?.timelineHeading ?? defaults.timelineHeading,
  timelineLede: pageContent?.timelineLede ?? defaults.timelineLede,
  timelineItems: pageContent?.timelineItems?.length
    ? pageContent.timelineItems
    : defaults.timelineItems,
};

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/about/", siteOrigin).toString();
const description = content.seoDescription;
const _structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About Tulio Cunha",
  description,
  url: canonical,
};

const _principleIconMap: Record<string, string> = {
  modularity: "puzzle-piece",
  separation: "arrows-split",
  performance: "lightning",
  craft: "paint-brush",
};
const _principleIconFallbacks = ["puzzle-piece", "arrows-split", "lightning", "paint-brush"];
---

<Base
  title="About"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "About Tulio Cunha" }}
  structuredData={_structuredData}
  sidebar={true}
>
  <div class="pageBento">
    <section class="container pageHero pageWidget" data-reveal data-reveal-type="scale">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/", icon: "home" },
          { label: "About", icon: "info" },
        ]}
      />
      <div class="pageHero__copy">
        <span class="pageHero__eyebrow">
          <PhosphorIcon name="info" size={14} weight="regular" />
          {content.heroEyebrow}
        </span>
        <h1 class="pageHero__title">{content.heroTitle}</h1>
        <p class="pageHero__lede">{content.heroLede}</p>
      </div>
    </section>

    <section class="homepage-stage" aria-labelledby="about-foundation-title">
      <header class="stage-intro stage-intro--single">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name="sparkle" size={14} weight="regular" />
            {content.manifestoLabel}
          </span>
          <h2 id="about-foundation-title" class="stage-intro__title">{content.manifestoTitle}</h2>
          <p class="stage-intro__caption">{content.manifestoCopy}</p>
        </div>
      </header>

      <div class="container home__section pageWidget" data-reveal>
        <ul class="about__proof" role="list" aria-label="Core beliefs">
          {content.proofBullets.map((item) => (
            <li class="chip-pill" role="listitem">
              <PhosphorIcon name="check-circle" size={14} weight="regular" />
              {item}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="homepage-stage" aria-labelledby="about-craft-title">
      <header class="stage-intro stage-intro--single">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name="code" size={14} weight="regular" />
            How I build
          </span>
          <h2 id="about-craft-title" class="stage-intro__title">Different problems, different tools. Same obsession with getting it right.</h2>
          <p class="stage-intro__caption">I move between native apps, web systems, and low-level code. Not because I can't pick a lane — because the interesting work lives at the intersections.</p>
        </div>
      </header>

      <div class="container home__section pageWidget" data-reveal>
        <div class="cardGrid about__principles">
          {content.principles.map((principle, i) => (
            <article class="card card--static hover-elevate motion-surface-standard" data-parallax-card>
              <div class="card__inner">
                <div class="card__content">
                  <span class="card__icon">
                    <PhosphorIcon
                      name={(principle as any).icon ?? _principleIconMap[(principle as any)._key ?? ""] ?? _principleIconFallbacks[i % _principleIconFallbacks.length]}
                      size={18}
                      weight="regular"
                    />
                  </span>
                  <h2 class="card-title">{principle.title}</h2>
                  <p class="card-body">{principle.body}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="homepage-stage" aria-labelledby="about-timeline-title">
      <header class="stage-intro stage-intro--single">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name="clock" size={14} weight="regular" />
            Timeline
          </span>
          <h2 id="about-timeline-title" class="stage-intro__title">{content.timelineHeading}</h2>
          <p class="stage-intro__caption">{content.timelineLede}</p>
        </div>
      </header>

      <div class="container home__section about__timeline pageWidget" data-reveal>
        <ol class="about__timelineList">
          {content.timelineItems.map((item) => (
            <li class="hover-elevate motion-surface-standard" data-parallax-card>
              <span class="about__timelineYear">
                <PhosphorIcon name="clock" size={14} weight="regular" />
                {item.year}
              </span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="homepage-stage" aria-labelledby="about-closing-title">
      <header class="stage-intro stage-intro--single">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name="wrench" size={14} weight="regular" />
            Philosophy
          </span>
          <h2 id="about-closing-title" class="stage-intro__title">{defaults.closingTitle}</h2>
          <p class="stage-intro__caption">{defaults.closingBody}</p>
        </div>
      </header>
    </section>
  </div>
</Base>
