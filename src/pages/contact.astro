---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/contact/", siteOrigin).toString();
const description = "Send a project inquiry, collaboration request, or a quick hello.";
const contactEmail = "contact@tuliocunha.dev";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact Tulio Cunha",
  description,
  url: canonical,
};
---

<Base
  title="Contact"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "Contact Tulio Cunha" }}
  structuredData={structuredData}
  sidebar={true}
>
  <div class="pageBento">
    <section class="container pageWidget" data-reveal data-reveal-type="scale">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/", icon: "home" },
          { label: "Contact", icon: "mail" },
        ]}
      />

      <div class="contactHero">
        <span class="contactHero__eyebrow">Contact</span>
        <h1 class="contactHero__title">Let's build something deliberate.</h1>
        <p class="contactHero__lede">
          Share your context and goals. I will reply by email.
        </p>
      </div>
    </section>

    <section class="container pageWidget" data-reveal>
      <div class="contactCard card card--static">
        <div class="card__inner">
          <form class="contactForm" id="contact-form" data-contact-form>
            <label class="contactForm__field">
              <span>Name</span>
              <input name="name" type="text" required autocomplete="name" />
            </label>

            <label class="contactForm__field">
              <span>Email</span>
              <input name="email" type="email" required autocomplete="email" />
            </label>

            <label class="contactForm__field">
              <span>Subject</span>
              <input
                name="subject"
                type="text"
                required
                placeholder="Project, consultation, or collaboration"
              />
            </label>

            <label class="contactForm__field contactForm__field--full">
              <span>Message</span>
              <textarea
                name="message"
                rows="7"
                required
                placeholder="Tell me what you're building, timeline, and expected outcome."
              ></textarea>
            </label>

            <div class="contactForm__actions">
              <button type="submit" class="btn contactForm__submit">Open email draft</button>
              <p class="contactForm__hint">
                This opens your default email app prefilled to {contactEmail}.
              </p>
            </div>
          </form>
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    const form = document.querySelector("[data-contact-form]");
    if (form instanceof HTMLFormElement) {
      form.addEventListener("submit", (event) => {
        event.preventDefault();
        const data = new FormData(form);

        const name = (data.get("name") || "").toString().trim();
        const email = (data.get("email") || "").toString().trim();
        const subject = (data.get("subject") || "").toString().trim();
        const message = (data.get("message") || "").toString().trim();

        const body = [
          `Name: ${name}`,
          `Email: ${email}`,
          "",
          message,
        ].join("\n");

        const mailto = `mailto:${"contact@tuliocunha.dev"}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        window.location.href = mailto;
      });
    }
  </script>
</Base>

<style>
  .contactHero {
    display: grid;
    gap: 10px;
    max-width: 60ch;
  }

  .contactHero__eyebrow {
    margin: 0;
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .contactHero__title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .contactHero__lede {
    margin: 0;
    color: var(--text-secondary);
    line-height: var(--lh-relaxed);
  }

  .contactForm {
    display: grid;
    gap: 12px;
    grid-template-columns: 1fr 1fr;
  }

  .contactForm__field {
    display: grid;
    gap: 6px;
  }

  .contactForm__field--full {
    grid-column: 1 / -1;
  }

  .contactForm__field span {
    font-size: var(--fs-footnote);
    color: var(--text-secondary);
    font-weight: var(--fw-medium);
  }

  .contactForm input,
  .contactForm textarea {
    width: 100%;
    border-radius: 12px;
    border: 1px solid var(--panel-border);
    background: color-mix(in srgb, var(--surface-card) 92%, transparent);
    color: var(--text-primary);
    padding: 10px 12px;
    font: inherit;
    transition: border-color var(--motion-duration-sm) var(--motion-ease-out);
  }

  .contactForm input:focus-visible,
  .contactForm textarea:focus-visible {
    outline: none;
    border-color: var(--blue);
    box-shadow: var(--focus-ring);
  }

  .contactForm__actions {
    grid-column: 1 / -1;
    display: grid;
    gap: 8px;
    justify-items: start;
  }

  .contactForm__hint {
    margin: 0;
    color: var(--text-tertiary);
    font-size: var(--fs-footnote);
  }

  @media (max-width: 760px) {
    .contactForm {
      grid-template-columns: 1fr;
    }
  }
</style>
