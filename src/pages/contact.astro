---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import PhosphorIcon from "../components/PhosphorIcon.astro";
import styles from "./contact.module.css";

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/contact/", siteOrigin).toString();
const description =
  "Get in touch — project work, technical questions, or just to say hi.";
const contactEmail = "contact@tuliocunha.dev";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact Tulio Cunha",
  description,
  url: canonical,
};
---

<Base
  title="Contact"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "Contact Tulio Cunha" }}
  structuredData={structuredData}
  sidebar={true}
>
  <div class="pageBento">
    <section class="container pageHero pageWidget" data-reveal data-reveal-type="scale">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/", icon: "home" },
          { label: "Contact", icon: "mail" },
        ]}
      />

      <div class="pageHero__copy">
        <h1 class="pageHero__title">Tell me what you're building and where it's stuck.</h1>
        <p class="pageHero__lede">
          Native apps, web work, backend systems, tooling — or just a sharp technical question. This form opens an email draft so you can send it straight from your mail client.
        </p>
        <div class="pageHero__meta" aria-label="Contact details">
          <a
            class:list={["pageHero__metaItem", "meta-chip", "meta-chip--signal"]}
            href={`mailto:${contactEmail}`}
          >
            <PhosphorIcon name="mail" size={14} weight="regular" />
            {contactEmail}
          </a>
        </div>
      </div>
    </section>

    <section class="container pageWidget" data-reveal>
      <div class="pageWidget__header">
        <h2 class="pageWidget__title">A good first message</h2>
        <p class="pageWidget__caption">The stack, the problem, and a rough timeline. That's enough context to start a real conversation.</p>
      </div>
      <div
        class:list={[styles.contactCard, "surface-panel", "surface-panel--nested"]}
        data-contact-card
      >
        <form class={styles.contactForm} id="contact-form" data-contact-form>
          <label class={styles.contactFormField}>
            <span id="contact-name-label">Name</span>
            <input
              name="name"
              type="text"
              required
              autocomplete="name"
              aria-labelledby="contact-name-label"
            />
          </label>

          <label class={styles.contactFormField}>
            <span id="contact-email-label">Email</span>
            <input
              name="email"
              type="email"
              required
              autocomplete="email"
              aria-labelledby="contact-email-label"
              aria-describedby="contact-email-hint"
            />
            <span id="contact-email-hint" class={styles.contactFormFieldHint}>
              Used only to reply — never added to a list.
            </span>
          </label>

          <label class={styles.contactFormField}>
            <span id="contact-subject-label">Subject</span>
            <input
              name="subject"
              type="text"
              required
              placeholder="e.g. iOS app, web platform, backend migration"
              aria-labelledby="contact-subject-label"
              aria-describedby="contact-subject-hint"
            />
            <span id="contact-subject-hint" class={styles.contactFormFieldHint}>
              One line on the product or problem area.
            </span>
          </label>

          <label class:list={[styles.contactFormField, styles.contactFormFieldFull]}>
            <span id="contact-message-label">Message</span>
            <textarea
              name="message"
              rows="7"
              required
              placeholder="What's the project, what broke (or hasn't been built yet), and what does the timeline look like?"
              aria-labelledby="contact-message-label"
              aria-describedby="contact-message-hint"
            ></textarea>
            <span id="contact-message-hint" class={styles.contactFormFieldHint}>
              Stack, constraints, and timeline help me respond with something useful.
            </span>
          </label>

          <div class={styles.contactFormActions}>
            <button type="submit" class:list={["btn", styles.contactFormButton]}>
              <PhosphorIcon name="paper-plane-tilt" size={16} weight="regular" />
              <span>Open in mail</span>
            </button>
            <p
              class={styles.contactFormStatus}
              data-contact-status
              role="status"
              aria-live="polite"
              data-kind="idle"
            />
            <p class={styles.contactFormHint}>
              <PhosphorIcon name="mail" size={14} weight="regular" />
              Opens your default mail client with a draft to {contactEmail}.
            </p>
          </div>
        </form>
      </div>
    </section>
  </div>

  <script>
    import "../scripts/contact-form";
  </script>
</Base>
