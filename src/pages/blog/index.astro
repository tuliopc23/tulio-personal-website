---
import Base from "../../layouts/Base.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PageIndicator from "../../components/PageIndicator.astro";
import ScrollHint from "../../components/ScrollHint.astro";
import PhosphorIcon from "../../components/PhosphorIcon.astro";
import { optimizedImageUrl } from "../../sanity/lib/image";
import { getBlogPageContent } from "../../sanity/lib/page-content";
import { getAllPosts, getFeaturedPosts, type PostSummary } from "../../sanity/lib/posts";

const pageContent = await getBlogPageContent();

if (import.meta.env.PROD && !pageContent) {
  throw new Error("[sanity] Missing required blogPage document for the /blog route.");
}

const formatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const defaults = {
  pageDescription:
    "Dev notes on Swift, TypeScript, Go, Rust, Zig — platforms, systems, tooling, and the tradeoffs behind real code.",
  heroEyebrow: "Writing",
  heroTitle: "Notes on building software, from the terminal up.",
  heroLede:
    "Platform deep dives, tooling takes, architecture decisions, and the kind of posts that start with 'I tried this and here's what happened.' Mostly Swift, TypeScript, Go, Rust, and systems work.",
  emptyStateTitle: "Nothing published yet",
  emptyStateBody:
    "Posts are in draft. Drop the RSS or Atom feed in your reader — the first one will show up there.",
  archiveHeading: "By year",
  archiveLede: "Everything published, sorted by when it shipped.",
  allArticlesLabel: "All posts",
  loadOlderLabel: "Load more",
};

function refineHeroLede(lede: string) {
  const normalized = lede.trim();
  if (
    normalized ===
    "From interface architecture to execution tradeoffs, this is where I document what works, what breaks, and what actually moves products forward."
  ) {
    return "From interface architecture to execution tradeoffs, this is where I document what works, what breaks, and what actually moves products forward. The focus stays on systems, product decisions, and the realities of shipping software that has to hold up outside the happy path.";
  }

  return lede;
}

function toPostEntry(post: PostSummary) {
  const date = new Date(post.publishedAt);
  const summaryWordCount = post.summary.split(/\s+/).filter(Boolean).length;
  const estimatedReadingTime = Math.max(1, Math.round(summaryWordCount / 170));
  const isNew = Date.now() - date.getTime() < 7 * 24 * 60 * 60 * 1000; // 7 days
  return {
    ...post,
    href: `/blog/${post.slug}/`,
    dateISO: date.toISOString(),
    dateLabel: formatter.format(date),
    readingTimeMinutes: post.readingTimeMinutes ?? estimatedReadingTime,
    isNew,
  };
}

const featuredCandidates = await getFeaturedPosts();
const allPosts = await getAllPosts();
const postEntries: Array<
  PostSummary & {
    href: string;
    dateISO: string;
    dateLabel: string;
    readingTimeMinutes: number;
    isNew: boolean;
  }
> = allPosts.map(toPostEntry);

const featuredPost = featuredCandidates[0] ?? allPosts[0] ?? null;
const featured = featuredPost ? toPostEntry(featuredPost) : null;
const rest = featured ? postEntries.filter((post) => post.slug !== featured.slug) : postEntries;
const spotlightTags = pageContent?.spotlightTags?.length
  ? pageContent.spotlightTags
  : ["swift", "tooling", "backend", "opinion"];
const tagSet = new Set<string>(spotlightTags);

const runtimeOrigin = Astro.url?.origin ?? "https://example.com";
const siteOrigin = Astro.site?.origin ?? runtimeOrigin;
const canonical = new URL("/blog/", siteOrigin).toString();
const content = {
  pageDescription: pageContent?.pageDescription ?? defaults.pageDescription,
  heroEyebrow: pageContent?.heroEyebrow ?? defaults.heroEyebrow,
  heroTitle: pageContent?.heroTitle ?? defaults.heroTitle,
  heroLede: refineHeroLede(pageContent?.heroLede ?? defaults.heroLede),
  emptyStateTitle: pageContent?.emptyStateTitle ?? defaults.emptyStateTitle,
  emptyStateBody: pageContent?.emptyStateBody ?? defaults.emptyStateBody,
  archiveHeading: pageContent?.archiveHeading ?? defaults.archiveHeading,
  archiveLede: pageContent?.archiveLede ?? defaults.archiveLede,
  allArticlesLabel: pageContent?.allArticlesLabel ?? defaults.allArticlesLabel,
  loadOlderLabel: pageContent?.loadOlderLabel ?? defaults.loadOlderLabel,
};
const pageDescription = content.pageDescription;
const featuredSocial = featured?.seo?.socialImage?.url
  ? featured.seo.socialImage
  : (featured?.heroImage ?? null);
const ogImage = featuredSocial?.url
  ? {
      url: optimizedImageUrl(featuredSocial.url, 1200, 630, {
        quality: 88,
        sharpen: 1.2,
        fit: "cover",
      }),
      alt: featuredSocial.alt ?? null,
      width: featuredSocial.width,
      height: featuredSocial.height,
    }
  : null;
const _structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Tulio Cunha Blog",
  description: pageDescription,
  url: canonical,
  inLanguage: "en",
  publisher: {
    "@type": "Organization",
    name: "Tulio Cunha",
    url: siteOrigin,
  },
  sameAs: [
    "https://github.com/tuliopc23",
    "https://linkedin.com/in/tuliocunha",
    "https://instagram.com/tuliopinheirocunha",
  ],
  image: ogImage?.url ? [ogImage.url] : undefined,
};

postEntries.forEach((entry) => {
  entry.tags?.forEach((tag) => {
    if (tag) {
      tagSet.add(tag);
    }
  });
});

const _uniqueTags = Array.from(tagSet).sort((a, b) => a.localeCompare(b));
const _initialDisplayCount = rest.length > 0 ? Math.min(6, rest.length) : 6;
const _byYear = postEntries.reduce((acc, post) => {
  const year = new Date(post.publishedAt).getFullYear();
  const current = acc.get(year) ?? { year, count: 0 };
  current.count += 1;
  acc.set(year, current);
  return acc;
}, new Map<number, { year: number; count: number }>());
const _archiveYears = Array.from(_byYear.values()).sort((a, b) => b.year - a.year);
const _placeholders = pageContent?.placeholderCards?.length
  ? pageContent.placeholderCards
  : [
      {
        title: "Swift and Apple platforms",
        summary:
          "Notes on native APIs, SwiftUI, platform changes, and what the WWDC sessions don't tell you.",
        href: "/blog/",
        tags: ["Preview"],
      },
      {
        title: "Backend and systems",
        summary:
          "Go, Rust, runtimes, infra. The parts of the stack nobody screenshots but everything depends on.",
        href: "/blog/",
        tags: ["Preview"],
      },
      {
        title: "Tooling and workflow",
        summary:
          "Terminal setups, editor configs, CI pipelines, and the small automations that compound over time.",
        href: "/blog/",
        tags: ["Preview"],
      },
    ];

const _sectionHeaders = {
  archive: {
    eyebrow: "Archive",
    icon: "calendar",
  },
  latest: {
    eyebrow: "Recent posts",
    title: "Latest",
    lede: "Recent writing on platforms, toolchains, and the decisions that show up once you start building.",
    icon: "notebook",
  },
} as const;
---

<Base
  title="Blog"
  description={pageDescription}
  canonical={canonical}
  ogDescription={pageDescription}
  ogImage={ogImage}
  structuredData={_structuredData}
  sidebar={true}
>
  <div class="pageBento">
  <section
    class="container blogHero pageWidget"
    data-reveal
    data-reveal-type="scale"
    data-reveal-group="blog-hero"
  >
    <div class="blogHero__breadcrumbs">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/", icon: "home" },
          { label: "Blog", icon: "book" },
        ]}
      />
    </div>
    <div class="blogHero__copy">
      <span class="blogHero__eyebrow meta-chip meta-chip--eyebrow">
        <PhosphorIcon name="article" size={14} weight="regular" />
        {content.heroEyebrow}
      </span>
      <h1 class="blogHero__title">{content.heroTitle}</h1>
      <p class="blogHero__lede">{content.heroLede}</p>
    </div>
    {
      featured ? (
        <div class="blogHero__featured">
          <ArticleCard
            href={featured.href}
            title={featured.title}
            summary={featured.summary}
            dateISO={featured.dateISO}
            dateLabel={featured.dateLabel}
            ctaLabel="Read post"
            tags={featured.tags}
            categories={featured.categories}
            readingTimeMinutes={featured.readingTimeMinutes}
            isNew={featured.isNew}
            featured={true}
            heroImage={featured.heroImage}
            coverVariant={featured.coverVariant}
            imagePriority={true}
            editorialLayout="featured-editorial"
            editorialSize="hero"
            revealGroup="blog-hero"
            revealOrder={0}
          />
        </div>
      ) : (
        <div class="blogHero__empty card">
          <h2>{content.emptyStateTitle}</h2>
          <p>{content.emptyStateBody}</p>
        </div>
      )
    }
  </section>

  {
    featured && rest.length > 0 && (
      <section
        class="container blogSurface blogSurface--feed pageWidget"
        aria-labelledby="blog-latest-title"
        data-reveal
        data-reveal-group="blog-list"
      >
        <header class="stage-intro stage-intro--single">
          <div class="stage-intro__copy">
            <span class="stage-intro__eyebrow">
              <PhosphorIcon name={_sectionHeaders.latest.icon} size={14} weight="regular" />
              {_sectionHeaders.latest.eyebrow}
            </span>
            <h2 id="blog-latest-title" class="stage-intro__title">
              {_sectionHeaders.latest.title}
            </h2>
            <p class="stage-intro__caption">
              {_sectionHeaders.latest.lede}
            </p>
          </div>
        </header>
        <div class="blogFilters blogFilters--feed">
          <p class="blogFilters__label">
            <PhosphorIcon name="folder" size={14} weight="regular" />
            Topics
          </p>
          <div class="blogFilters__scroller" role="toolbar" aria-label="Filter posts by tag">
            <button
              class:list={["blogFilters__link", "chip-pill", "chip-pill--interactive", "motion-chip", "is-active"]}
              data-blog-filter="all"
              type="button"
            >
              {content.allArticlesLabel}
            </button>
            {_uniqueTags.map((tag) => {
              const slug = tag.toLowerCase().replace(/\s+/g, "-");
              return (
                <button
                  class:list={["blogFilters__link", "chip-pill", "chip-pill--interactive", "motion-chip"]}
                  data-blog-filter={slug}
                  type="button"
                >
                  {tag}
                </button>
              );
            })}
          </div>
        </div>
        <div
          class="sr-only"
          role="status"
          aria-live="polite"
          aria-atomic="true"
          data-blog-filter-status
        />

        <div class="articleCarousel articleCarousel--feed">
          <ul
            class="articleGrid"
            data-article-list
            data-initial-count={_initialDisplayCount}
          >
            {rest.map((post, index) => (
              <li
                class="articleGrid__item"
                data-article
                data-tags={post.tags
                  .map((tag) => tag.toLowerCase().replace(/\s+/g, "-"))
                  .join(",")}
                data-index={index}
              >
                <ArticleCard
                  href={post.href}
                  title={post.title}
                  summary={post.summary}
                  dateISO={post.dateISO}
                  dateLabel={post.dateLabel}
                  ctaLabel="Read post"
                  tags={post.tags}
                  categories={post.categories}
                  readingTimeMinutes={post.readingTimeMinutes}
                  isNew={post.isNew}
                  heroImage={post.heroImage}
                  coverVariant={post.coverVariant}
                  imagePriority={index < _initialDisplayCount}
                  editorialLayout="featured-editorial"
                  editorialSize="standard"
                  revealGroup="blog-list"
                  revealOrder={index}
                />
              </li>
            ))}
            {_placeholders.map((placeholder) => (
              <li class="articleGrid__item articleGrid__item--placeholder" aria-hidden="true">
                <ArticleCard
                  href={placeholder.href}
                  title={placeholder.title}
                  summary={placeholder.summary}
                  dateISO={new Date().toISOString()}
                  dateLabel="On deck"
                  ctaLabel="Read post"
                  tags={placeholder.tags ?? []}
                  editorialLayout="featured-editorial"
                  editorialSize="standard"
                  featured={false}
                />
              </li>
            ))}
          </ul>
          <div class="blogSurface__indicator">
            <PageIndicator
              containerSelector=".articleGrid"
              itemSelector=".articleGrid__item:not([hidden])"
              ariaLabel="Articles navigation"
            />
          </div>
          <ScrollHint
            target=".articleGrid"
            variant="mobile"
            text="Scroll Left"
            storageKey="blog-featured-scroll-v4"
            ctaLabel="Scroll Left"
            ctaIcon="arrow-left"
            persist={false}
            ctaOnly={true}
          />
        </div>

        <div class="blogActions">
          <button class="blogActions__load cta-pill cta-pill--neutral motion-cta-pill" data-blog-load-more type="button">
            {content.loadOlderLabel}
          </button>
        </div>
      </section>
    )
  }

  {_archiveYears.length > 0 && (
    <section
      class="container home__section blogArchive pageWidget"
      aria-labelledby="blog-archive-title"
      data-reveal
      data-reveal-group="blog-archive"
    >
      <header class="stage-intro stage-intro--single">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name={_sectionHeaders.archive.icon} size={14} weight="regular" />
            {_sectionHeaders.archive.eyebrow}
          </span>
          <h2
            id="blog-archive-title"
            class="stage-intro__title"
            data-reveal
            data-reveal-group="blog-archive"
            data-reveal-order={0}
          >
            {content.archiveHeading}
          </h2>
          <p class="stage-intro__caption">
            {content.archiveLede}
          </p>
        </div>
      </header>
      <ul class="blogArchive__list" role="list" aria-label="Posts by year">
        {_archiveYears.map((item, index) => (
          <li class="hover-elevate motion-surface-standard" data-reveal data-reveal-group="blog-archive" data-reveal-order={index + 1} data-parallax-card>
            <span class="blogArchive__year">{item.year}</span>
            <span class="blogArchive__count">{item.count} {item.count === 1 ? "entry" : "entries"}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <script is:inline>
    const list = document.querySelector("[data-article-list]");
    const filters = Array.from(document.querySelectorAll("[data-blog-filter]"));
    const filterScroller = document.querySelector(".blogFilters__scroller");
    const loadMoreButton = document.querySelector("[data-blog-load-more]");

    if (list) {
      const cards = Array.from(list.querySelectorAll("[data-article]"));
      const initial = Number(list.dataset.initialCount ?? cards.length);
      let visibleLimit = initial;
      let activeTag = "all";

      const fadeDuration = 200;
      const phoneQuery = window.matchMedia("(max-width: 768px)");
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const revealActiveFilter = (button, immediate = false) => {
        if (!(filterScroller instanceof HTMLElement) || !(button instanceof HTMLElement)) return;

        const behavior = immediate || prefersReducedMotion ? "auto" : "smooth";
        const tag = button.dataset.blogFilter ?? "all";

        if (tag === "all") {
          filterScroller.scrollTo({ left: 0, behavior });
          return;
        }

        button.scrollIntoView({
          behavior,
          block: "nearest",
          inline: phoneQuery.matches ? "start" : "nearest",
        });
      };

      const applyFilters = () => {
        let shown = 0;
        let matches = 0;

        cards.forEach((card) => {
          const tags = (card.dataset.tags ?? "").split(",").filter(Boolean);
          const matchesTag = activeTag === "all" || tags.includes(activeTag);

          if (!matchesTag) {
            if (!card.hidden) {
              card.dataset.state = "hiding";
              setTimeout(() => {
                card.hidden = true;
                card.dataset.state = "filtered";
              }, fadeDuration);
            } else {
              card.hidden = true;
              card.dataset.state = "filtered";
            }
            return;
          }

          matches += 1;

          if (shown < visibleLimit) {
            if (card.hidden) {
              card.hidden = false;
              card.dataset.state = "showing";
              requestAnimationFrame(() => {
                card.dataset.state = "visible";
              });
            } else {
              card.dataset.state = "visible";
            }
            shown += 1;
          } else {
            card.hidden = true;
            card.dataset.state = "hidden";
          }
        });

        const hasHidden = cards.some((card) => card.dataset.state === "hidden");

        if (loadMoreButton) {
          const shouldHide = !hasHidden || matches <= visibleLimit;
          loadMoreButton.hidden = shouldHide;
          loadMoreButton.disabled = shouldHide;
        }

        // Update ARIA live region for screen readers
        const statusEl = document.querySelector("[data-blog-filter-status]");
        if (statusEl) {
          const filterLabel =
            activeTag === "all" ? "all articles" : activeTag.replace(/-/g, " ");
          statusEl.textContent = `Showing ${matches} article${matches === 1 ? "" : "s"} for ${filterLabel}`;
        }
      };

      const resetLimit = () => {
        visibleLimit = initial;
      };

      const selectFilter = (button) => {
        const tag = button.dataset.blogFilter ?? "all";
        if (activeTag === tag) {
          revealActiveFilter(button);
          return;
        }
        activeTag = tag;
        resetLimit();
        filters.forEach((chip) => chip.classList.toggle("is-active", chip === button));
        applyFilters();
        revealActiveFilter(button);
        if (phoneQuery.matches) {
          list.scrollIntoView({
            behavior: prefersReducedMotion ? "auto" : "smooth",
            block: "start",
          });
        } else {
          list.scrollTo({ left: 0, behavior: prefersReducedMotion ? "auto" : "smooth" });
        }
      };

      filters.forEach((button, index) => {
        button.addEventListener("click", () => selectFilter(button));

        // Keyboard navigation
        button.addEventListener("keydown", (e) => {
          let targetIndex = index;

          switch (e.key) {
            case "ArrowLeft":
              e.preventDefault();
              targetIndex = index > 0 ? index - 1 : filters.length - 1;
              break;
            case "ArrowRight":
              e.preventDefault();
              targetIndex = index < filters.length - 1 ? index + 1 : 0;
              break;
            case "Enter":
            case " ":
              e.preventDefault();
              selectFilter(button);
              return;
            case "Escape":
              e.preventDefault();
              filters[0].focus(); // Focus "All" filter
              return;
          }

          if (targetIndex !== index) {
            filters[targetIndex].focus();
          }
        });
      });

      loadMoreButton?.addEventListener("click", () => {
        visibleLimit += initial;
        applyFilters();
      });

      applyFilters();
      revealActiveFilter(filters[0], true);
    }
  </script>
  <style>
    @media (max-width: 768px) {
      .blogSurface--feed {
        gap: var(--space-sm);
      }

      .blogSurface--feed .stage-intro {
        gap: 8px;
      }

      .blogSurface--feed .blogFilters--feed {
        gap: 8px;
      }

      .blogSurface--feed .blogFilters__label {
        font-size: var(--fs--2);
        letter-spacing: 0.08em;
      }

      .blogSurface--feed .blogFilters__scroller {
        padding: 6px;
        border-radius: 16px;
        gap: 8px;
        scroll-snap-type: x proximity;
        scroll-padding-inline: 12px;
        overscroll-behavior-x: contain;
      }

      .blogSurface--feed .blogFilters__link {
        scroll-snap-align: start;
      }

      /* Strip the pageWidget box on mobile so cards float freely */
      .blogSurface--feed.pageWidget {
        border: none !important;
        background: transparent !important;
        box-shadow: none !important;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        border-radius: 0 !important;
        overflow: visible !important;
        padding-inline: 0 !important;
        padding-block: 0 !important;
      }

      .blogSurface--feed.pageWidget::before {
        display: none !important;
      }

      .blogSurface--feed .articleCarousel--feed {
        gap: 8px;
        position: relative;
        overflow: visible;
      }

      /* Single-card horizontal carousel on mobile — seamless, no visible rail */
      .blogSurface--feed .articleGrid {
        display: flex;
        gap: 16px;
        padding: 10px 18px 12px;
        overflow-x: auto;
        overflow-y: clip;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior-x: contain;
        scrollbar-width: none;
        background: transparent;
        margin-inline: 0;
        position: relative;
        -webkit-mask-image: linear-gradient(
          to bottom,
          black 0,
          black calc(100% - 18px),
          transparent 100%
        );
        mask-image: linear-gradient(
          to bottom,
          black 0,
          black calc(100% - 18px),
          transparent 100%
        );
      }

      .blogSurface--feed .articleGrid::-webkit-scrollbar {
        display: none;
      }

      .blogSurface--feed .articleGrid__item {
        flex: 0 0 calc(100vw - 64px);
        max-width: calc(100vw - 64px);
        animation: none;
      }

      .blogSurface--feed .articleGrid__item--placeholder {
        display: none;
      }

      /* Minimal page indicator — no track background, just floating dots */
      .blogSurface__indicator {
        display: block;
        padding: 0;
        margin-top: 0;
        position: relative;
        z-index: 2;
      }

      .blogSurface__indicator [data-page-indicator] {
        padding: 4px 0;
      }

      .blogSurface__indicator [data-page-indicator-track] {
        background: transparent;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
        box-shadow: none;
        padding: 0 8px;
        gap: 5px;
      }

      .blogSurface__indicator [data-page-indicator-slider] {
        display: none;
      }

      .blogSurface__indicator [data-page-indicator-dot] {
        width: 7px;
        height: 7px;
        background: color-mix(in srgb, var(--text-tertiary) 40%, transparent);
        box-shadow: none;
        transition: background 200ms ease, transform 200ms ease;
      }

      .blogSurface__indicator [data-page-indicator-dot][data-active="true"] {
        width: 9px;
        height: 9px;
        background: var(--blue, #0d8aff);
        box-shadow: 0 0 6px rgba(13, 138, 255, 0.3);
      }

      /* Scroll hint below dots — centered */
      .blogSurface--feed .articleCarousel--feed [data-scroll-hint] {
        display: flex;
        justify-content: center;
        margin-top: 0;
        margin-bottom: 0;
        position: relative;
        z-index: 2;
        pointer-events: auto;
      }

      /* Separate load button from the carousel — standalone with spacing */
      .blogSurface--feed .blogActions {
        margin-top: var(--space-xs);
        padding-inline: var(--container-padding, 16px);
      }
    }

    @media (max-width: 480px) {
      .blogSurface--feed .articleGrid__item {
        flex: 0 0 calc(100vw - 52px);
        max-width: calc(100vw - 52px);
      }

      .blogSurface--feed .blogFilters__scroller {
        border-radius: 14px;
        gap: 6px;
      }
    }
  </style>
  </div>
</Base>
