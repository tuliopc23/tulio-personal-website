---
import Base from "../../../layouts/Base.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import PageIndicator from "../../../components/PageIndicator.astro";
import PhosphorIcon from "../../../components/PhosphorIcon.astro";
import ScrollHint from "../../../components/ScrollHint.astro";
import { isNewPublishedAt } from "../../../lib/is-new-post";
import {
  getAllCategories,
  getCategoryBySlug,
  getPostsByCategory,
  type PostSummary,
} from "../../../sanity/lib/posts";

export const prerender = true;

export async function getStaticPaths() {
  const categories = await getAllCategories();

  return categories.map((category) => ({
    params: { slug: category.slug },
  }));
}

const { slug } = Astro.params;
if (!slug) {
  throw Astro.redirect("/404");
}

const category = await getCategoryBySlug(slug);

if (!category) {
  throw Astro.redirect("/404");
}

const posts = await getPostsByCategory(slug);

const formatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const postEntries: Array<
  PostSummary & {
    href: string;
    dateISO: string;
    dateLabel: string;
    readingTimeMinutes: number;
    isNew: boolean;
  }
> = posts.map((post) => {
  const date = new Date(post.publishedAt);
  const summaryWordCount = post.summary.split(/\s+/).filter(Boolean).length;
  const estimatedReadingTime = Math.max(1, Math.round(summaryWordCount / 170));
  const isNew = isNewPublishedAt(post.publishedAt);
  return {
    ...post,
    href: `/blog/${post.slug}/`,
    dateISO: date.toISOString(),
    dateLabel: formatter.format(date),
    readingTimeMinutes: post.readingTimeMinutes ?? estimatedReadingTime,
    isNew,
  };
});

const runtimeOrigin = Astro.url?.origin ?? "https://example.com";
const siteOrigin = Astro.site?.origin ?? runtimeOrigin;
const canonical = new URL(`/blog/category/${slug}/`, siteOrigin).toString();
const pageTitle = `${category.title} Posts`;
const pageDescription =
  category.description || `Programming posts about ${category.title} by Tulio Cunha`;
const _latestDate =
  postEntries.length > 0 ? formatter.format(new Date(postEntries[0].publishedAt)) : null;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  inLanguage: "en",
  publisher: {
    "@type": "Organization",
    name: "Tulio Cunha",
    url: siteOrigin,
  },
};
---

<Base
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  ogDescription={pageDescription}
  structuredData={structuredData}
  sidebar={true}
>
  <section
    class="container categoryHero categoryHero--feed pageWidget"
    data-reveal
    data-reveal-type="scale"
    data-reveal-group="category-hero"
  >
    <Breadcrumbs
      items={[
        { label: "Home", href: "/", icon: "home" },
        { label: "Blog", href: "/blog/", icon: "book" },
        { label: category.title, icon: "folder" },
      ]}
    />

    <div class="categoryHero__copy">
      <span class="categoryHero__eyebrow">
        <PhosphorIcon name="folder" size={14} weight="regular" />
        Topic
      </span>
      <h1 class="categoryHero__title">{category.title}</h1>
      {category.description && <p class="categoryHero__description">{category.description}</p>}
    </div>

    <div class="categoryHero__meta" role="list" aria-label="Category metadata">
      <span role="listitem" class:list={["meta-chip", "meta-chip--signal"]}>
        <PhosphorIcon name="article" size={14} weight="regular" />
        {postEntries.length} {postEntries.length === 1 ? "post" : "posts"}
      </span>
      {_latestDate && (
        <span role="listitem" class:list={["meta-chip", "meta-chip--signal"]}>
          <PhosphorIcon name="calendar" size={14} weight="regular" />
          Latest post: {_latestDate}
        </span>
      )}
    </div>
  </section>

  {postEntries.length > 0 ? (
    <section
      class="container categorySurface categorySurface--feed pageWidget"
      data-reveal
      data-reveal-group="category-list"
    >
      <ScrollHint target=".categorySurface .articleGrid" variant="all" />
      <div class="articleCarousel articleCarousel--category">
        <ul class="articleGrid">
          {postEntries.map((post, index) => (
            <li class="articleGrid__item">
              <ArticleCard
                href={post.href}
                title={post.title}
                summary={post.summary}
                dateISO={post.dateISO}
                dateLabel={post.dateLabel}
                ctaLabel="Read post"
                tags={post.tags}
                categories={post.categories}
                readingTimeMinutes={post.readingTimeMinutes}
                isNew={post.isNew}
                heroImage={post.heroImage}
                coverVariant={post.coverVariant}
                editorialLayout="featured-editorial"
                editorialSize="standard"
                revealGroup="category-list"
                revealOrder={index}
              />
            </li>
          ))}
        </ul>
        <div class="blogSurface__indicator">
          <PageIndicator
            containerSelector=".categorySurface .articleGrid"
            itemSelector=".categorySurface .articleGrid__item"
            ariaLabel="Category articles navigation"
          />
        </div>
      </div>
    </section>
  ) : (
    <section class="container home__section" data-reveal>
      <div class="categoryEmpty card card--static">
        <div class="card__inner">
          <div class="card__content">
            <span class="categoryEmpty__icon" aria-hidden="true">
              <PhosphorIcon name="folder" size={20} weight="regular" />
            </span>
            <h2 class="card-title">Nothing here yet</h2>
            <p class="card-body">
              Posts for this topic are in the works. Browse everything on the <a href="/blog/">blog</a>.
            </p>
          </div>
        </div>
      </div>
    </section>
  )}
  <style>
    @media (max-width: 768px) {
      .categoryHero--feed {
        gap: var(--space-sm);
      }

      .categoryHero--feed .categoryHero__copy {
        gap: var(--space-xs);
      }

      .categoryHero--feed .categoryHero__meta {
        gap: 8px;
      }

      .categorySurface--feed {
        gap: var(--space-sm);
      }

      .categorySurface--feed .articleCarousel--category {
        gap: 0;
      }

      .categorySurface--feed .articleGrid {
        display: grid;
        gap: var(--space-sm);
        padding: 0;
        overflow: visible;
        scroll-snap-type: none;
        scroll-padding-inline: 0;
      }

      .categorySurface--feed .articleGrid__item {
        flex: none;
        max-width: none;
        width: 100%;
        animation: none;
      }

      .categorySurface--feed :global(.scrollHint) {
        display: none;
      }
    }
  </style>
</Base>
