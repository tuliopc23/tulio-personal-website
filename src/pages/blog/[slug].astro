---
import Base from "../../layouts/Base.astro";
import ReadingProgress from "../../components/ReadingProgress.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import PhosphorIcon from "../../components/PhosphorIcon.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";
import { mdxComponents } from "../../components/mdx/mdx-components";
import { Image } from "astro:assets";
import { isNewPublishedAt } from "../../lib/is-new-post";
import { toAbsoluteUrl } from "../../lib/seo.js";
import {
  getAllPostSlugs,
  getPostBySlug,
  getRecentPosts,
  renderPostMdx,
  type PostDetail,
  type PostSummary,
} from "../../lib/content/posts";

const formatter = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const cardFormatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

export const prerender = true;

export async function getStaticPaths() {
  const slugs = await getAllPostSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug = "" } = Astro.params;
const post: PostDetail | null = await getPostBySlug(slug);

if (!post) {
  Astro.response.status = 404;
}

const postRender = slug ? await renderPostMdx(slug) : null;
const ArticleBodyContent = postRender?.Content ?? null;
const _articleHeadings = (postRender?.headings ?? [])
  .filter((heading) => heading.depth >= 2 && heading.depth <= 3)
  .map((heading) => ({
    ...heading,
    depth: heading.depth as 2 | 3,
  }));

const _related: PostSummary[] = post ? await getRecentPosts(post.slug, 3) : [];
const _dateISO = post ? new Date(post.publishedAt).toISOString() : "";
const _dateLabel = post ? formatter.format(new Date(post.publishedAt)) : "";
const _readingLabel = post ? `${post.readingTimeMinutes} min read` : "";
const defaultOrigin = Astro.url?.origin ?? "https://example.com";
const siteOrigin = Astro.site?.origin ?? "";
const shareOrigin = siteOrigin || defaultOrigin;
const shareUrl = `${shareOrigin}/blog/${slug}/`;
const _shareText = post ? encodeURIComponent(post.title) : "";
const heroImage = post?.heroImage;
const _tags = post?.tags ?? [];
const _takeaways = post?.keyTakeaways?.filter(Boolean) ?? [];
const _pullQuotes = post?.pullQuotes?.filter((entry) => entry?.quote) ?? [];
const _furtherReading = post?.furtherReading?.filter((entry) => entry?.title && entry?.href) ?? [];
const _sourceReferences =
  post?.sourceReferences?.filter((entry) => entry?.title && entry?.url) ?? [];
const _topics = post?.topics ?? [];
const _seriesRefs = post?.relatedSeries ?? [];
const _series = _seriesRefs[0]?.title ?? post?.series ?? null;
const _coverVariant = post?.coverVariant ?? "default";
const _readerDensity = post
  ? post.readingTimeMinutes <= 5
    ? "short"
    : post.readingTimeMinutes >= 12
      ? "long"
      : "medium"
  : "short";
const _primaryTopic = _topics[0]?.title ?? post?.categories?.[0]?.title ?? "Article";
const _secondaryTopic = _series ?? _topics[1]?.title ?? post?.categories?.[1]?.title ?? null;
const _footerTopics = [
  ...(_series ? [`Series: ${_series}`] : []),
  ...(_topics.map((topic) => topic.title) ?? []),
  ...(post?.categories?.map((category) => category.title) ?? []),
  ..._tags,
].filter((value, index, values) => values.indexOf(value) === index);
const _hasArticleBody = Boolean(ArticleBodyContent);
const _heroImageSrc = heroImage?.src ?? null;
const _heroCaption = heroImage?.caption?.trim() ?? "";
const _heroAspectRatio =
  _heroImageSrc && typeof _heroImageSrc === "object" && _heroImageSrc && "width" in (_heroImageSrc as any) && "height" in (_heroImageSrc as any)
    ? Number((_heroImageSrc as any).width) / Number((_heroImageSrc as any).height)
    : null;
const _heroShape = _heroAspectRatio
  ? _heroAspectRatio >= 1.7
    ? "wide"
    : _heroAspectRatio < 1.3
      ? "tall"
      : "standard"
  : "standard";
const seo = post?.seo ?? null;
const baseTitle = post?.title ?? "Article not found";
const seoTitle = seo?.metaTitle ?? baseTitle;
const seoDescription =
  seo?.metaDescription ??
  post?.summary ??
  "Programming notes from Tulio Cunha on Apple platforms, web development, systems, and tools.";
const canonical = seo?.canonicalUrl ?? shareUrl;
const _noIndex = Boolean(seo?.noIndex);
const ogImage =
  _heroImageSrc && typeof _heroImageSrc === "object" && "src" in (_heroImageSrc as any)
    ? {
        url: String((_heroImageSrc as any).src),
        alt: heroImage?.alt ?? null,
      }
    : null;
const customJsonLd =
  typeof seo?.jsonLd === "string" && seo.jsonLd.trim().length > 0 ? seo.jsonLd : null;
const _articleModifiedAt = post ? post.updatedAt : "";

const articleStructuredData = post
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: seoTitle,
      description: seoDescription,
      datePublished: post.publishedAt,
      dateModified: _articleModifiedAt,
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonical,
      },
      author: {
        "@type": "Person",
        name: post.author?.name ?? "Tulio Cunha",
        url: `${shareOrigin}/`,
      },
      publisher: {
        "@type": "Organization",
        name: "Tulio Cunha",
        url: shareOrigin,
        logo: {
          "@type": "ImageObject",
          url: `${shareOrigin}/terminal-favicon.svg`,
        },
      },
      image: ogImage?.url ? toAbsoluteUrl(ogImage.url, shareOrigin) : undefined,
      keywords: post.tags?.join(", "),
      articleSection: post.categories?.[0]?.title,
      wordCount: post ? post.readingTimeMinutes * 225 : undefined,
      inLanguage: "en",
    }
  : null;

const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: shareOrigin,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: `${shareOrigin}/blog/`,
    },
    ...(post?.categories?.[0]
      ? [
          {
            "@type": "ListItem",
            position: 3,
            name: post.categories[0].title,
            item: `${shareOrigin}/blog/category/${post.categories[0].slug}/`,
          },
        ]
      : []),
    {
      "@type": "ListItem",
      position: post?.categories?.[0] ? 4 : 3,
      name: post?.title ?? "Article",
      item: shareUrl,
    },
  ],
};

const _structuredData = customJsonLd ?? [articleStructuredData, breadcrumbStructuredData];
---

<Base
  title={seoTitle}
  description={seoDescription}
  canonical={canonical}
  ogType="article"
  ogTitle={seoTitle}
  ogDescription={seoDescription}
  ogImage={ogImage}
  articleAuthor={post?.author?.name ?? "Tulio Cunha"}
  articlePublishedTime={post?.publishedAt}
  articleModifiedTime={post ? _articleModifiedAt : undefined}
  articleTags={post?.tags}
  noIndex={_noIndex}
  structuredData={_structuredData}
  sidebar={true}
>
  {ogImage?.url && (
    <link slot="head" rel="preload" as="image" href={ogImage.url} fetchpriority="high" />
  )}
  <link
    slot="head"
    rel="preload"
    href="/fonts/new-york/v1/new-york-medium-regular.woff2"
    as="font"
    type="font/woff2"
    crossorigin="anonymous"
  />
  <ReadingProgress />
  <article
    class:list={[
      "container",
      "article",
      "pageWidget",
      `article--cover-${_coverVariant}`,
      `article--density-${_readerDensity}`,
      `article--hero-${_heroShape}`,
    ]}
    data-reveal
    data-reveal-type="scale"
    data-reveal-group="post-shell"
  >
    {
      post ? (
        <>
          <header
            class="article__header surface-panel surface-panel--premium"
            data-reveal
            data-reveal-group="post-shell"
            data-reveal-order={0}
          >
            <div class="article__breadcrumbsWrap">
              <Breadcrumbs
                variant="editorial"
                items={[
                  { label: "Home", href: "/", icon: "house" },
                  { label: "Blog", href: "/blog/", icon: "notebook" },
                  { label: post.title, icon: "article" },
                ]}
              />
            </div>
            <div class="article__headerInner">
              <p
                class:list={[
                  "article__eyebrow",
                  "meta-chip",
                  "meta-chip--eyebrow",
                  "meta-chip--accent",
                ]}
              >
                <PhosphorIcon name="article" size={14} weight="regular" />
                <span>{_primaryTopic}</span>
                {_secondaryTopic && (
                  <>
                    <span class="article__eyebrowDot" aria-hidden="true"></span>
                    <span>{_secondaryTopic}</span>
                  </>
                )}
              </p>
              <h1 class="article__title">{post.title}</h1>
              {post.summary && <p class="article__summary">{post.summary}</p>}
              {(_dateISO || _readingLabel || post.author) && (
                <div class="article__metaRail">
                  <div class="article__metaDivider" aria-hidden="true"></div>
                  <div class="article__meta">
                    {post.author && (
                      <span class="article__authorMeta">
                        <PhosphorIcon name="user" size={14} weight="regular" />
                        By {post.author.name}
                        {post.author.role && <span class="article__authorRole">{post.author.role}</span>}
                      </span>
                    )}
                    {_dateISO && (
                      <time datetime={_dateISO}>
                        <PhosphorIcon name="calendar" size={14} weight="regular" />
                        {_dateLabel}
                      </time>
                    )}
                    {_readingLabel && (
                      <span>
                        <PhosphorIcon name="clock" size={14} weight="regular" />
                        {_readingLabel}
                      </span>
                    )}
                  </div>
                </div>
              )}
            </div>
          </header>

          {_heroImageSrc && (
            <figure
              class="article__hero"
              data-reveal
              data-reveal-group="post-shell"
              data-reveal-order={1}
            >
              <Image
                src={_heroImageSrc as any}
                widths={[640, 1024, 1280, 1920, 2560]}
                sizes="(max-width: 768px) calc(100vw - 28px), (max-width: 1200px) min(100vw - 56px, 980px), 1040px"
                alt={heroImage?.alt ?? ""}
                loading="eager"
                fetchpriority="high"
                decoding="async"
              />
              {_heroCaption && <figcaption class="article__heroCaption">{_heroCaption}</figcaption>}
            </figure>
          )}

          <section
            class="article__bridge"
            aria-labelledby="article-reading-bridge-title"
            data-reveal
            data-reveal-group="post-shell"
            data-reveal-order={2}
          >
            <div class="article__bridgeCopy">
              <span class="article__bridgeEyebrow">
                <PhosphorIcon name="article" size={14} weight="regular" />
                Reader
              </span>
              <h2 id="article-reading-bridge-title" class="article__bridgeTitle">
                The long version.
              </h2>
              <p class="article__bridgeCaption">
                Implementation details, tradeoffs, and the parts that didn't fit in a tweet.
              </p>
            </div>
          </section>

          {_articleHeadings.length > 1 && (
            <details
              class="article__panel article__toc surface-panel surface-panel--nested"
              aria-labelledby="article-toc-title"
              data-reveal
              data-reveal-group="post-shell"
              data-reveal-order={3}
            >
              <summary class="article__tocSummary">
                <span class="article__sectionEyebrow">
                  <PhosphorIcon name="article" size={14} weight="regular" />
                  On this page
                </span>
                <span id="article-toc-title" class="article__tocSummaryTitle">Reader map</span>
                <span class="article__tocSummaryCount">
                  {_articleHeadings.length} sections
                  <PhosphorIcon
                    name="caret-down"
                    size={14}
                    weight="regular"
                    class="article__tocCaret"
                  />
                </span>
              </summary>
              <ol class="article__tocList">
                {_articleHeadings.map((heading) => (
                  <li class:list={["article__tocItem", `article__tocItem--depth-${heading.depth}`]}>
                    <a class="article__tocLink" href={`#${heading.slug}`}>
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ol>
            </details>
          )}

          <section
            class="article__body surface-panel surface-panel--premium"
            data-reading-body
            data-reveal
            data-reveal-group="post-shell"
            data-reveal-order={4}
          >
            {_hasArticleBody && ArticleBodyContent ? (
              <div class="articlePortable articlePortable--mdx">
                <ArticleBodyContent components={mdxComponents} />
              </div>
            ) : (
              <div class="articlePortable articlePortable--empty" role="status" aria-live="polite">
                <strong class="articlePortable--emptyTitle">Content unavailable</strong>
                <p class="articlePortable--emptyBody">
                  Could not render article body for this slug.
                </p>
              </div>
            )}
          </section>

          {_pullQuotes.length > 0 && (
            <section
              class="article__panel surface-panel surface-panel--nested"
              aria-label="Pull quotes"
              data-reveal
              data-reveal-group="post-shell"
              data-reveal-order={5}
            >
              <div class="article__sectionHeader">
                <span class="article__sectionEyebrow">
                  <PhosphorIcon name="quotes" size={14} weight="regular" />
                  Pull quotes
                </span>
                <h2 class="article__relatedTitle">Quotable bits</h2>
              </div>
              <ul class="article__resourceList">
                {_pullQuotes.map((entry) => (
                  <li class="article__resourceItem">
                    <p class="article__resourceNote">“{entry.quote}”</p>
                    {entry.attribution && <p class="article__resourceTitle">{entry.attribution}</p>}
                  </li>
                ))}
              </ul>
            </section>
          )}

          {_takeaways.length > 0 && (
            <section
              class="article__takeaways article__panel surface-panel surface-panel--nested"
              aria-label="Key takeaways"
              data-reveal
              data-reveal-group="post-shell"
              data-reveal-order={6}
            >
              <div class="article__sectionHeader">
                <span class="article__sectionEyebrow">
                  <PhosphorIcon name="check-circle" size={14} weight="regular" />
                  Key takeaways
                </span>
                <h2 class="article__relatedTitle">TL;DR</h2>
              </div>
              <ul class="article__takeawayList">
                {_takeaways.map((takeaway) => (
                  <li>{takeaway}</li>
                ))}
              </ul>
            </section>
          )}

          <footer class="article__footer" aria-label="Article footer">
            <section
              class="article__footerPanel article__footerPanel--cta surface-panel surface-panel--nested"
              data-reveal
              data-reveal-group="post-shell"
              data-reveal-order={7}
            >
              <div class="article__sectionHeader">
                <span class="article__sectionEyebrow">
                  <PhosphorIcon name="share" size={14} weight="regular" />
                  Keep going
                </span>
                <h2 class="article__relatedTitle">Share or subscribe</h2>
                <p class="article__sectionCaption">
                  Found this useful? Forward it, or add the feed to your reader.
                </p>
              </div>
              <div class="article__actionGroup" role="group" aria-label="Share article">
                <a
                  class="article__actionPill"
                  href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(shareUrl)}&text=${_shareText}`}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <PhosphorIcon name="twitter" size={16} weight="regular" />
                  Share on X (Twitter)
                </a>
                <a
                  class="article__actionPill"
                  href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(shareUrl)}&title=${_shareText}`}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <PhosphorIcon name="linkedin" size={16} weight="regular" />
                  Share on LinkedIn
                </a>
                <a class="article__actionPill" href="/rss.xml">
                  <PhosphorIcon name="rss" size={16} weight="regular" />
                  RSS
                </a>
                <a class="article__actionPill" href="/blog/atom.xml">
                  <PhosphorIcon name="rss" size={16} weight="regular" />
                  Atom
                </a>
                <a class="article__actionPill article__actionPill--secondary" href="/contact/">
                  <PhosphorIcon name="mail" size={16} weight="regular" />
                  Send a note
                </a>
              </div>

              <div class="article__ctaNewsletter" aria-label="Newsletter signup">
                <NewsletterSignup source="blog-article" />
              </div>
              {_footerTopics.length > 0 && (
                <div class="article__taxonomyRail" aria-label="Article topics">
                  <span class="article__taxonomyLabel">
                    <PhosphorIcon name="folder" size={14} weight="regular" />
                    Filed under
                  </span>
                  <ul class:list={["article__taxonomyList", "taxonomy-labels"]}>
                    {_footerTopics.map((topic) => (
                      <li class:list={["article__taxonomyItem", "taxonomy-label"]}>{topic}</li>
                    ))}
                  </ul>
                </div>
              )}
            </section>

            {_furtherReading.length > 0 && (
              <section
                class="article__footerPanel article__footerPanel--resources surface-panel surface-panel--nested"
                aria-label="Further reading"
                data-reveal
                data-reveal-group="post-shell"
                data-reveal-order={8}
              >
                <div class="article__sectionHeader">
                  <span class="article__sectionEyebrow">
                    <PhosphorIcon name="link" size={14} weight="regular" />
                    Further reading
                  </span>
                  <h2 class="article__relatedTitle">Sources and links</h2>
                  <p class="article__sectionCaption">
                    References, related reading, and links worth following from here.
                  </p>
                </div>
                <ul class="article__resourceList">
                  {_furtherReading.map((entry) => (
                    <li class="article__resourceItem">
                      <a
                        class="article__resourceLink"
                        href={entry.href}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <span class="article__resourceTitle">{entry.title}</span>
                        <PhosphorIcon name="arrow-up-right" size={16} weight="regular" />
                      </a>
                      {entry.note && <p class="article__resourceNote">{entry.note}</p>}
                    </li>
                  ))}
                </ul>
              </section>
            )}

            {_sourceReferences.length > 0 && (
              <section
                class="article__footerPanel article__footerPanel--resources surface-panel surface-panel--nested"
                aria-label="Source references"
                data-reveal
                data-reveal-group="post-shell"
                data-reveal-order={9}
              >
                <div class="article__sectionHeader">
                  <span class="article__sectionEyebrow">
                    <PhosphorIcon name="link" size={14} weight="regular" />
                    Research sources
                  </span>
                  <h2 class="article__relatedTitle">References</h2>
                  <p class="article__sectionCaption">
                    Primary sources and documentation cited in this post.
                  </p>
                </div>
                <ul class="article__resourceList">
                  {_sourceReferences.map((entry) => (
                    <li class="article__resourceItem">
                      <a
                        class="article__resourceLink"
                        href={entry.url}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <span class="article__resourceTitle">{entry.title}</span>
                        <PhosphorIcon name="arrow-up-right" size={16} weight="regular" />
                      </a>
                      {(entry.author || entry.sourceType) && (
                        <p class="article__resourceNote">
                          {[entry.author, entry.sourceType].filter(Boolean).join(" · ")}
                        </p>
                      )}
                    </li>
                  ))}
                </ul>
              </section>
            )}

            {_related.length > 0 && (
              <section
                class="article__footerPanel article__footerPanel--related surface-panel surface-panel--nested"
                aria-label="Related posts"
                data-reveal
                data-reveal-group="post-shell"
                data-reveal-order={10}
              >
                <div class="article__sectionHeader">
                  <span class="article__sectionEyebrow">
                    <PhosphorIcon name="book-open" size={14} weight="regular" />
                    Continue reading
                  </span>
                  <h2 class="article__relatedTitle">Related posts</h2>
                  <p class="article__sectionCaption">
                    More on similar topics — platforms, systems, and how things actually get built.
                  </p>
                </div>
                <div class="article__relatedGrid">
                  {_related.map((entry, index) => {
                    const relatedISO = new Date(entry.publishedAt).toISOString();
                    const relatedLabel = cardFormatter.format(new Date(entry.publishedAt));
                    const relatedIsNew = isNewPublishedAt(entry.publishedAt);
                    return (
                      <ArticleCard
                        href={`/blog/${entry.slug}/`}
                        title={entry.title}
                        summary={entry.summary}
                        dateISO={relatedISO}
                        dateLabel={relatedLabel}
                        ctaLabel="Read post"
                        tags={entry.tags}
                        categories={entry.categories}
                        readingTimeMinutes={entry.readingTimeMinutes}
                        isNew={relatedIsNew}
                        heroImage={entry.heroImage}
                        coverVariant={entry.coverVariant}
                        context="reader-related"
                        editorialLayout="featured-editorial"
                        editorialSize="standard"
                        revealGroup="related-posts"
                        revealOrder={index}
                      />
                    );
                  })}
                </div>
              </section>
            )}
          </footer>
        </>
      ) : (
        <section
          class="article__body article__panel surface-panel surface-panel--premium"
          data-reveal
          data-reveal-group="post-shell"
        >
          <p class="article__sectionEyebrow">
            <PhosphorIcon name="warning" size={14} weight="regular" />
            Missing article
          </p>
          <h1 class="article__title">Article not found</h1>
          <p class="article__summary">
            This post may have been unpublished, renamed, or moved. Head back to the
            <a class="articlePortable__link motion-link-inline" href="/blog">
              {" "}
              blog
            </a>{" "}
            to see what’s current.
          </p>
        </section>
      )
    }
  </article>
</Base>

<script>
  (() => {
    const tocList = document.querySelector<HTMLOListElement>(".article__tocList");
    if (!tocList) return;

    const links = Array.from(
      tocList.querySelectorAll<HTMLAnchorElement>(".article__tocLink"),
    );
    if (links.length === 0) return;

    const headings = links
      .map((link) => {
        const id = link.getAttribute("href")?.slice(1);
        if (!id) return null;
        const target = document.getElementById(id);
        if (!target) return null;
        return { link, target };
      })
      .filter((entry): entry is { link: HTMLAnchorElement; target: HTMLElement } =>
        Boolean(entry),
      );
    if (headings.length === 0) return;

    let current: HTMLAnchorElement | null = null;

    const setActive = (next: HTMLAnchorElement | null) => {
      if (next === current) return;
      current?.removeAttribute("aria-current");
      next?.setAttribute("aria-current", "location");
      current = next;
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .map((entry) => entry.target as HTMLElement);

        if (visible.length === 0) {
          // Pick the closest heading above the viewport.
          const above = headings
            .filter(({ target }) => target.getBoundingClientRect().top < 80)
            .pop();
          if (above) setActive(above.link);
          return;
        }

        const top = visible.reduce((a, b) =>
          a.getBoundingClientRect().top < b.getBoundingClientRect().top ? a : b,
        );
        const match = headings.find(({ target }) => target === top);
        if (match) setActive(match.link);
      },
      { rootMargin: "-72px 0px -65% 0px", threshold: 0.01 },
    );

    headings.forEach(({ target }) => observer.observe(target));
  })();
</script>
