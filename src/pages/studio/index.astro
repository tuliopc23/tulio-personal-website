---
import Base from "../../layouts/Base.astro";
import PhosphorIcon from "../../components/PhosphorIcon.astro";

export const prerender = true;

const isLocalStudioHost = Astro.url.hostname === "localhost" || Astro.url.hostname === "127.0.0.1";
let SanityStudioComponent = null;
const hostedStudioUrl = import.meta.env.PUBLIC_SANITY_STUDIO_URL;
const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/studio/", siteOrigin).toString();
const description =
  "Sanity Studio runs inside this site during local development. In production, content is edited on the hosted Studio.";

if (isLocalStudioHost) {
  // @ts-expect-error Resolved by Vite only during local embedded Studio development.
  const mod = await import(/* @vite-ignore */ "/@id/sanity:studio");
  SanityStudioComponent = mod.SanityStudio;
}
---

{
  isLocalStudioHost && SanityStudioComponent ? (
    <SanityStudioComponent />
  ) : (
    <Base
      title="Studio"
      description={description}
      canonical={canonical}
      ogDescription={description}
      ogImage={{ url: "/terminal-favicon.svg", alt: "Sanity Studio" }}
      noIndex={true}
      sidebar={false}
      mobileDrawer={false}
    >
      <div class="pageBento">
        <section class="container pageHero pageWidget" data-reveal data-reveal-type="scale">
          <div class="pageHero__copy">
            <span class="pageHero__eyebrow">
              <PhosphorIcon name="notebook" size={14} weight="regular" />
              Sanity Studio
            </span>
            <h1 class="pageHero__title">Content editing lives on the hosted Studio.</h1>
            <p class="pageHero__lede">
              The embedded editor is enabled when you run this site on localhost. For production
              updates, open the hosted Studio, publish, and the site rebuilds from the webhook.
            </p>
            <div class="pageHero__meta" aria-label="Studio actions">
              {hostedStudioUrl ? (
                <a
                  class:list={["pageHero__metaItem", "meta-chip", "meta-chip--signal"]}
                  href={hostedStudioUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <PhosphorIcon name="arrow-square-out" size={14} weight="regular" />
                  Open hosted Studio
                </a>
              ) : (
                <span class:list={["pageHero__metaItem", "meta-chip"]}>
                  <PhosphorIcon name="info" size={14} weight="regular" />
                  Set PUBLIC_SANITY_STUDIO_URL for a direct link here.
                </span>
              )}
              <a class:list={["pageHero__metaItem", "meta-chip", "meta-chip--signal"]} href="/">
                <PhosphorIcon name="house" size={14} weight="regular" />
                Back to site
              </a>
            </div>
          </div>
        </section>
      </div>
    </Base>
  )
}
