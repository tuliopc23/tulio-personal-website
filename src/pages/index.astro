---
import Base from "../layouts/Base.astro";
import FeatureWritingWidget from "../components/FeatureWritingWidget.astro";
import PhosphorIcon from "../components/PhosphorIcon.astro";
import { isNewPublishedAt } from "../lib/is-new-post";
import { getAllPosts } from "../lib/content/posts";

const posts = await getAllPosts();
const formatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const writingPosts = posts.slice(0, 3).map((post) => {
  const date = new Date(post.publishedAt);
  const summaryWordCount = post.summary.split(/\s+/).filter(Boolean).length;
  return {
    title: post.title,
    summary: post.summary,
    href: `/blog/${post.slug}/`,
    dateISO: date.toISOString(),
    dateLabel: formatter.format(date),
    readingTimeMinutes: post.readingTimeMinutes ?? Math.max(1, Math.round(summaryWordCount / 170)),
    tags: post.tags,
    categories: post.categories,
    heroImage: post.heroImage,
    coverVariant: post.coverVariant,
    isNew: isNewPublishedAt(post.publishedAt),
  };
});

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/", siteOrigin).toString();
const description =
  "Tulio Cunha — full stack developer. Swift, TypeScript, Go, Rust, and Zig. Native apps, web systems, and the backend in between.";
---

<Base
  title="Home"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/android-chrome-512x512.png", alt: "Tulio Cunha — Full Stack Developer", width: 512, height: 512 }}
  sidebar={false}
  mobileDrawer={true}
  heroPage={true}
>
  <section class="homepage-stage" aria-labelledby="homepage-exploration-title">
    <header class="stage-intro stage-intro--single">
      <div class="stage-intro__copy">
        <span class="stage-intro__eyebrow">
          <PhosphorIcon name="article" size={14} weight="regular" />
          Journal
        </span>
        <h2 id="homepage-exploration-title" class="stage-intro__title">Long-form notes on things I actually built.</h2>
      </div>
    </header>

    <div
      id="section-writing"
      class="widget-box widget-feature-writing surface-panel surface-panel--premium hover-elevate"
      data-reveal
      data-parallax-card
    >
      <div class="widget-header surface-header">
        <span class="widget-eyebrow surface-eyebrow">
          <PhosphorIcon name="article" size={13} weight="regular" />
          Journal
        </span>
        <h2 class="widget-title surface-title">
          <span>Writing</span>
          <PhosphorIcon name="article" size={18} weight="regular" />
        </h2>
      </div>
      <FeatureWritingWidget posts={writingPosts} />
    </div>
  </section>
</Base>
