---
import Base from "../layouts/Base.astro";
import ProfileCard from "../components/ProfileCard.astro";
import DockLink from "../components/DockLink.astro";
import SectionQuickNav from "../components/SectionQuickNav.astro";
import GitHubActivityWidget from "../components/GitHubActivityWidget.astro";
import FeatureWritingWidget from "../components/FeatureWritingWidget.astro";
import PhosphorIcon from "../components/PhosphorIcon.astro";
import { getAllPosts } from "../sanity/lib/posts";

const posts = await getAllPosts();
const formatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const writingPosts = posts.slice(0, 3).map((post) => {
  const date = new Date(post.publishedAt);
  const summaryWordCount = post.summary.split(/\s+/).filter(Boolean).length;
  return {
    title: post.title,
    summary: post.summary,
    href: `/blog/${post.slug}/`,
    dateLabel: formatter.format(date),
    readingTimeMinutes: post.readingTimeMinutes ?? Math.max(1, Math.round(summaryWordCount / 170)),
  };
});

const toolLinks = [
  {
    title: "Ghostty",
    href: "https://ghostty.org",
    tint: "blue",
    iconAsset: "/icons/Tools/Ghostty Dark_upscayl_2x_digital-art-4x_wrapped.svg",
  },
  {
    title: "Neovim",
    href: "https://neovim.io",
    tint: "green",
    iconAsset: "/icons/Tools/neovimlight_upscayl_2x_digital-art-4x_wrapped.svg",
  },
  {
    title: "Xcode",
    href: "https://developer.apple.com/xcode/",
    tint: "blue",
    iconAsset: "/icons/Tools/xcodelogh_upscayl_2x_digital-art-4x.svg",
  },
  {
    title: "Containers",
    href: "https://support.apple.com/guide/terminal/welcome/mac",
    tint: "cyan",
    iconAsset: "/icons/Tools/Apple Containerization_upscayl_2x_digital-art-4x.svg",
  },
  {
    title: "Transmit",
    href: "https://panic.com/transmit/",
    tint: "yellow",
    iconAsset: "/icons/Tools/Transmit_upscayl_2x_digital-art-4x.svg",
  },
  {
    title: "Tower",
    href: "https://www.git-tower.com",
    tint: "orange",
    iconAsset: "/icons/Tools/Tower.svg",
  },
  {
    title: "CodeEdit",
    href: "https://www.codeedit.app",
    tint: "blue",
    iconAsset: "/icons/Tools/Codeedit_upscayl_2x_digital-art-4x_wrapped.svg",
  },
  {
    title: "OrbStack",
    href: "https://orbstack.dev",
    tint: "indigo",
    iconAsset: "/icons/orbstack.svg",
  },
];

const stackLinks = [
  {
    title: "Swift",
    href: "https://developer.apple.com/swift/",
    tint: "orange",
    iconAsset: "/icons/stack/swift.svg",
  },
  {
    title: "Go",
    href: "https://go.dev",
    tint: "cyan",
    iconAsset: "/icons/stack/go.svg",
  },
  {
    title: "TypeScript",
    href: "https://www.typescriptlang.org",
    tint: "blue",
    iconAsset: "/icons/stack/typescript.svg",
  },
  {
    title: "React",
    href: "https://react.dev",
    tint: "blue",
    iconAsset: "/icons/stack/react.svg",
  },
  {
    title: "Vue",
    href: "https://vuejs.org",
    tint: "green",
    iconAsset: "/icons/stack/vuejs.svg",
  },
  {
    title: "Svelte",
    href: "https://svelte.dev",
    tint: "orange",
    iconAsset: "/icons/stack/svelte.svg",
  },
  {
    title: "Rust",
    href: "https://www.rust-lang.org",
    tint: "brown",
    iconAsset: "/icons/stack/rust.svg",
  },
  {
    title: "Zig",
    href: "https://ziglang.org",
    tint: "yellow",
    iconAsset: "/icons/stack/zig.svg",
  },
  {
    title: "Docker",
    href: "https://www.docker.com",
    tint: "indigo",
    iconAsset: "/icons/stack/docker.svg",
  },
];

const sectionNavItems = [
  { id: "section-profile", label: "Hello" },
  { id: "section-tools", label: "Tools" },
  { id: "section-stack", label: "Stack" },
  { id: "section-github", label: "Proof" },
  { id: "section-writing", label: "Writing" },
];

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/", siteOrigin).toString();
const description =
  "Portfolio of Tulio Cunha with shipped apps, tooling, interface systems, and build notes.";
---

<Base
  title="Home"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "Tulio Cunha portfolio" }}
  sidebar={false}
  mobileDrawer={true}
>
  <section id="top" class="bento-grid">
    <div id="section-profile" class="widget-profile">
      <ProfileCard
        name="Tulio Cunha"
        title="Full Stack Developer . Command Line Junkie . Mac Head . Unix Enthusiast . Tool Addict."
        location="Brazil"
        email="contact@tuliocunha.dev"
      />
    </div>

    <section class="homepage-stage homepage-stage--context" aria-labelledby="homepage-working-context-title">
      <header class="stage-intro">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name="terminal-window" size={14} weight="regular" />
            Working context
          </span>
          <h2 id="homepage-working-context-title" class="stage-intro__title">
            Tools, stack, and setup behind the work.
          </h2>
          <p class="stage-intro__caption">
            The day-to-day environment behind product work, developer tooling, and interface passes.
          </p>
        </div>

        <SectionQuickNav sections={sectionNavItems} />
      </header>

      <div class="widget-carousel widget-carousel--context" role="region" aria-label="Working context widgets">
        <div
          id="section-tools"
          class="widget-box widget-tools surface-panel surface-panel--premium hover-elevate"
          data-reveal
          data-parallax-card
        >
          <div class="widget-header surface-header">
            <span class="widget-eyebrow surface-eyebrow">
              <PhosphorIcon name="toolbox" size={13} weight="regular" />
              Toolkit
            </span>
            <h2 class="widget-title surface-title">
              <span>Tools</span>
              <PhosphorIcon name="toolbox" size={18} weight="regular" />
            </h2>
            <p class="widget-caption surface-caption">Utilities, workflows, and interfaces I keep close to the build.</p>
          </div>
          <div class="tools-grid" role="list" aria-label="Tools">
            {toolLinks.map((link, index) => (
              <DockLink
                href={link.href}
                title={link.title}
                tint={link.tint}
                iconAsset={link.iconAsset}
                revealOrder={index}
                sizeVariant="dock-premium"
              />
            ))}
          </div>
        </div>

        <div
          id="section-stack"
          class="widget-box widget-stack surface-panel surface-panel--premium hover-elevate"
          data-reveal
          data-parallax-card
        >
          <div class="widget-header surface-header">
            <span class="widget-eyebrow surface-eyebrow">
              <PhosphorIcon name="code" size={13} weight="regular" />
              Languages
            </span>
            <h2 class="widget-title surface-title">
              <span>Stack</span>
              <PhosphorIcon name="code" size={18} weight="regular" />
            </h2>
            <p class="widget-caption surface-caption">Languages and frameworks behind the products, tooling, and experiments.</p>
          </div>
          <div class="tools-grid" role="list" aria-label="Stack">
            {stackLinks.map((link, index) => (
              <DockLink
                href={link.href}
                title={link.title}
                tint={link.tint}
                iconAsset={link.iconAsset}
                revealOrder={index}
                sizeVariant="dock-premium"
                iconContext="stack"
              />
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="homepage-stage" aria-labelledby="homepage-proof-title">
      <header class="stage-intro stage-intro--single">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name="chart-bar" size={14} weight="regular" />
            Proof of work
          </span>
          <h2 id="homepage-proof-title" class="stage-intro__title">Recent work and visible shipping activity.</h2>
          <p class="stage-intro__caption">
            GitHub is the live signal: active repos, recent commits, and delivery rhythm.
          </p>
        </div>
      </header>

      <div
        id="section-github"
        class="widget-box widget-github surface-panel surface-panel--premium hover-elevate"
        data-reveal
        data-parallax-card
      >
        <div class="widget-header surface-header">
          <span class="widget-eyebrow surface-eyebrow">
            <PhosphorIcon name="chart-bar" size={13} weight="regular" />
            Proof of work
          </span>
          <h2 class="widget-title surface-title">
            <span>GitHub</span>
            <PhosphorIcon name="github" size={18} weight="regular" />
          </h2>
          <p class="widget-caption surface-caption">Live momentum, active work, and the cadence behind ongoing projects.</p>
        </div>
        <GitHubActivityWidget large={true} limit={10} />
      </div>
    </section>

    <section class="homepage-stage" aria-labelledby="homepage-exploration-title">
      <header class="stage-intro stage-intro--single">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name="article" size={14} weight="regular" />
            Exploration
          </span>
          <h2 id="homepage-exploration-title" class="stage-intro__title">Writing, experiments, and open threads.</h2>
          <p class="stage-intro__caption">
            Notes that sit next to the shipped work: essays, postmortems, and technical threads.
          </p>
        </div>
      </header>

      <div
        id="section-writing"
        class="widget-box widget-feature-writing surface-panel surface-panel--premium hover-elevate"
        data-reveal
        data-parallax-card
      >
        <div class="widget-header surface-header">
          <span class="widget-eyebrow surface-eyebrow">
            <PhosphorIcon name="article" size={13} weight="regular" />
            Exploration
          </span>
          <h2 class="widget-title surface-title">
            <span>Writing</span>
            <PhosphorIcon name="article" size={18} weight="regular" />
          </h2>
          <p class="widget-caption surface-caption">Essays, experiments, and technical notes kept public.</p>
        </div>
        <FeatureWritingWidget posts={writingPosts} />
      </div>
    </section>
  </section>
</Base>
