---
import Base from "../layouts/Base.astro";
import ProfileCard from "../components/ProfileCard.astro";
import DockLink from "../components/DockLink.astro";
import SectionQuickNav from "../components/SectionQuickNav.astro";
import GitHubActivityWidget from "../components/GitHubActivityWidget.astro";
import FeatureWritingWidget from "../components/FeatureWritingWidget.astro";
import { getAllPosts } from "../sanity/lib/posts";

const posts = await getAllPosts();
const formatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const writingPosts = posts.slice(0, 3).map((post) => {
  const date = new Date(post.publishedAt);
  const summaryWordCount = post.summary.split(/\s+/).filter(Boolean).length;
  return {
    title: post.title,
    summary: post.summary,
    href: `/blog/${post.slug}/`,
    dateLabel: formatter.format(date),
    readingTimeMinutes: post.readingTimeMinutes ?? Math.max(1, Math.round(summaryWordCount / 170)),
  };
});

const toolLinks = [
  {
    title: "Ghostty",
    href: "https://ghostty.org",
    tint: "blue",
    iconAsset: "/icons/Ghostty Dark_upscayl_2x_digital-art-4x_wrapped.svg",
  },
  {
    title: "Neovim",
    href: "https://neovim.io",
    tint: "green",
    iconAsset: "/icons/neovimlight_upscayl_2x_digital-art-4x_wrapped.svg",
  },
  {
    title: "Xcode",
    href: "https://developer.apple.com/xcode/",
    tint: "blue",
    iconAsset: "/icons/xcodelogh_upscayl_2x_digital-art-4x copy.svg",
  },
  {
    title: "Containers",
    href: "https://support.apple.com/guide/terminal/welcome/mac",
    tint: "cyan",
    iconAsset: "/icons/Apple Containerization_upscayl_2x_digital-art-4x.svg",
  },
  {
    title: "Transmit",
    href: "https://panic.com/transmit/",
    tint: "yellow",
    iconAsset: "/icons/Transmit_upscayl_2x_digital-art-4x.svg",
  },
  {
    title: "Tower",
    href: "https://www.git-tower.com",
    tint: "orange",
    iconAsset: "/icons/Tower.svg",
  },
  {
    title: "CodeEdit",
    href: "https://www.codeedit.app",
    tint: "blue",
    iconAsset: "/icons/Codeedit_upscayl_2x_digital-art-4x_wrapped.svg",
  },
  {
    title: "OrbStack",
    href: "https://orbstack.dev",
    tint: "indigo",
    iconAsset: "/icons/orbstack.svg",
  },
];

const sectionNavItems = [
  { id: "section-profile", label: "Profile" },
  { id: "section-tools", label: "Tools" },
  { id: "section-github", label: "GitHub" },
  { id: "section-writing", label: "Writing" },
];

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/", siteOrigin).toString();
const description =
  "Full stack developer portfolio and blog with Apple-inspired craft, polished motion, and editorial engineering depth.";
---

<Base
  title="Home"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "Tulio Cunha portfolio" }}
  sidebar={false}
>
  <section id="top" class="bento-grid">
    <div id="section-profile" class="widget-profile">
      <ProfileCard
        name="Tulio Cunha"
        title="Full Stack Developer"
        location="Brazil"
        email="contact@tuliocunha.dev"
      />
    </div>

    <SectionQuickNav sections={sectionNavItems} />

    <div class="widget-carousel" role="region" aria-label="Widget carousel">
      <div id="section-tools" class="widget-box widget-tools hover-elevate" data-reveal>
        <div class="widget-header">
          <span class="widget-eyebrow">Toolkit</span>
          <h2 class="widget-title">Tools</h2>
          <p class="widget-caption">macOS utilities that stay docked.</p>
        </div>
        <div class="tools-grid" role="list" aria-label="Tools">
          {toolLinks.map((link, index) => (
            <DockLink
              href={link.href}
              title={link.title}
              tint={link.tint}
              iconAsset={link.iconAsset}
              revealOrder={index}
            />
          ))}
        </div>
      </div>

      <div id="section-github" class="widget-box widget-github hover-elevate" data-reveal>
        <div class="widget-header">
          <span class="widget-eyebrow">Activity</span>
          <h2 class="widget-title">GitHub</h2>
          <p class="widget-caption">Latest commits and streaks.</p>
        </div>
        <GitHubActivityWidget />
      </div>

      <div id="section-writing" class="widget-box widget-feature-writing hover-elevate" data-reveal>
        <div class="widget-header">
          <span class="widget-eyebrow">Writing</span>
          <h2 class="widget-title">Feature Writing</h2>
          <p class="widget-caption">Fresh perspectives from the lab.</p>
        </div>
        <FeatureWritingWidget posts={writingPosts} />
      </div>
    </div>
  </section>
</Base>

<style is:global>
  .bento-grid {
    padding: clamp(28px, 6vw, 60px) var(--container-padding);
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    gap: clamp(20px, 2.6vw, 32px);
    grid-template-columns: repeat(12, minmax(0, 1fr));
    align-items: stretch;
  }

  .widget-profile {
    grid-column: 1 / -1;
  }

  .widget-carousel {
    display: contents;
    grid-column: 1 / -1;
  }

  .widget-box {
    --hover-elevate-translate: -6px;
    --hover-elevate-scale: 1.015;
    --hover-elevate-shadow:
      var(--shadow-card-hover),
      var(--shadow-card-highlight),
      var(--shadow-card-glow),
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 0 100px rgba(10, 132, 255, 0.08);
    --hover-elevate-border: var(--panel-border-strong);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: clamp(var(--space-4), 2vw, var(--space-5));
    padding: clamp(24px, 2.8vw, 32px);
    background: color-mix(in srgb, var(--surface-elevated) 96%, transparent);
    border: 1px solid var(--panel-border);
    border-radius: 36px;
    box-shadow:
      var(--shadow-card),
      var(--shadow-card-highlight),
      0 0 0 1px rgba(255, 255, 255, 0.04),
      0 0 60px rgba(10, 132, 255, 0.03);
    backdrop-filter: blur(var(--glass-regular-blur)) saturate(var(--glass-saturation-base));
    -webkit-backdrop-filter: blur(var(--glass-regular-blur)) saturate(var(--glass-saturation-base));
    overflow: hidden;
    grid-column: span 6;
  }

  .widget-box::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 80%);
    mix-blend-mode: screen;
    pointer-events: none;
    opacity: 0.6;
  }

  .widget-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .widget-eyebrow {
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    font-weight: var(--fw-medium);
    color: var(--text-secondary);
  }

  .widget-title {
    font-size: var(--fs-title-2);
    font-weight: 700;
    letter-spacing: var(--ls-title);
    margin: 0;
    color: var(--text-primary);
  }

  .widget-caption {
    font-size: var(--fs-subheadline);
    color: var(--text-tertiary);
    margin: 0;
    max-width: 42ch;
  }

  .widget-tools,
  .widget-github {
    grid-column: span 6;
  }

  .widget-feature-writing {
    grid-column: 1 / -1;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(var(--space-3), 1.4vw, var(--space-4));
  }

  @media (max-width: 1199px) {
    .bento-grid {
      grid-template-columns: repeat(8, minmax(0, 1fr));
    }

    .widget-tools,
    .widget-github,
    .widget-feature-writing {
      grid-column: 1 / -1;
    }

    .tools-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 767px) {
    .bento-grid {
      grid-template-columns: 1fr;
      gap: 18px;
      padding: 24px 16px 80px;
    }

    .widget-box {
      grid-column: 1 / -1;
      padding: 24px;
    }

    .tools-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
