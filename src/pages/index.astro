---
import Base from "../layouts/Base.astro";
import ProfileCard from "../components/ProfileCard.astro";
import DockLink from "../components/DockLink.astro";
import SectionQuickNav from "../components/SectionQuickNav.astro";
import GitHubActivityWidget from "../components/GitHubActivityWidget.astro";
import FeatureWritingWidget from "../components/FeatureWritingWidget.astro";
import PhosphorIcon from "../components/PhosphorIcon.astro";
import { getAllPosts } from "../sanity/lib/posts";

const posts = await getAllPosts();
const formatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const writingPosts = posts.slice(0, 3).map((post) => {
  const date = new Date(post.publishedAt);
  const summaryWordCount = post.summary.split(/\s+/).filter(Boolean).length;
  return {
    title: post.title,
    summary: post.summary,
    href: `/blog/${post.slug}/`,
    dateLabel: formatter.format(date),
    readingTimeMinutes: post.readingTimeMinutes ?? Math.max(1, Math.round(summaryWordCount / 170)),
  };
});

const toolLinks = [
  {
    title: "Ghostty",
    href: "https://ghostty.org",
    tint: "blue",
    iconAsset: "/icons/Tools/Ghostty Dark_upscayl_2x_digital-art-4x_wrapped.svg",
  },
  {
    title: "Neovim",
    href: "https://neovim.io",
    tint: "green",
    iconAsset: "/icons/Tools/neovimlight_upscayl_2x_digital-art-4x_wrapped.svg",
  },
  {
    title: "Xcode",
    href: "https://developer.apple.com/xcode/",
    tint: "blue",
    iconAsset: "/icons/Tools/xcodelogh_upscayl_2x_digital-art-4x.svg",
  },
  {
    title: "Containers",
    href: "https://support.apple.com/guide/terminal/welcome/mac",
    tint: "cyan",
    iconAsset: "/icons/Tools/Apple Containerization_upscayl_2x_digital-art-4x.svg",
  },
  {
    title: "Transmit",
    href: "https://panic.com/transmit/",
    tint: "yellow",
    iconAsset: "/icons/Tools/Transmit_upscayl_2x_digital-art-4x.svg",
  },
  {
    title: "Tower",
    href: "https://www.git-tower.com",
    tint: "orange",
    iconAsset: "/icons/Tools/Tower.svg",
  },
  {
    title: "CodeEdit",
    href: "https://www.codeedit.app",
    tint: "blue",
    iconAsset: "/icons/Tools/Codeedit_upscayl_2x_digital-art-4x_wrapped.svg",
  },
  {
    title: "OrbStack",
    href: "https://orbstack.dev",
    tint: "indigo",
    iconAsset: "/icons/orbstack.svg",
  },
];

const stackLinks = [
  {
    title: "Swift",
    href: "https://developer.apple.com/swift/",
    tint: "orange",
    iconAsset: "/icons/stack/swift.svg",
  },
  {
    title: "Go",
    href: "https://go.dev",
    tint: "cyan",
    iconAsset: "/icons/stack/go.svg",
  },
  {
    title: "TypeScript",
    href: "https://www.typescriptlang.org",
    tint: "blue",
    iconAsset: "/icons/stack/typescript.svg",
  },
  {
    title: "React",
    href: "https://react.dev",
    tint: "blue",
    iconAsset: "/icons/stack/react.svg",
  },
  {
    title: "Vue",
    href: "https://vuejs.org",
    tint: "green",
    iconAsset: "/icons/stack/vuejs.svg",
  },
  {
    title: "Svelte",
    href: "https://svelte.dev",
    tint: "orange",
    iconAsset: "/icons/stack/svelte.svg",
  },
  {
    title: "Rust",
    href: "https://www.rust-lang.org",
    tint: "brown",
    iconAsset: "/icons/stack/rust.svg",
  },
  {
    title: "Zig",
    href: "https://ziglang.org",
    tint: "yellow",
    iconAsset: "/icons/stack/zig.svg",
  },
  {
    title: "Docker",
    href: "https://www.docker.com",
    tint: "indigo",
    iconAsset: "/icons/stack/docker.svg",
  },
];

const sectionNavItems = [
  { id: "section-profile", label: "Hello" },
  { id: "section-tools", label: "Tools" },
  { id: "section-stack", label: "Stack" },
  { id: "section-github", label: "Proof" },
  { id: "section-writing", label: "Writing" },
];

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/", siteOrigin).toString();
const description =
  "Portfolio of Tulio Cunha with shipped apps, tooling, interface systems, and build notes.";
---

<Base
  title="Home"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "Tulio Cunha portfolio" }}
  sidebar={false}
>
  <section id="top" class="bento-grid">
    <div id="section-profile" class="widget-profile">
      <ProfileCard
        name="Tulio Cunha"
        title="Full-stack engineer building apps, tooling, and interface systems."
        location="Brazil"
        email="contact@tuliocunha.dev"
      />
    </div>

    <section class="homepage-stage homepage-stage--context" aria-labelledby="homepage-working-context-title">
      <header class="stage-intro">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name="terminal-window" size={14} weight="regular" />
            Working context
          </span>
          <h2 id="homepage-working-context-title" class="stage-intro__title">
            Tools, stack, and setup behind the work.
          </h2>
          <p class="stage-intro__caption">
            The day-to-day environment behind product work, developer tooling, and interface passes.
          </p>
        </div>

        <SectionQuickNav sections={sectionNavItems} />
      </header>

      <div class="widget-carousel widget-carousel--context" role="region" aria-label="Working context widgets">
        <div id="section-tools" class="widget-box widget-tools hover-elevate" data-reveal data-parallax-card>
          <div class="widget-header">
            <span class="widget-eyebrow">
              <PhosphorIcon name="toolbox" size={13} weight="regular" />
              Toolkit
            </span>
            <h2 class="widget-title">
              <span>Tools</span>
              <PhosphorIcon name="toolbox" size={18} weight="regular" />
            </h2>
            <p class="widget-caption">Utilities, workflows, and interfaces I keep close to the build.</p>
          </div>
          <div class="tools-grid" role="list" aria-label="Tools">
            {toolLinks.map((link, index) => (
              <DockLink
                href={link.href}
                title={link.title}
                tint={link.tint}
                iconAsset={link.iconAsset}
                revealOrder={index}
                sizeVariant="dock-premium"
              />
            ))}
          </div>
        </div>

        <div id="section-stack" class="widget-box widget-stack hover-elevate" data-reveal data-parallax-card>
          <div class="widget-header">
            <span class="widget-eyebrow">
              <PhosphorIcon name="code" size={13} weight="regular" />
              Languages
            </span>
            <h2 class="widget-title">
              <span>Stack</span>
              <PhosphorIcon name="code" size={18} weight="regular" />
            </h2>
            <p class="widget-caption">Languages and frameworks behind the products, tooling, and experiments.</p>
          </div>
          <div class="tools-grid" role="list" aria-label="Stack">
            {stackLinks.map((link, index) => (
              <DockLink
                href={link.href}
                title={link.title}
                tint={link.tint}
                iconAsset={link.iconAsset}
                revealOrder={index}
                sizeVariant="dock-premium"
                iconContext="stack"
              />
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="homepage-stage" aria-labelledby="homepage-proof-title">
      <header class="stage-intro stage-intro--single">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name="chart-bar" size={14} weight="regular" />
            Proof of work
          </span>
          <h2 id="homepage-proof-title" class="stage-intro__title">Recent work and visible shipping activity.</h2>
          <p class="stage-intro__caption">
            GitHub is the live signal: active repos, recent commits, and delivery rhythm.
          </p>
        </div>
      </header>

      <div id="section-github" class="widget-box widget-github hover-elevate" data-reveal data-parallax-card>
        <div class="widget-header">
          <span class="widget-eyebrow">
            <PhosphorIcon name="chart-bar" size={13} weight="regular" />
            Proof of work
          </span>
          <h2 class="widget-title">
            <span>GitHub</span>
            <PhosphorIcon name="github" size={18} weight="regular" />
          </h2>
          <p class="widget-caption">Live momentum, active work, and the cadence behind ongoing projects.</p>
        </div>
        <GitHubActivityWidget large={true} limit={10} />
      </div>
    </section>

    <section class="homepage-stage" aria-labelledby="homepage-exploration-title">
      <header class="stage-intro stage-intro--single">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name="article" size={14} weight="regular" />
            Exploration
          </span>
          <h2 id="homepage-exploration-title" class="stage-intro__title">Writing, experiments, and open threads.</h2>
          <p class="stage-intro__caption">
            Notes that sit next to the shipped work: essays, postmortems, and technical threads.
          </p>
        </div>
      </header>

      <div id="section-writing" class="widget-box widget-feature-writing hover-elevate" data-reveal data-parallax-card>
        <div class="widget-header">
          <span class="widget-eyebrow">
            <PhosphorIcon name="article" size={13} weight="regular" />
            Exploration
          </span>
          <h2 class="widget-title">
              <span>Writing</span>
            <PhosphorIcon name="article" size={18} weight="regular" />
          </h2>
          <p class="widget-caption">Essays, experiments, and technical notes kept public.</p>
        </div>
        <FeatureWritingWidget posts={writingPosts} />
      </div>
    </section>
  </section>
</Base>

<style is:global>
  .bento-grid {
    width: min(100%, var(--content-max));
    box-sizing: border-box;
    padding: clamp(14px, 2.4vw, 24px) clamp(10px, 2vw, 20px);
    max-width: var(--content-max);
    margin: 0 auto;
    display: grid;
    gap: clamp(14px, 1.8vw, 20px);
    grid-template-columns: repeat(12, minmax(0, 1fr));
    align-items: stretch;
  }

  .widget-profile {
    grid-column: 1 / -1;
    min-width: 0;
  }

  .homepage-stage {
    grid-column: 1 / -1;
    display: grid;
    gap: clamp(14px, 1.8vw, 20px);
    min-width: 0;
  }

  .stage-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(12px, 1.8vw, 20px);
    align-items: end;
    min-width: 0;
  }

  .stage-intro--single {
    grid-template-columns: minmax(0, 1fr);
  }

  .stage-intro__copy {
    display: grid;
    gap: 10px;
    max-width: 62ch;
    min-width: 0;
  }

  .stage-intro__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    font-weight: var(--fw-semibold);
    color: var(--text-secondary);
  }

  .stage-intro__eyebrow :global(svg) {
    flex: none;
    opacity: 0.82;
  }

  .stage-intro__title {
    margin: 0;
    font-size: clamp(28px, 2.4vw, 40px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 800;
    color: var(--text-primary);
  }

  .stage-intro__caption {
    margin: 0;
    max-width: 56ch;
    font-size: var(--fs-subheadline);
    line-height: var(--lh-relaxed);
    color: var(--text-tertiary);
  }

  .widget-carousel {
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(14px, 1.8vw, 20px);
    min-width: 0;
  }

  .widget-box {
    --hover-elevate-translate: -6px;
    --hover-elevate-scale: 1.015;
    --hover-elevate-shadow:
      var(--shadow-card-hover),
      var(--shadow-card-highlight),
      var(--shadow-card-glow),
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 0 100px rgba(10, 132, 255, 0.08);
    --hover-elevate-border: color-mix(in srgb, var(--panel-border-strong) 82%, transparent);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: clamp(var(--space-xs), 1.2vw, var(--space-sm));
    padding: clamp(14px, 1.5vw, 18px);
    background: color-mix(in srgb, var(--surface-elevated) 96%, transparent);
    border: 1px solid color-mix(in srgb, var(--panel-border) 84%, transparent);
    border-radius: 26px;
    box-shadow:
      var(--shadow-card),
      var(--shadow-card-highlight),
      0 0 0 1px rgba(255, 255, 255, 0.04),
      0 22px 44px rgba(5, 8, 18, 0.42),
      0 0 80px rgba(10, 132, 255, 0.08);
    backdrop-filter: blur(var(--glass-regular-blur)) saturate(var(--glass-saturation-base));
    -webkit-backdrop-filter: blur(var(--glass-regular-blur)) saturate(var(--glass-saturation-base));
    overflow: hidden;
    grid-column: auto;
    min-width: 0;
  }

  .widget-box::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), transparent 80%);
    mix-blend-mode: screen;
    pointer-events: none;
    opacity: 0.48;
  }

  .widget-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .widget-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    font-weight: var(--fw-medium);
    color: var(--text-secondary);
  }

  .widget-title {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-title-3);
    font-weight: 800;
    letter-spacing: var(--ls-title);
    margin: 0;
    color: var(--text-primary);
  }

  .widget-caption {
    font-size: var(--fs-subheadline);
    color: var(--text-tertiary);
    margin: 0;
    max-width: 42ch;
  }

  .widget-tools,
  .widget-stack {
    grid-column: auto;
  }

  .widget-github,
  .widget-feature-writing {
    grid-column: 1 / -1;
  }

  .widget-github {
    min-height: clamp(360px, 34vw, 520px);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(var(--space-3), 1.4vw, var(--space-4));
  }

  @media (max-width: 1199px) {
    .bento-grid {
      grid-template-columns: repeat(8, minmax(0, 1fr));
    }

    .stage-intro {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .widget-carousel {
      grid-template-columns: 1fr;
    }

    .tools-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 14px;
      padding: 14px 10px 44px;
    }

    .stage-intro__title {
      font-size: clamp(24px, 8vw, 32px);
    }

    .widget-box {
      grid-column: 1 / -1;
      padding: 18px;
    }

    .widget-github {
      min-height: clamp(300px, 74vw, 420px);
    }

    .tools-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
