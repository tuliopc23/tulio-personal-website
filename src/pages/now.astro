---
import Base from "../layouts/Base.astro";

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/now/", siteOrigin).toString();
const description = "What Tulio Cunha is currently building, refining, and preparing next.";
const _lastUpdated = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(new Date());
const _structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Now - Tulio Cunha",
  description,
  url: canonical,
};
---

<Base
  title="Now"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "Tulio Cunha current focus" }}
  structuredData={_structuredData}
  sidebar={true}
>
  <section class="container blogHero" data-reveal data-reveal-type="scale">
    <div class="blogHero__copy">
      <span class="blogHero__eyebrow">Now</span>
      <h1 class="blogHero__title">Live priorities, not static intentions.</h1>
      <p class="blogHero__lede">
        A transparent snapshot of what I am shipping now, what is queued next, and where my
        attention is headed.
      </p>
    </div>
    <p class="now__updated">Last updated: {_lastUpdated}</p>
  </section>

  <section class="container home__section now__roadmap" data-reveal>
    <div class="now__columns" role="list" aria-label="Roadmap stages">
      <article class="now__column" role="listitem">
        <h2>Now</h2>
        <ul>
          <li>Portfolio redesign and storytelling depth expansion</li>
          <li>Case studies with stronger context, tradeoffs, and impact</li>
          <li>Motion and editorial polish across primary pages</li>
        </ul>
      </article>
      <article class="now__column" role="listitem">
        <h2>Next</h2>
        <ul>
          <li>Blog templates with richer narrative and illustration blocks</li>
          <li>Project-by-project technical postmortems</li>
          <li>Better publishing pipeline ergonomics in Sanity</li>
        </ul>
      </article>
      <article class="now__column" role="listitem">
        <h2>Later</h2>
        <ul>
          <li>Interactive showcase modules for selected product work</li>
          <li>Expanded writing series on design systems and delivery</li>
          <li>Public playbooks for engineering + interface quality</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="container home__section now__signals" data-reveal>
    <div class="home__selectedHeader">
      <h2 class="section-title">Execution Signals</h2>
      <p class="home__selectedLede">
        What indicates this current direction is working.
      </p>
    </div>
    <div class="now__signalGrid">
      <article class="card card--static">
        <div class="card__inner">
          <div class="card__content">
            <h3 class="card-title">Clearer narrative flow</h3>
            <p class="card-body">
              Visitors can understand scope, depth, and outcomes quickly without losing
              detail.
            </p>
          </div>
        </div>
      </article>
      <article class="card card--static">
        <div class="card__inner">
          <div class="card__content">
            <h3 class="card-title">Higher publishing cadence</h3>
            <p class="card-body">
              More frequent articles and case-study updates with consistent editorial quality.
            </p>
          </div>
        </div>
      </article>
      <article class="card card--static">
        <div class="card__inner">
          <div class="card__content">
            <h3 class="card-title">Stronger design consistency</h3>
            <p class="card-body">
              Shared motion, spacing, and visual language across home, projects, and blog.
            </p>
          </div>
        </div>
      </article>
    </div>
  </section>
</Base>
