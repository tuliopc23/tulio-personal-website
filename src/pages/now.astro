---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import GitHubActivityWidget from "../components/GitHubActivityWidget.astro";
import PhosphorIcon from "../components/PhosphorIcon.astro";
import { getNowPageContent } from "../sanity/lib/page-content";

const pageContent = await getNowPageContent();

const defaults = {
  seoDescription:
    "What I am building now across Apple apps, web work, backend systems, and developer notes.",
  heroEyebrow: "Now",
  heroTitle: "What I’m building now, what’s next, and what’s on deck.",
  heroLede:
    "A working snapshot of the code, platforms, tools, and essays that currently have attention.",
  nowItems: [
    "Swift work for Apple platforms, especially macOS-first ideas",
    "Full-stack web and backend work that shares the same engineering discipline",
    "Essays on platform changes, tooling, and current programming topics",
  ],
  nextItems: [
    "More project write-ups with architecture and implementation detail",
    "More essays on Apple platforms, local AI, and implementation tradeoffs",
    "Small improvements to the publishing flow and project index",
  ],
  laterItems: [
    "Small tools in Zig, Rust, and Go",
    "More experiments around local tooling, automation, and developer UX",
    "Deeper comparisons between native and web implementation patterns",
  ],
  signalsHeading: "What success looks like",
  signalsLede: "The signals I watch to know the current mix of work is healthy.",
  executionSignals: [
    {
      title: "Shipped code stays visible",
      body: "Projects, commits, and notes should reflect real work rather than placeholder narrative.",
    },
    {
      title: "One practice across platforms",
      body: "The same standards should hold across Swift apps, web products, backend work, and systems code.",
    },
    {
      title: "Writing stays close to the work",
      body: "The blog should track current platform changes, tools, and opinions that come directly from programming work.",
    },
  ],
  githubHeading: "GitHub activity",
  githubLede: "Recent commits across active repositories.",
};

const content = {
  seoDescription: pageContent?.seoDescription ?? defaults.seoDescription,
  heroEyebrow: pageContent?.heroEyebrow ?? defaults.heroEyebrow,
  heroTitle: pageContent?.heroTitle ?? defaults.heroTitle,
  heroLede: pageContent?.heroLede ?? defaults.heroLede,
  lastUpdated: pageContent?.lastUpdated ?? new Date().toISOString(),
  nowItems: pageContent?.nowItems?.length ? pageContent.nowItems : defaults.nowItems,
  nextItems: pageContent?.nextItems?.length ? pageContent.nextItems : defaults.nextItems,
  laterItems: pageContent?.laterItems?.length ? pageContent.laterItems : defaults.laterItems,
  signalsHeading: pageContent?.signalsHeading ?? defaults.signalsHeading,
  signalsLede: pageContent?.signalsLede ?? defaults.signalsLede,
  executionSignals: pageContent?.executionSignals?.length
    ? pageContent.executionSignals
    : defaults.executionSignals,
  githubHeading: pageContent?.githubHeading ?? defaults.githubHeading,
  githubLede: pageContent?.githubLede ?? defaults.githubLede,
};

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/now/", siteOrigin).toString();
const description = content.seoDescription;
const _lastUpdated = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(new Date(content.lastUpdated));
const _structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Now - Tulio Cunha",
  description,
  url: canonical,
};
---

<Base
  title="Now"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "Tulio Cunha current focus" }}
  structuredData={_structuredData}
  sidebar={true}
>
  <div class="pageBento">
    <section class="container pageHero pageWidget" data-reveal data-reveal-type="scale">
    <Breadcrumbs
      items={[
        { label: "Home", href: "/", icon: "home" },
        { label: "Now", icon: "clock" },
      ]}
    />
    <div class="pageHero__copy">
      <span class="pageHero__eyebrow">
        <PhosphorIcon name="clock" size={14} weight="regular" />
        {content.heroEyebrow}
      </span>
      <h1 class="pageHero__title">{content.heroTitle}</h1>
      <p class="pageHero__lede">{content.heroLede}</p>
      <div class="pageHero__meta" aria-label="Now page overview">
        <span class:list={["pageHero__metaItem", "meta-chip", "meta-chip--signal"]}>
          <PhosphorIcon name="calendar-check" size={14} weight="regular" />
          Updated {_lastUpdated}
        </span>
        <span class:list={["pageHero__metaItem", "meta-chip", "meta-chip--signal"]}>
          <PhosphorIcon name="notebook" size={14} weight="regular" />
          Now / Next / Later
        </span>
      </div>
    </div>
    </section>

    <section class="container home__section now__roadmap pageWidget" data-reveal>
      <div class="pageWidget__header">
        <span class="pageWidget__eyebrow">
          <PhosphorIcon name="notebook" size={14} weight="regular" />
          Queue
        </span>
        <h2 class="pageWidget__title">What has attention right now</h2>
        <p class="pageWidget__caption">A rough split between active engineering work, near-term follow-ups, and ideas I want to earn time for.</p>
      </div>
      <div class="now__columns" role="list" aria-label="Roadmap stages">
      <article class="now__column hover-elevate motion-surface-standard" role="listitem" data-parallax-card>
        <h2>
          <PhosphorIcon name="sparkle" size={16} weight="regular" />
          Now
        </h2>
        <ul>
          {content.nowItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="now__column hover-elevate motion-surface-standard" role="listitem" data-parallax-card>
        <h2>
          <PhosphorIcon name="arrow-right" size={16} weight="regular" />
          Next
        </h2>
        <ul>
          {content.nextItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="now__column hover-elevate motion-surface-standard" role="listitem" data-parallax-card>
        <h2>
          <PhosphorIcon name="clock" size={16} weight="regular" />
          Later
        </h2>
        <ul>
          {content.laterItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      </div>
    </section>

    <section class="container home__section now__signals pageWidget" data-reveal>
      <div class="pageWidget__header">
        <span class="pageWidget__eyebrow">
          <PhosphorIcon name="chart-bar" size={14} weight="regular" />
          Signals
        </span>
        <h2 class="pageWidget__title">{content.signalsHeading}</h2>
        <p class="pageWidget__caption">{content.signalsLede}</p>
      </div>
      <div class="now__signalGrid">
      {content.executionSignals.map((signal) => (
        <article class="card card--static hover-elevate motion-surface-standard" data-parallax-card>
          <div class="card__inner">
            <div class="card__content">
              <h3 class="card-title">{signal.title}</h3>
              <p class="card-body">{signal.body}</p>
            </div>
          </div>
        </article>
      ))}
      </div>
    </section>

    <section class="container home__section now__github pageWidget" data-reveal>
      <div class="pageWidget__header">
        <span class="pageWidget__eyebrow">
          <PhosphorIcon name="github" size={14} weight="regular" />
          Activity
        </span>
        <h2 class="pageWidget__title">{content.githubHeading}</h2>
        <p class="pageWidget__caption">{content.githubLede}</p>
      </div>
      <GitHubActivityWidget live={true} large={true} limit={12} />
    </section>
  </div>
</Base>
