---
import Base from "../layouts/Base.astro";
import GitHubActivityWidget from "../components/GitHubActivityWidget.astro";
import { getNowPageContent } from "../sanity/lib/page-content";

const pageContent = await getNowPageContent();

const defaults = {
  seoDescription: "What Tulio Cunha is currently building, refining, and preparing next.",
  heroEyebrow: "Now",
  heroTitle: "Live priorities, not static intentions.",
  heroLede:
    "A transparent snapshot of what I am shipping now, what is queued next, and where my attention is headed.",
  nowItems: [
    "Portfolio redesign and storytelling depth expansion",
    "Case studies with stronger context, tradeoffs, and impact",
    "Motion and editorial polish across primary pages",
  ],
  nextItems: [
    "Blog templates with richer narrative and illustration blocks",
    "Project-by-project technical postmortems",
    "Better publishing pipeline ergonomics in Sanity",
  ],
  laterItems: [
    "Interactive showcase modules for selected product work",
    "Expanded writing series on design systems and delivery",
    "Public playbooks for engineering + interface quality",
  ],
  signalsHeading: "Execution Signals",
  signalsLede: "What indicates this current direction is working.",
  executionSignals: [
    {
      title: "Clearer narrative flow",
      body: "Visitors can understand scope, depth, and outcomes quickly without losing detail.",
    },
    {
      title: "Higher publishing cadence",
      body: "More frequent articles and case-study updates with consistent editorial quality.",
    },
    {
      title: "Stronger design consistency",
      body: "Shared motion, spacing, and visual language across home, projects, and blog.",
    },
  ],
  githubHeading: "Live GitHub Stream",
  githubLede: "Real-time commit activity across active repositories.",
};

const content = {
  seoDescription: pageContent?.seoDescription ?? defaults.seoDescription,
  heroEyebrow: pageContent?.heroEyebrow ?? defaults.heroEyebrow,
  heroTitle: pageContent?.heroTitle ?? defaults.heroTitle,
  heroLede: pageContent?.heroLede ?? defaults.heroLede,
  lastUpdated: pageContent?.lastUpdated ?? new Date().toISOString(),
  nowItems: pageContent?.nowItems?.length ? pageContent.nowItems : defaults.nowItems,
  nextItems: pageContent?.nextItems?.length ? pageContent.nextItems : defaults.nextItems,
  laterItems: pageContent?.laterItems?.length ? pageContent.laterItems : defaults.laterItems,
  signalsHeading: pageContent?.signalsHeading ?? defaults.signalsHeading,
  signalsLede: pageContent?.signalsLede ?? defaults.signalsLede,
  executionSignals: pageContent?.executionSignals?.length
    ? pageContent.executionSignals
    : defaults.executionSignals,
  githubHeading: pageContent?.githubHeading ?? defaults.githubHeading,
  githubLede: pageContent?.githubLede ?? defaults.githubLede,
};

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const canonical = new URL("/now/", siteOrigin).toString();
const description = content.seoDescription;
const _lastUpdated = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(new Date(content.lastUpdated));
const _structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Now - Tulio Cunha",
  description,
  url: canonical,
};
---

<Base
  title="Now"
  description={description}
  canonical={canonical}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "Tulio Cunha current focus" }}
  structuredData={_structuredData}
  sidebar={true}
>
  <div class="pageBento">
    <section class="container blogHero pageWidget" data-reveal data-reveal-type="scale">
    <div class="blogHero__copy">
      <span class="blogHero__eyebrow">{content.heroEyebrow}</span>
      <h1 class="blogHero__title">{content.heroTitle}</h1>
      <p class="blogHero__lede">{content.heroLede}</p>
    </div>
    <p class="now__updated">Last updated: {_lastUpdated}</p>
    </section>

    <section class="container home__section now__roadmap pageWidget" data-reveal>
      <div class="now__columns" role="list" aria-label="Roadmap stages">
      <article class="now__column hover-elevate motion-surface-standard" role="listitem" data-parallax-card>
        <h2>Now</h2>
        <ul>
          {content.nowItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="now__column hover-elevate motion-surface-standard" role="listitem" data-parallax-card>
        <h2>Next</h2>
        <ul>
          {content.nextItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="now__column hover-elevate motion-surface-standard" role="listitem" data-parallax-card>
        <h2>Later</h2>
        <ul>
          {content.laterItems.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      </div>
    </section>

    <section class="container home__section now__signals pageWidget" data-reveal>
      <div class="home__selectedHeader">
        <h2 class="section-title">{content.signalsHeading}</h2>
        <p class="home__selectedLede">{content.signalsLede}</p>
      </div>
      <div class="now__signalGrid">
      {content.executionSignals.map((signal) => (
        <article class="card card--static hover-elevate motion-surface-standard" data-parallax-card>
          <div class="card__inner">
            <div class="card__content">
              <h3 class="card-title">{signal.title}</h3>
              <p class="card-body">{signal.body}</p>
            </div>
          </div>
        </article>
      ))}
      </div>
    </section>

    <section class="container home__section now__github pageWidget" data-reveal>
      <div class="home__selectedHeader">
        <span class="pageWidget__eyebrow">Activity</span>
        <h2 class="section-title">{content.githubHeading}</h2>
        <p class="home__selectedLede">{content.githubLede}</p>
      </div>
      <GitHubActivityWidget live={true} large={true} limit={12} />
    </section>
  </div>
</Base>
