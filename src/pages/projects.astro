---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getAllProjects } from "../sanity/lib/projects";
import { getProjectsPageContent } from "../sanity/lib/page-content";
import { PROJECT_CATEGORIES } from "../sanity/project-categories";
import projectsFiltersScriptHref from "../scripts/projects-filters.ts?url";

const projects = await getAllProjects();
const pageContent = await getProjectsPageContent();

const defaults = {
  description:
    "Selected work across Apple apps, full-stack web products, backend services, and developer tooling.",
  heroEyebrow: "Selected work",
  heroTitle: "Projects",
  heroLede:
    "A selection of Apple apps, web software, backend services, and developer tools I have built or contributed to.",
  filterEmptyTitle: "No projects in this slice yet",
  filterEmptyBody:
    "Try another track, or email if you want technical context on work that is not written up here:",
  pageEmptyTitle: "Project notes are being prepared",
  pageEmptyBody:
    "The work exists. The write-ups are catching up. Email if you want implementation details:",
  contactEmail: "contact@tuliocunha.dev",
};

const content = {
  description: pageContent?.description ?? defaults.description,
  heroEyebrow: pageContent?.heroEyebrow ?? defaults.heroEyebrow,
  heroTitle: pageContent?.heroTitle ?? defaults.heroTitle,
  heroLede: pageContent?.heroLede ?? defaults.heroLede,
  filterEmptyTitle: pageContent?.filterEmptyTitle ?? defaults.filterEmptyTitle,
  filterEmptyBody: pageContent?.filterEmptyBody ?? defaults.filterEmptyBody,
  pageEmptyTitle: pageContent?.pageEmptyTitle ?? defaults.pageEmptyTitle,
  pageEmptyBody: pageContent?.pageEmptyBody ?? defaults.pageEmptyBody,
  contactEmail: pageContent?.contactEmail ?? defaults.contactEmail,
};

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const description = content.description;
const canonicalUrl = new URL("/projects/", siteOrigin).toString();
const _hasProjects = projects.length > 0;
const _projectFilters = [
  { id: "all", label: "All" },
  ...PROJECT_CATEGORIES.map(({ value, label }) => ({ id: value, label })),
];

const _structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Tulio Cunha Projects",
  description,
  url: canonicalUrl,
};
---

<Base
  title="Projects"
  description={description}
  canonical={canonicalUrl}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "Projects preview" }}
  structuredData={_structuredData}
>
  <div class="pageBento">
    <section
      class="container projects__intro pageHero pageWidget"
      data-reveal
      data-reveal-type="scale"
      data-reveal-group="projects-intro"
    >
      <Breadcrumbs
        items={[
          { label: "Home", href: "/", icon: "home" },
          { label: "Projects", icon: "cube" },
        ]}
      />
      <div class="pageHero__copy">
        <span class="pageHero__eyebrow">{content.heroEyebrow}</span>
        <h1 class="pageHero__title">{content.heroTitle}</h1>
        <p class="pageHero__lede">{content.heroLede}</p>
        <div class="pageHero__meta" aria-label="Projects overview">
          <span class:list={["pageHero__metaItem", "meta-chip", "meta-chip--signal"]}>{_hasProjects ? `${projects.length} projects` : "Project notes in progress"}</span>
          <span class:list={["pageHero__metaItem", "meta-chip", "meta-chip--signal"]} data-dot="teal">{PROJECT_CATEGORIES.length} areas</span>
        </div>
      </div>
      {
        _hasProjects && (
          <div class="projects__filters" role="toolbar" aria-label="Filter projects">
            {_projectFilters.map((filter, index) => (
              <button
                type="button"
                class:list={[
                  "projectsFilter__button",
                  "chip-pill",
                  "chip-pill--interactive",
                  "motion-chip",
                  index === 0 && "is-active",
                ]}
                data-project-filter={filter.id}
                aria-pressed={index === 0 ? "true" : "false"}
              >
                {filter.label}
              </button>
            ))}
          </div>
        )
      }
    </section>

    <section class="container pageWidget" data-reveal data-reveal-group="projects-list">
      {
        _hasProjects ? (
          <Fragment>
            <div class="projects__filterEmpty card" data-project-empty hidden>
              <h2>{content.filterEmptyTitle}</h2>
              <p>
                {content.filterEmptyBody}
                {" "}
                <a href={`mailto:${content.contactEmail}`}>{content.contactEmail}</a>
              </p>
            </div>
            <div class="cardGrid projects__grid" data-projects-grid>
              {projects.map((project, i) => (
                <ProjectCard project={project} revealOrder={i} />
              ))}
            </div>
          </Fragment>
        ) : (
          <div class="projects__empty card" data-reveal data-reveal-group="projects-list">
            <h2>{content.pageEmptyTitle}</h2>
            <p>
              {content.pageEmptyBody}
              {" "}
              <a href={`mailto:${content.contactEmail}`}>{content.contactEmail}</a>
            </p>
          </div>
        )
      }
    </section>
  </div>

  <script is:inline type="module" src={projectsFiltersScriptHref}></script>
</Base>
