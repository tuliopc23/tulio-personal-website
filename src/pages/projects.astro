---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import PhosphorIcon from "../components/PhosphorIcon.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getAllProjects } from "../lib/content/projects";
import { Image } from "astro:assets";
import { getProjectsPageContent } from "../lib/content/page-content";

const projects = await getAllProjects();
const pageContent = await getProjectsPageContent();

const caseStudyImages = import.meta.glob("../assets/images/case-studies/*", { eager: true });
function resolveCaseStudyImage(src: string) {
  if (!src) return null;
  if (src.startsWith("/src/assets/")) {
    const key = src.replace("/src/assets", "../assets");
    const mod = (caseStudyImages as any)[key] ?? null;
    return mod && typeof mod === "object" && "default" in mod ? (mod as any).default : null;
  }
  return null;
}

if (import.meta.env.PROD && (!pageContent || !pageContent.caseStudies || pageContent.caseStudies.length === 0)) {
  throw new Error(
    "Missing projects page case studies for /projects. Edit `src/content/site/projects-page/index.yaml` (Keystatic singleton) so `caseStudies` is non-empty.",
  );
}

const defaults = {
  description:
    "Case studies on native apps, web platforms, backend systems, and developer tools — client work and indie projects that shipped.",
  heroEyebrow: "Case Studies",
  heroTitle: "Case Studies",
  heroLede:
    "Real work, real constraints, real deadlines. Client builds and indie projects that made it to production — with the decisions, tradeoffs, and technical details behind them.",
  contactEmail: "contact@tuliocunha.dev",
};

const content = {
  description: pageContent?.description ?? defaults.description,
  heroEyebrow: pageContent?.heroEyebrow ?? defaults.heroEyebrow,
  heroTitle: pageContent?.heroTitle ?? defaults.heroTitle,
  heroLede: pageContent?.heroLede ?? defaults.heroLede,
  contactEmail: pageContent?.contactEmail ?? defaults.contactEmail,
};

const siteOrigin = Astro.site?.origin ?? Astro.url?.origin ?? "https://www.tuliocunha.dev";
const description = content.description;
const canonicalUrl = new URL("/projects/", siteOrigin).toString();

const _structuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Tulio Cunha — Case Studies",
  description,
  url: canonicalUrl,
};

const caseStudies =
  pageContent?.caseStudies && pageContent.caseStudies.length > 0
    ? pageContent.caseStudies.map((cs) => ({
        id: cs._key,
        icon: cs.icon,
        eyebrow: cs.eyebrow,
        title: cs.title,
        headline: cs.headline,
        lede: cs.lede,
        role: cs.role,
        stack: cs.stack ?? [],
        href: cs.href ?? undefined,
        status: cs.status,
        images: (cs.images ?? [])
          .filter((image) => image?.url)
          .map((image) => ({
            src: image.url as string,
            meta: resolveCaseStudyImage(String(image.url ?? "")),
            alt: image.alt ?? cs.title,
            width: image.dimensions?.width ?? undefined,
            height: image.dimensions?.height ?? undefined,
          })),
      }))
    : [];

const _statusLabels: Record<string, string> = {
  live: "Live",
  maintained: "Maintained",
  exploration: "Exploration",
};
const _statusIcons: Record<string, string> = {
  live: "broadcast",
  maintained: "wrench",
  exploration: "flask",
};
---

<Base
  title="Case Studies"
  description={description}
  canonical={canonicalUrl}
  ogDescription={description}
  ogImage={{ url: "/terminal-favicon.svg", alt: "Case studies preview" }}
  structuredData={_structuredData}
>
  <div class="pageBento">
    <!-- Hero -->
    <section class="container pageHero pageWidget" data-reveal data-reveal-type="scale">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/", icon: "home" },
          { label: "Case Studies", icon: "briefcase" },
        ]}
      />
      <div class="pageHero__copy">
        <span class="pageHero__eyebrow">
          <PhosphorIcon name="briefcase" size={14} weight="regular" />
          {content.heroEyebrow}
        </span>
        <h1 class="pageHero__title">{content.heroTitle}</h1>
        <p class="pageHero__lede">{content.heroLede}</p>
        <div class="pageHero__meta" aria-label="Case studies overview">
          <span class:list={["pageHero__metaItem", "meta-chip", "meta-chip--signal"]}>
            <PhosphorIcon name="briefcase" size={14} weight="regular" />
            {caseStudies.length} case studies
          </span>
          <span class:list={["pageHero__metaItem", "meta-chip", "meta-chip--signal"]}>
            <PhosphorIcon name="code" size={14} weight="regular" />
            Client &amp; indie work
          </span>
        </div>
      </div>
    </section>

    <!-- Case study slider -->
    {caseStudies.length > 0 ? (
    <section class="caseSlider" aria-label="Case studies" data-case-slider>
      <!-- Nav pills -->
      <nav class="caseSlider__nav" aria-label="Case study navigation">
        {caseStudies.map((cs, i) => (
          <button
            type="button"
            class:list={["caseSlider__pill", "cta-pill", i === 0 ? "cta-pill--accent" : "cta-pill--neutral", "motion-cta-pill"]}
            data-case-nav={cs.id}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            <PhosphorIcon name={cs.icon} size={14} weight="regular" />
            <span>{cs.title}</span>
          </button>
        ))}
      </nav>

      <!-- Swipe hint -->
      <span class="caseSlider__hint" data-swipe-hint>
        <PhosphorIcon name="arrows-left-right" size={14} weight="regular" />
        <span>Swipe to explore</span>
      </span>

      <!-- Slides -->
      <div class="caseSlider__track" data-case-track data-case-rail>
        {caseStudies.map((cs, i) => (
          <article
            class="caseSlide"
            data-case-slide={cs.id}
            aria-hidden={i !== 0 ? "true" : "false"}
          >
            <!-- Editorial heading -->
            <header class="stage-intro stage-intro--single">
              <div class="stage-intro__copy">
                <span class="stage-intro__eyebrow">
                  <PhosphorIcon name={cs.icon} size={14} weight="regular" />
                  {cs.eyebrow}
                </span>
                <h2 class="stage-intro__title">{cs.title}</h2>
                <p class="caseSlide__headline">{cs.headline}</p>
                <p class="stage-intro__caption">{cs.lede}</p>
              </div>
            </header>

            <!-- Image showcase -->
            <div class="caseSlide__showcase">
              {cs.images.map((img, imgIdx) => (
                <figure
                  class="caseSlide__frame hover-elevate"
                  data-reveal
                  data-reveal-order={imgIdx}
                  data-parallax-card
                >
                  <div class="caseSlide__imageWrap">
                    {
                      img.meta ? (
                        <Image
                          src={img.meta as any}
                          widths={[640, 960, 1280, 1600]}
                          sizes="(max-width: 768px) calc(100vw - 28px), (max-width: 1200px) min(100vw - 56px, 980px), 1040px"
                          alt={img.alt}
                          draggable="false"
                          class="caseSlide__image"
                          loading={i === 0 ? "eager" : "lazy"}
                          decoding="async"
                        />
                      ) : (
                        <img
                          src={img.src}
                          alt={img.alt}
                          width={img.width}
                          height={img.height}
                          draggable="false"
                          class="caseSlide__image"
                          loading={i === 0 ? "eager" : "lazy"}
                          decoding="async"
                        />
                      )
                    }
                  </div>
                </figure>
              ))}
            </div>

            <!-- Meta bar -->
            <div class="caseSlide__meta">
              <div class="caseSlide__metaLeft">
                <span class="caseSlide__role">
                  <PhosphorIcon name="user" size={14} weight="regular" />
                  {cs.role}
                </span>
                <span class="caseSlide__status" data-status={cs.status}>
                  <PhosphorIcon name={_statusIcons[cs.status] ?? "circle"} size={12} weight="fill" />
                  {_statusLabels[cs.status] ?? cs.status}
                </span>
              </div>
              <ul class="caseSlide__stack" aria-label="Tech stack">
                {cs.stack.map((tech) => (
                  <li class="caseSlide__tag">{tech}</li>
                ))}
              </ul>
            </div>

            {cs.href && (
              <a
                href={cs.href}
                target="_blank"
                rel="noreferrer noopener"
                class="caseSlide__cta cta-pill cta-pill--accent motion-cta-pill"
              >
                <span>Visit project</span>
                <PhosphorIcon name="arrow-up-right" size={16} weight="regular" />
              </a>
            )}
          </article>
        ))}
      </div>
    </section>
    ) : (
    <section class="container pageWidget" aria-label="Case studies empty state">
      <header class="stage-intro stage-intro--single">
        <div class="stage-intro__copy">
          <span class="stage-intro__eyebrow">
            <PhosphorIcon name="briefcase" size={14} weight="regular" />
            {content.heroEyebrow}
          </span>
          <h2 class="stage-intro__title">{pageContent?.pageEmptyTitle ?? "Case studies are being prepared"}</h2>
          <p class="stage-intro__caption">
            {pageContent?.pageEmptyBody ?? "The project writeups are not published yet."}{" "}
            <a href={`mailto:${content.contactEmail}`}>{content.contactEmail}</a>.
          </p>
        </div>
      </header>
    </section>
    )}

    <!-- CMS-managed projects (if any) -->
    {projects.length > 0 && (
      <section class="homepage-stage" aria-labelledby="projects-more-title">
        <header class="stage-intro stage-intro--single">
          <div class="stage-intro__copy">
            <span class="stage-intro__eyebrow">
              <PhosphorIcon name="rocket-launch" size={14} weight="regular" />
              More work
            </span>
            <h2 id="projects-more-title" class="stage-intro__title">Other projects and contributions.</h2>
            <p class="stage-intro__caption">Smaller builds, open source work, and experiments that shipped.</p>
          </div>
        </header>

        <section class="container pageWidget" data-reveal data-reveal-group="projects-list">
          <div class="cardGrid projects__grid" data-projects-grid>
            {projects.map((project, i) => (
              <ProjectCard project={project} revealOrder={i} />
            ))}
          </div>
        </section>
      </section>
    )}
  </div>
</Base>
