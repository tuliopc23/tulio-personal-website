---
import BrandLogo from "../components/BrandLogo.astro";
import Signature from "../components/Signature.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import MobileLiquidGlassNav from "../components/navigation/MobileLiquidGlassNav.tsx";
import SiteSearchTrigger from "../components/navigation/SiteSearchTrigger.tsx";
import NavIconTile from "../components/NavIconTile.astro";
import PhosphorIcon from "../components/PhosphorIcon.astro";
import ThemeToggle from "../components/navigation/ThemeToggle.tsx";
import NewsletterSignup from "../components/NewsletterSignup.astro";
import motionCssHref from "../styles/motion.css?url";
import themeCssHref from "../styles/theme.css?url";
import fontsCssHref from "../styles/fonts.css?url";
import {
  ATOM_FEED_PATH,
  RSS_FEED_PATH,
  SITEMAP_INDEX_PATH,
  getSiteOrigin,
  toAbsoluteUrl,
} from "../lib/seo.js";
import {
  SITE_CONTACT_MAILTO_URL,
  SITE_GITHUB_PROFILE_URL,
  SITE_LINKEDIN_PROFILE_URL,
} from "../lib/site-identity";
import { normalizePathname, primaryNavLinks } from "../lib/navigation/primary-nav-links";
import { HEAD_IOS_SAFARI_MARK_INIT } from "../lib/browser-environment";
import { SAFARI_THEME_CHROME_COLORS } from "../lib/safari-theme-color";

interface OgImageMeta {
  url: string;
  alt?: string | null;
  width?: number;
  height?: number;
}

interface BaseProps {
  title?: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: OgImageMeta | null;
  articleAuthor?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleTags?: string[];
  noIndex?: boolean;
  structuredData?: Record<string, unknown> | string | null;
  sidebar?: boolean;
  mobileDrawer?: boolean;
  heroPage?: boolean;
}

const {
  title = "Home",
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogType = "website",
  ogImage,
  articleAuthor,
  articlePublishedTime,
  articleModifiedTime,
  articleTags,
  noIndex = false,
  structuredData,
  sidebar = true,
  mobileDrawer,
  heroPage = false,
} = Astro.props as BaseProps;

const fullTitle = `${title} • Tulio Cunha`;
const computedOgTitle = ogTitle ?? fullTitle;
const computedOgDescription = ogDescription ?? description;
const canonicalUrl = canonical ?? (typeof Astro.url !== "undefined" ? Astro.url.href : undefined);
const siteOrigin = getSiteOrigin(Astro.site ?? Astro.url);
const absoluteCanonicalUrl = canonicalUrl ? toAbsoluteUrl(canonicalUrl, siteOrigin) : undefined;
const absoluteOgImageUrl = ogImage?.url
  ? toAbsoluteUrl(ogImage.url, absoluteCanonicalUrl ?? siteOrigin)
  : null;
const robotsValue = noIndex ? "noindex,nofollow" : "index,follow";
const rssFeedUrl = toAbsoluteUrl(RSS_FEED_PATH, siteOrigin);
const atomFeedUrl = toAbsoluteUrl(ATOM_FEED_PATH, siteOrigin);
const sitemapUrl = toAbsoluteUrl(SITEMAP_INDEX_PATH, siteOrigin);
const aboutUrl = toAbsoluteUrl("/about/", siteOrigin);
const structuredDataJson =
  typeof structuredData === "string"
    ? structuredData
    : structuredData
      ? JSON.stringify(structuredData)
      : null;
const pathname = Astro.url.pathname;
const normalizedPath = normalizePathname(pathname);
const isBlogIndexRoute = normalizedPath === "/blog";
const isBlogCategoryRoute = normalizedPath.startsWith("/blog/category");
const isBlogRoute = isBlogIndexRoute || normalizedPath.startsWith("/blog/");
const isArticleRoute = isBlogRoute && !isBlogIndexRoute && !isBlogCategoryRoute;
const isBlogArchiveRoute =
  isBlogCategoryRoute ||
  normalizedPath.startsWith("/blog/topic/") ||
  normalizedPath.startsWith("/blog/series/");
const pageRoute = heroPage
  ? "home"
  : normalizedPath === "/about"
    ? "about"
    : normalizedPath === "/projects"
      ? "projects"
      : normalizedPath === "/contact"
        ? "contact"
        : isBlogIndexRoute
          ? "blog-index"
          : isArticleRoute
            ? "blog-article"
            : isBlogArchiveRoute
              ? "blog-archive"
              : normalizedPath === "/404" || normalizedPath.startsWith("/newsletter/")
                ? "utility"
                : "default";
const hasMobileDrawer = mobileDrawer ?? sidebar;

const globalNavLinkMeta = {
  home: {
    tint: "indigo",
    description: "The starting point. Stack, tools, writing, and what I'm building.",
    keywords: "homepage landing featured overview",
  },
  blog: {
    tint: "blue",
    description: "Long-form notes on code, platforms, and implementation tradeoffs.",
    keywords: "articles writing essays notes programming",
  },
  cases: {
    tint: "orange",
    description:
      "Client work and indie projects that shipped — the decisions and tradeoffs behind them.",
    keywords: "work case studies builds portfolio apps clients",
  },
  about: {
    tint: "teal",
    description: "How I think about software, what I've worked on, and how I operate.",
    keywords: "profile bio background approach",
  },
} as const;

const globalNavLinks = primaryNavLinks.map((link) => ({
  href: link.href,
  label: link.label,
  icon: link.icon,
  tint: globalNavLinkMeta[link.id].tint,
  current: link.match(normalizedPath),
  external: false as const,
  description: globalNavLinkMeta[link.id].description,
  keywords: globalNavLinkMeta[link.id].keywords,
}));
const topbarSubtitle = isArticleRoute
  ? "Dev notes · reader mode"
  : isBlogRoute
    ? "Writing · platforms, systems, and tools"
    : "Full stack · native, web, and systems";
const sidebarTitle = isBlogIndexRoute ? "Programming essays" : title;
const sidebarMeta = isArticleRoute
  ? "Notes on platforms, code, and tools."
  : isBlogIndexRoute
    ? "Writing on what I build and why."
    : isBlogCategoryRoute
      ? "Posts filtered by topic."
      : normalizedPath.startsWith("/projects")
        ? "Client work, indie builds, real constraints."
        : normalizedPath.startsWith("/about")
          ? "Background, principles, and current arc."
          : normalizedPath.startsWith("/contact")
            ? "Reach out. Email preferred."
            : "Navigation and links.";
const sidebarSiteLinks = globalNavLinks;

const sidebarSocialLinks = [
  {
    href: SITE_GITHUB_PROFILE_URL,
    label: "GitHub",
    icon: "github",
    tint: "indigo",
    current: false,
    external: true,
    description: "Repos, commits, and public work on GitHub.",
    keywords: "github code repositories open source",
  },
  {
    href: SITE_CONTACT_MAILTO_URL,
    label: "Contact",
    icon: "mail",
    tint: "indigo",
    current: false,
    external: false,
    description: "Drop a line. Project inquiries or just a question.",
    keywords: "contact email reach out inquiry",
  },
] as const;

---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" id="color-scheme-meta" content="light" />
    <meta name="theme-color" id="theme-color-meta" content={SAFARI_THEME_CHROME_COLORS.light} />
    <meta name="format-detection" content="telephone=no" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="author" content={articleAuthor ?? "Tulio Cunha"} />
    <meta name="generator" content="Astro" />
    <title>{fullTitle}</title>
    <meta name="robots" content={robotsValue} />
    {description && <meta name="description" content={description} />}
    {absoluteCanonicalUrl && <link rel="canonical" href={absoluteCanonicalUrl} />}
    <link rel="author" href={aboutUrl} />
    <link rel="me" href={SITE_GITHUB_PROFILE_URL} />
    <link rel="me" href={SITE_LINKEDIN_PROFILE_URL} />
    <link rel="alternate" type="application/rss+xml" title="Tulio Cunha — RSS Feed" href={rssFeedUrl} />
    <link rel="alternate" type="application/atom+xml" title="Tulio Cunha — Atom Feed" href={atomFeedUrl} />
    <link rel="sitemap" type="application/xml" href={sitemapUrl} />

    <!-- Theme-aware favicons (PNG; explicit light/dark mapping) -->
    <link
      rel="icon"
      type="image/png"
      href="/brand-icon-light.png"
      media="(prefers-color-scheme: light)"
      sizes="1024x1024"
    />
    <link
      rel="icon"
      type="image/png"
      href="/brand-icon-dark.png"
      media="(prefers-color-scheme: dark)"
      sizes="1024x1024"
    />
    <!-- Fallback + conventional small favicons -->
    <link rel="icon" type="image/png" href="/brand-icon-light.png" sizes="1024x1024" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />

    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Performance: Resource hints for external domains -->
    <!-- Preload critical CSS for faster rendering -->
    <link rel="preload" href={themeCssHref} as="style" />
    <link rel="preload" href={fontsCssHref} as="style" />

    <!-- SF Mono: small (61KB), safe to preload for code blocks -->
    <link
      rel="preload"
      href="/fonts/sf/v1/sf-mono-medium.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <!-- SF Pro: loaded async after page is interactive (see inline script below).
         Preloading 7.8MB was forcing download on all devices including non-Apple.
         Apple devices resolve via local() instantly; others get it post-load. -->

    <!-- Theme script must run BEFORE CSS to prevent FOUC -->
    <script is:inline define:vars={{ safariThemeChromeColors: SAFARI_THEME_CHROME_COLORS, headIosSafariMarkInit: HEAD_IOS_SAFARI_MARK_INIT }}>
      (() => {
        const root = document.documentElement;

        const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const initialTheme = prefersLight ? "light" : "dark";

        root.setAttribute("data-theme", initialTheme);
        if (initialTheme === "light") {
          root.classList.remove("dark");
          root.classList.add("light");
        } else {
          root.classList.remove("light");
          root.classList.add("dark");
        }

        // Update favicon based on theme (brand icon PNG)
        const updateFavicon = (theme) => {
          const favicon = document.querySelector('link[rel="icon"]');
          if (favicon) {
            favicon.href = theme === "light" ? "/brand-icon-light.png" : "/brand-icon-dark.png";
          }
        };

        const applyBrowserChrome = (theme) => {
          const isLight = theme === "light";
          const themeColorMeta = document.getElementById("theme-color-meta");
          if (themeColorMeta) {
            themeColorMeta.setAttribute("content", safariThemeChromeColors[theme]);
          }
          const colorSchemeMeta = document.getElementById("color-scheme-meta");
          if (colorSchemeMeta) {
            colorSchemeMeta.setAttribute("content", isLight ? "light" : "dark");
          }
          root.style.colorScheme = isLight ? "light" : "dark";
        };

        updateFavicon(initialTheme);
        applyBrowserChrome(initialTheme);
        new Function("root", headIosSafariMarkInit)(root);

        root.dataset.motionBooted = prefersReducedMotion ? "true" : "false";
        root.dataset.revealState = prefersReducedMotion ? "ready" : "armed";
        window.setTimeout(() => {
          if (
            root.dataset.motionBooted !== "true" &&
            (root.dataset.revealState === "armed" || root.dataset.revealState === "running")
          ) {
            root.dataset.revealState = "fallback";
          }
        }, 1800);


      })();
    </script>



    <link rel="stylesheet" href={fontsCssHref} />
    <link rel="stylesheet" href={themeCssHref} />
    <link rel="stylesheet" href={motionCssHref} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Tulio Cunha" />
    <meta property="og:title" content={computedOgTitle} />
    {
      computedOgDescription && (
        <meta property="og:description" content={computedOgDescription} />
      )
    }
    {absoluteCanonicalUrl && <meta property="og:url" content={absoluteCanonicalUrl} />}
    <meta property="og:locale" content="en_US" />
    {absoluteOgImageUrl && <meta property="og:image" content={absoluteOgImageUrl} />}
    {absoluteOgImageUrl && <meta property="og:image:secure_url" content={absoluteOgImageUrl} />}
    {ogType === "article" && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === "article" && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === "article" && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === "article" &&
      articleTags &&
      articleTags.length > 0 &&
      articleTags.map((tag) => <meta property="article:tag" content={tag} />)}
    {ogImage?.alt && <meta property="og:image:alt" content={ogImage.alt} />}
    {
      typeof ogImage?.width === "number" && (
        <meta property="og:image:width" content={String(ogImage.width)} />
      )
    }
    {
      typeof ogImage?.height === "number" && (
        <meta property="og:image:height" content={String(ogImage.height)} />
      )
    }
    <meta
      name="twitter:card"
      content={absoluteOgImageUrl ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={computedOgTitle} />
    {
      computedOgDescription && (
        <meta name="twitter:description" content={computedOgDescription} />
      )
    }
    {absoluteOgImageUrl && <meta name="twitter:image" content={absoluteOgImageUrl} />}
    {
      structuredDataJson && (
        <script is:inline type="application/ld+json" set:html={structuredDataJson} />
      )
    }

    <slot name="head" />

    <!-- Async SF Pro loader: zero LCP impact, all platforms get SF Pro after page load.
         Apple devices already have SF Pro via -apple-system in the CSS font stack — no download.
         Non-Apple (Android, Windows, Linux): woff2 fetched after window.load, text repaints.
         Caching: browser HTTP cache stores the woff2 after first download; repeat visits are instant.
         NOTE: document.fonts.check() is NOT used — Chrome returns true for any font when the
         fallback system font is available, making it unreliable for detecting local() resolution.
         Platform detection via navigator.platform / userAgentData is the correct signal. -->
    <script is:inline>
      (function () {
        if (typeof FontFace === "undefined") return;
        function loadSFPro() {
          document.fonts.ready.then(function () {
            // Apple devices get SF Pro through -apple-system in the CSS font-family stack.
            // navigator.userAgentData.platform is the modern API; navigator.platform is the
            // legacy fallback (deprecated but still widely supported and reliable here).
            var uaPlatform = (navigator.userAgentData || {}).platform || "";
            var platform = navigator.platform || "";
            var isApple =
              /^(macOS|iOS)$/i.test(uaPlatform) ||
              /^(Mac|iPhone|iPad|iPod)/i.test(platform);
            if (isApple) return;
            // Non-Apple: load SF Pro woff2 asynchronously. font-display:swap means
            // text repaints to SF Pro when the download finishes (FOUT on first visit only).
            var face = new FontFace(
              "SF Pro",
              'url("/fonts/sf/v1/sf-pro.woff2") format("woff2")',
              { style: "normal", weight: "400 900", display: "swap" }
            );
            document.fonts.add(face);
            face.load().catch(function () {});
          });
        }
        if (document.readyState === "complete") {
          loadSFPro();
        } else {
          window.addEventListener("load", loadSFPro);
        }
      })();
    </script>
  </head>
    <body
    data-page-state="ready"
    data-page-route={pageRoute}
    data-glass-state="rest"
    data-has-sidebar={sidebar ? "true" : "false"}
    data-has-mobile-drawer={hasMobileDrawer ? "true" : "false"}
    data-mobile-liquid-nav="true"
    data-hero-active={heroPage ? "true" : undefined}
  >
    <div class="liquid-glass-reflector" aria-hidden="true"></div>
    <a href="#main" class="sr-only">Skip to content</a>
    {heroPage && <a href="#top" class="sr-only sr-only--offset">Skip past hero</a>}
    <header class="topbar">
      <div class="topbar__inner">
        <div class="topbar__brandGroup">
          {
            hasMobileDrawer && (
              <button
                type="button"
                class="topbar__menu"
                aria-label="Open menu"
                aria-expanded="false"
                aria-controls="site-sidebar"
              >
                <PhosphorIcon name="sidebar-left" size={22} weight="regular" />
                <span class="topbar__menuLabel">Menu</span>
              </button>
            )
          }
          <a href="/" class="topbar__brandIcon" aria-label="Tulio Cunha – Home">
            <BrandLogo size={26} priority={true} variant="bare" />
          </a>
          <div class="topbar__brand">
            <span class="topbar__brandName">Tulio Cunha</span>
            <span class="topbar__brandSubtitle">{topbarSubtitle}</span>
          </div>
        </div>
        <nav class="topbar__nav" aria-label="Global">
          <div class="topbar__navShell" data-topbar-nav-shell>
            <span
              class="topbar__navIndicator liquid-glass--segment"
              data-topbar-tab-indicator
              hidden
              aria-hidden="true"
            />
            <div
              class="topbar__navMask"
              data-topbar-mask
              data-edge-start="true"
              data-edge-end="true"
            >
              <ul class="topbar__navList" data-topbar-list>
                {globalNavLinks.map((link) => (
                  <li class="topbar__navItem">
                    <a
                      href={link.href}
                      class="topbar__navLink"
                      aria-current={link.current ? "page" : undefined}
                    >
                      <span class="topbar__navLabel">{link.label}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </nav>
        <div class="topbar__actions">
          <ThemeToggle client:only="react" />
          <SiteSearchTrigger client:only="react" />
        </div>
      </div>
    </header>

    <main id="main" tabindex="-1" class:list={["layout", !sidebar && "layout--noSidebar"]}>
      {
        hasMobileDrawer && (
          <aside
            id="site-sidebar"
            class:list={["sidebar", !sidebar && "sidebar--mobileOnly"]}
            aria-label="Site navigation"
          >
            <div class="sidebar__inner">
              <div class="sidebar__header">
                <div class="sidebar__headerTop">
                  <div>
                    <p class="sidebar__eyebrow">Menu</p>
                    <h2 class="sidebar__title">{sidebarTitle}</h2>
                  </div>
                  <button
                    type="button"
                    class="sidebar__close"
                    aria-label="Close menu"
                    data-sidebar-close
                  >
                    <PhosphorIcon name="x" size={20} weight="regular" />
                  </button>
                </div>
                <p class="sidebar__meta">{sidebarMeta}</p>
              </div>
              <div class="sidebar__body">
                <nav class="sidebar__nav" role="navigation" aria-label="Sections">
                  <div class="sidebar__group sidebar__group--site">
                    <div class="sidebar__groupLabel">Explore</div>
                    {sidebarSiteLinks.map((link) => (
                      <a
                        class="sidebar__link"
                        href={link.href}
                        aria-current={link.current ? "page" : undefined}
                      >
                        <NavIconTile tint={link.tint} icon={link.icon} />
                        {link.label}
                      </a>
                    ))}
                  </div>
                </nav>
                <div class="sidebar__footer">
                  <div class="sidebar__group sidebar__group--social">
                    <div class="sidebar__groupLabel">Elsewhere</div>
                    <div class="sidebar__socialGrid">
                      {sidebarSocialLinks.map((link) => (
                        <a
                          class="sidebar__link sidebar__link--secondary"
                          href={link.href}
                          target={link.external ? "_blank" : undefined}
                          rel={link.external ? "noreferrer noopener" : undefined}
                          aria-current={link.current ? "page" : undefined}
                        >
                          <NavIconTile tint={link.tint ?? "blue"} icon={link.icon} />
                          {link.label}
                        </a>
                      ))}
                    </div>
                  </div>
                  <div class="sidebar__filter">
                    <label class="sidebar__filterLabel" for="sidebarFilter">Quick jump</label>
                    <div class="sidebar__filterField">
                      <input
                        id="sidebarFilter"
                        type="search"
                        placeholder="Jump to a page"
                        aria-label="Jump to a page from the menu"
                      />
                      <kbd class="slash sidebar__filterShortcut">/</kbd>
                    </div>
                    <p class="sidebar__dockHint">
                      Search every page from the magnifying glass in the dock.
                    </p>
                    <span
                      class="sr-only"
                      data-sidebar-status
                      aria-live="polite"
                      role="status"
                    />
                  </div>
                </div>
              </div>
            </div>
          </aside>
        )
      }

      <section class="content">
        <div class="content__main">
          <slot />
        </div>
        <Signature />
        <footer class="footer" role="contentinfo">
          <div class="footer__inner">
            <div class="footer__newsletter">
              <NewsletterSignup variant="compact" source="footer" />
            </div>
            <div class="footer__body">
              <div class="footer__about">
                <p class="footer__eyebrow">Elsewhere</p>
                <p class="footer__title">
                  <span class="footer__titleRow">
                    Tulio Cunha
                    <BrandLogo size={20} class="footer__icon" variant="bare" />
                  </span>
                </p>
                <p class="footer__copy">
                  Full stack developer. Native apps, web systems, backend services, and the glue between them.
                </p>
              </div>
              <nav class="footer__links" aria-label="Footer links">
                <a class="footer__link" href="/projects/">
                  <PhosphorIcon name="briefcase" size={15} weight="regular" />
                  <span>Case studies</span>
                </a>
                <a class="footer__link" href="/blog/">
                  <PhosphorIcon name="article" size={15} weight="regular" />
                  <span>Blog</span>
                </a>
                <a class="footer__link" href="/about/">
                  <PhosphorIcon name="user" size={15} weight="regular" />
                  <span>About</span>
                </a>
                <a class="footer__link" href={SITE_CONTACT_MAILTO_URL}>
                  <PhosphorIcon name="envelope-simple" size={15} weight="regular" />
                  <span>Email</span>
                </a>
              </nav>
            </div>
            <div class="footer__meta">
              <p class="footer__status">Probably in a terminal tab right now. Swift, TypeScript, Go, Rust, Zig — depends on the day.</p>
              <p class="footer__legal">
                © {new Date().getFullYear()} Tulio Cunha. Built with Astro.
              </p>
            </div>
          </div>
        </footer>
      </section>
    </main>

    <ScrollToTop />

    <MobileLiquidGlassNav client:load pathname={normalizedPath} />

    <script>
      // Bundled client entrypoint to avoid route-relative 404s on nested pages.
      import "../scripts/client.ts";
    </script>
  </body>
</html>
