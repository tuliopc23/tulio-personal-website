---
import BrandLogo from "../components/BrandLogo.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import PhosphorIcon from "../components/PhosphorIcon.astro";
import LiquidThemeToggle from "../components/LiquidThemeToggle.astro";
import motionCssHref from "../styles/motion.css?url";
import themeCssHref from "../styles/theme.css?url";
import fontsCssHref from "../styles/fonts.css?url";
import {
  ATOM_FEED_PATH,
  RSS_FEED_PATH,
  SITEMAP_INDEX_PATH,
  getSiteOrigin,
  toAbsoluteUrl,
} from "../lib/seo.js";

interface OgImageMeta {
  url: string;
  alt?: string | null;
  width?: number;
  height?: number;
}

interface BaseProps {
  title?: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: OgImageMeta | null;
  articleAuthor?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleTags?: string[];
  noIndex?: boolean;
  structuredData?: Record<string, unknown> | string | null;
  sidebar?: boolean;
  mobileDrawer?: boolean;
  heroPage?: boolean;
}

const {
  title = "Home",
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogType = "website",
  ogImage,
  articleAuthor,
  articlePublishedTime,
  articleModifiedTime,
  articleTags,
  noIndex = false,
  structuredData,
  sidebar = true,
  mobileDrawer,
  heroPage = false,
} = Astro.props as BaseProps;

const fullTitle = `${title} • Tulio Cunha`;
const computedOgTitle = ogTitle ?? fullTitle;
const computedOgDescription = ogDescription ?? description;
const canonicalUrl = canonical ?? (typeof Astro.url !== "undefined" ? Astro.url.href : undefined);
const siteOrigin = getSiteOrigin(Astro.site ?? Astro.url);
const absoluteCanonicalUrl = canonicalUrl ? toAbsoluteUrl(canonicalUrl, siteOrigin) : undefined;
const absoluteOgImageUrl = ogImage?.url
  ? toAbsoluteUrl(ogImage.url, absoluteCanonicalUrl ?? siteOrigin)
  : null;
const robotsValue = noIndex ? "noindex,nofollow" : "index,follow";
const rssFeedUrl = toAbsoluteUrl(RSS_FEED_PATH, siteOrigin);
const atomFeedUrl = toAbsoluteUrl(ATOM_FEED_PATH, siteOrigin);
const sitemapUrl = toAbsoluteUrl(SITEMAP_INDEX_PATH, siteOrigin);
const aboutUrl = toAbsoluteUrl("/about/", siteOrigin);
const structuredDataJson =
  typeof structuredData === "string"
    ? structuredData
    : structuredData
      ? JSON.stringify(structuredData)
      : null;
const pathname = Astro.url.pathname;
const normalizedPath =
  pathname !== "/" && pathname.endsWith("/") ? pathname.slice(0, -1) : pathname;
const isBlogIndexRoute = normalizedPath === "/blog";
const isBlogCategoryRoute = normalizedPath.startsWith("/blog/category");
const isBlogRoute = isBlogIndexRoute || normalizedPath.startsWith("/blog/");
const isArticleRoute = isBlogRoute && !isBlogIndexRoute && !isBlogCategoryRoute;
const hasMobileDrawer = mobileDrawer ?? sidebar;
const globalNavLinks = [
  {
    href: "/",
    label: "Home",
    icon: "house",
    tint: "indigo",
    current: normalizedPath === "/",
    external: false,
    description: "Overview, featured work, and current focus.",
    keywords: "homepage landing featured overview",
  },
  {
    href: "/blog/",
    label: "Blog",
    icon: "notebook",
    tint: "blue",
    current: isBlogRoute,
    external: false,
    description: "Programming essays on apps, systems, and tools.",
    keywords: "articles writing essays notes programming",
  },
  {
    href: "/projects",
    label: "Projects",
    icon: "briefcase",
    tint: "orange",
    current: normalizedPath === "/projects",
    external: false,
    description: "Selected product work, experiments, and builds.",
    keywords: "work case studies builds portfolio apps",
  },
  {
    href: "/about",
    label: "About",
    icon: "sparkle",
    tint: "teal",
    current: normalizedPath.startsWith("/about"),
    external: false,
    description: "Background, approach, and working style.",
    keywords: "profile bio background approach",
  },
] as const;
const topbarSubtitle = isArticleRoute
  ? "Developer notes · reading view"
  : isBlogRoute
    ? "Programming essays · apps, web, and systems"
    : "Full stack developer · Apple, web, and systems";
const sidebarTitle = isBlogIndexRoute ? "Programming essays" : title;
const sidebarMeta = isArticleRoute
  ? "Posts on apps, systems, and tools."
  : isBlogIndexRoute
    ? "Programming essays and technical notes."
    : isBlogCategoryRoute
      ? "Posts grouped by topic."
      : normalizedPath.startsWith("/projects")
        ? "Apple apps, web builds, backend systems."
        : normalizedPath.startsWith("/about")
          ? "Background, approach, and current interests."
          : normalizedPath.startsWith("/now")
            ? "Current work and next threads."
            : normalizedPath.startsWith("/contact")
              ? "Email, project context, and links."
              : "Navigation, links, and contact.";
const sidebarSiteLinks = globalNavLinks;

const sidebarSocialLinks = [
  {
    href: "https://github.com/tuliopc23",
    label: "GitHub",
    icon: "github",
    tint: "indigo",
    current: false,
    external: true,
    description: "Open the public code archive and recent repos.",
    keywords: "github code repositories open source",
  },
  {
    href: "/contact",
    label: "Contact",
    icon: "mail",
    tint: "indigo",
    current: normalizedPath.startsWith("/contact"),
    external: false,
    description: "Project inquiries, email, and direct contact.",
    keywords: "contact email reach out inquiry",
  },
] as const;

const searchItems = [
  ...globalNavLinks.map((item) => ({
    ...item,
    external: false,
    meta: "Page",
  })),
  ...sidebarSocialLinks.map((item) => ({
    ...item,
    external: item.external,
    meta: item.external ? "External" : "Page",
  })),
] as const;
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" id="theme-color-meta" content="#f6f7fb" />
    <meta name="theme-color" content="#050506" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f6f7fb" media="(prefers-color-scheme: light)" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="author" content={articleAuthor ?? "Tulio Cunha"} />
    <meta name="generator" content="Astro" />
    <title>{fullTitle}</title>
    <meta name="robots" content={robotsValue} />
    {description && <meta name="description" content={description} />}
    {absoluteCanonicalUrl && <link rel="canonical" href={absoluteCanonicalUrl} />}
    <link rel="author" href={aboutUrl} />
    <link rel="me" href="https://github.com/tuliopc23" />
    <link rel="me" href="https://www.linkedin.com/in/tuliocunha/" />
    <link rel="alternate" type="application/rss+xml" title="Tulio Cunha — RSS Feed" href={rssFeedUrl} />
    <link rel="alternate" type="application/atom+xml" title="Tulio Cunha — Atom Feed" href={atomFeedUrl} />
    <link rel="sitemap" type="application/xml" href={sitemapUrl} />

    <!-- Theme-aware favicons (high-quality WebP brand icons) -->
    <link
      rel="icon"
      type="image/webp"
      href="/Brand-icon-dark.webp"
      media="(prefers-color-scheme: light)"
      sizes="32x32"
    />
    <link
      rel="icon"
      type="image/webp"
      href="/Brand-icon-light.webp"
      media="(prefers-color-scheme: dark)"
      sizes="32x32"
    />
    <link rel="icon" type="image/webp" href="/Brand-icon-dark.webp" sizes="32x32" />

    <!-- Performance: Resource hints for external domains -->
    <link rel="dns-prefetch" href="https://cdn.sanity.io" />
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    
    <!-- Preload critical CSS for faster rendering -->
    <link rel="preload" href={themeCssHref} as="style" />
    <link rel="preload" href={fontsCssHref} as="style" />

    <!-- Self-hosted SF fonts -->
    <link
      rel="preload"
      href="/fonts/sf/v1/sf-pro.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/sf/v1/sf-mono-medium.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!-- Theme script must run BEFORE CSS to prevent FOUC -->
    <script is:inline>
      (() => {
        const STORAGE_KEY = "theme-override";
        const readStoredTheme = () => {
          try {
            const value = localStorage.getItem(STORAGE_KEY);
            return value === "light" || value === "dark" ? value : null;
          } catch {
            return null;
          }
        };

        const stored = readStoredTheme();
        const root = document.documentElement;

        const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const initialTheme = stored ?? (prefersLight ? "light" : "dark");

        root.setAttribute("data-theme", initialTheme);
        if (initialTheme === "light") {
          root.classList.remove("dark");
          root.classList.add("light");
        } else {
          root.classList.remove("light");
          root.classList.add("dark");
        }

        // Update favicon based on theme (brand icon WebP)
        const updateFavicon = (theme) => {
          const favicon = document.querySelector('link[rel="icon"]');
          if (favicon) {
            favicon.href = theme === "light" ? "/Brand-icon-dark.webp" : "/Brand-icon-light.webp";
          }
        };

        const updateThemeColor = (theme) => {
          const themeColorMeta = document.getElementById("theme-color-meta");
          if (themeColorMeta) {
            themeColorMeta.setAttribute("content", theme === "light" ? "#f6f7fb" : "#050506");
          }
        };

        updateFavicon(initialTheme);
        updateThemeColor(initialTheme);

        root.dataset.revealState = prefersReducedMotion ? "ready" : "armed";
        window.setTimeout(() => {
          if (root.dataset.revealState === "armed") {
            root.dataset.revealState = "fallback";
          }
        }, 1800);
      })();
    </script>

    <link rel="stylesheet" href={fontsCssHref} />
    <link rel="stylesheet" href={themeCssHref} />
    <link rel="stylesheet" href={motionCssHref} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Tulio Cunha" />
    <meta property="og:title" content={computedOgTitle} />
    {
      computedOgDescription && (
        <meta property="og:description" content={computedOgDescription} />
      )
    }
    {absoluteCanonicalUrl && <meta property="og:url" content={absoluteCanonicalUrl} />}
    <meta property="og:locale" content="en_US" />
    {absoluteOgImageUrl && <meta property="og:image" content={absoluteOgImageUrl} />}
    {absoluteOgImageUrl && <meta property="og:image:secure_url" content={absoluteOgImageUrl} />}
    {ogType === "article" && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === "article" && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === "article" && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === "article" &&
      articleTags &&
      articleTags.length > 0 &&
      articleTags.map((tag) => <meta property="article:tag" content={tag} />)}
    {ogImage?.alt && <meta property="og:image:alt" content={ogImage.alt} />}
    {
      typeof ogImage?.width === "number" && (
        <meta property="og:image:width" content={String(ogImage.width)} />
      )
    }
    {
      typeof ogImage?.height === "number" && (
        <meta property="og:image:height" content={String(ogImage.height)} />
      )
    }
    <meta
      name="twitter:card"
      content={ogImage?.url ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={computedOgTitle} />
    {
      computedOgDescription && (
        <meta name="twitter:description" content={computedOgDescription} />
      )
    }
    {ogImage?.url && <meta name="twitter:image" content={ogImage.url} />}
    {
      structuredDataJson && (
        <script is:inline type="application/ld+json" set:html={structuredDataJson} />
      )
    }

    <slot name="head" />
  </head>
    <body
    class="liquid-glass"
    data-page-state="ready"
    data-glass-state="rest"
    data-has-sidebar={sidebar ? "true" : "false"}
    data-has-mobile-drawer={hasMobileDrawer ? "true" : "false"}
    data-hero-active={heroPage ? "true" : undefined}
  >
    <div class="liquid-glass-reflector" aria-hidden="true"></div>
    <a href="#main" class="sr-only">Skip to content</a>
    <header class="topbar">
      <div class="topbar__inner">
        <div class="topbar__brandGroup">
          {
            hasMobileDrawer && (
              <button
                type="button"
                class="topbar__menu"
                aria-label="Open menu"
                aria-expanded="false"
                aria-controls="site-sidebar"
              >
                <PhosphorIcon name="sidebar-left" size={22} weight="regular" />
                <span class="topbar__menuLabel">Menu</span>
              </button>
            )
          }
          <a href="/" class="topbar__brandIcon" aria-label="Tulio Cunha – Home">
            <BrandLogo size={26} priority={true} variant="bare" />
          </a>
          <div class="topbar__brand">
            <span class="topbar__brandName">Tulio Cunha</span>
            <span class="topbar__brandSubtitle">{topbarSubtitle}</span>
          </div>
        </div>
        <nav class="topbar__nav" aria-label="Global">
          <div class="topbar__navShell">
            <div
              class="topbar__navMask"
              data-topbar-mask
              data-edge-start="true"
              data-edge-end="true"
            >
              <ul class="topbar__navList" data-topbar-list>
                {globalNavLinks.map((link) => (
                  <li class="topbar__navItem">
                    <a
                      href={link.href}
                      class="topbar__navLink"
                      aria-current={link.current ? "page" : undefined}
                    >
                      <span class="topbar__navLabel">{link.label}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </nav>
        <div class="topbar__actions">
          <LiquidThemeToggle />
          <button
            type="button"
            class="topbar__iconButton topbar__searchButton"
            aria-label="Open quick search"
            aria-controls="site-search"
            aria-expanded="false"
            aria-haspopup="dialog"
            data-site-search-open
            title="Quick search (Cmd/Ctrl + K)"
          >
            <PhosphorIcon name="magnifying-glass" size={19} weight="regular" />
          </button>
        </div>
      </div>
    </header>

    <div
      id="site-search"
      class="topbarSearch"
      data-site-search-root
      aria-hidden="true"
      hidden
    >
      <button
        type="button"
        class="topbarSearch__backdrop"
        data-site-search-close
        tabindex="-1"
        aria-hidden="true"
      ></button>
      <div class="topbarSearch__dialog" role="dialog" aria-modal="true" aria-labelledby="site-search-title">
        <div class="topbarSearch__panel">
          <div class="topbarSearch__header">
            <div>
              <p class="topbarSearch__eyebrow">Quick Search</p>
              <h2 id="site-search-title" class="topbarSearch__title">Search the site</h2>
            </div>
            <button
              type="button"
              class="topbarSearch__dismiss"
              data-site-search-close
              aria-label="Close quick search"
            >
              <PhosphorIcon name="x" size={18} weight="regular" />
            </button>
          </div>

          <div class="topbarSearch__field">
            <span class="topbarSearch__fieldIcon" aria-hidden="true">
              <PhosphorIcon name="magnifying-glass" size={18} weight="regular" />
            </span>
            <label class="sr-only" for="siteSearchInput">Search pages and links</label>
            <input
              id="siteSearchInput"
              class="topbarSearch__input"
              type="search"
              name="site-search"
              placeholder="Search pages, links, and sections..."
              autocomplete="off"
              spellcheck="false"
              enterkeyhint="go"
              data-site-search-input
            />
            <span class="topbarSearch__shortcut" aria-hidden="true">Cmd/Ctrl + K</span>
          </div>

          <div class="topbarSearch__metaRow">
            <p class="topbarSearch__meta">Pages, sections, contact, and external profiles.</p>
            <span class="topbarSearch__hint">Enter opens the first match.</span>
          </div>

          <div class="topbarSearch__results" data-site-search-results>
            {searchItems.map((item) => (
              <a
                href={item.href}
                class="topbarSearch__result"
                data-site-search-item
                data-search-value={`${item.label} ${item.description} ${item.keywords}`.toLowerCase()}
                data-search-label={item.label}
                aria-current={item.current ? "page" : undefined}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noreferrer noopener" : undefined}
              >
                <span class="topbarSearch__resultIcon" aria-hidden="true">
                  <PhosphorIcon name={item.icon} size={18} weight="regular" />
                </span>
                <span class="topbarSearch__resultBody">
                  <span class="topbarSearch__resultLabel">{item.label}</span>
                  <span class="topbarSearch__resultDescription">{item.description}</span>
                </span>
                <span class="topbarSearch__resultMeta">{item.meta}</span>
              </a>
            ))}
          </div>

          <p class="topbarSearch__empty" data-site-search-empty hidden>
            No matches yet. Try a page name, a topic, or a platform.
          </p>
          <span class="sr-only" data-site-search-status aria-live="polite" role="status"></span>
        </div>
      </div>
    </div>

    <main class:list={["layout", !sidebar && "layout--noSidebar"]}>
      {
        hasMobileDrawer && (
          <aside
            id="site-sidebar"
            class:list={["sidebar", !sidebar && "sidebar--mobileOnly"]}
            aria-label="Site navigation"
          >
            <div class="sidebar__inner">
              <div class="sidebar__header">
                <div class="sidebar__headerTop">
                  <div>
                    <p class="sidebar__eyebrow">Menu</p>
                    <h2 class="sidebar__title">{sidebarTitle}</h2>
                  </div>
                  <button
                    type="button"
                    class="sidebar__close"
                    aria-label="Close menu"
                    data-sidebar-close
                  >
                    <PhosphorIcon name="x" size={20} weight="regular" />
                  </button>
                </div>
                <p class="sidebar__meta">{sidebarMeta}</p>
              </div>
              <nav class="sidebar__nav" role="navigation" aria-label="Sections">
                <div class="sidebar__group sidebar__group--site">
                  <div class="sidebar__groupLabel">Explore</div>
                  {sidebarSiteLinks.map((link) => (
                    <a
                      class="sidebar__link"
                      href={link.href}
                      aria-current={link.current ? "page" : undefined}
                    >
                      <span class:list={["icon-tile", `icon-tile--${link.tint}`]} aria-hidden="true">
                        <PhosphorIcon name={link.icon} size={20} weight="regular" />
                      </span>
                      {link.label}
                    </a>
                  ))}
                </div>
              </nav>
              <div class="sidebar__footer">
                <div class="sidebar__group sidebar__group--social">
                  <div class="sidebar__groupLabel">Elsewhere</div>
                  <div class="sidebar__socialGrid">
                    {sidebarSocialLinks.map((link) => (
                      <a
                        class="sidebar__link sidebar__link--secondary"
                        href={link.href}
                        target={link.external ? "_blank" : undefined}
                        rel={link.external ? "noreferrer noopener" : undefined}
                        aria-current={link.current ? "page" : undefined}
                      >
                        <span
                          class:list={["icon-tile", link.tint && `icon-tile--${link.tint}`]}
                          aria-hidden="true"
                        >
                          <PhosphorIcon name={link.icon} size={20} weight="regular" />
                        </span>
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
                <div class="sidebar__filter">
                  <label class="sidebar__filterLabel" for="sidebarFilter">Quick jump</label>
                  <div class="sidebar__filterField">
                    <input
                      id="sidebarFilter"
                      type="search"
                      placeholder="Jump to a page"
                      aria-label="Jump to a page from the menu"
                    />
                    <kbd class="slash">/</kbd>
                  </div>
                  <span
                    class="sr-only"
                    data-sidebar-status
                    aria-live="polite"
                    role="status"
                  />
                </div>
              </div>
            </div>
          </aside>
        )
      }

      <section class="content">
        <div id="main">
          <slot />
        </div>
        <footer class="footer">
          <div class="footer__inner">
            <div class="footer__about">
              <p class="footer__eyebrow">Elsewhere</p>
              <p class="footer__title">
                <span class="footer__titleRow">
                  Tulio Cunha
                  <BrandLogo size={20} class="footer__icon" variant="bare" />
                </span>
              </p>
              <p class="footer__copy">
                Full stack developer working across Apple platforms, the web, backend, and systems.
              </p>
            </div>
            <div class="footer__actions">
              <nav class="footer__links" aria-label="Footer links">
                <a href="/projects">Projects</a>
                <a href="/blog/">Blog</a>
                <a href="/about">About</a>
                <a
                  href="https://portfolio.tuliocunha.dev"
                  target="_blank"
                  rel="noreferrer noopener">Portfolio</a
                >
                <a href="mailto:contact@tuliocunha.dev">Email</a>
              </nav>
            </div>
            <div class="footer__meta">
              <p class="footer__status">Usually in Swift, TypeScript, Go, Rust, or a terminal tab that has gone too far.</p>
              <p class="footer__legal">
                © {new Date().getFullYear()} Tulio Cunha. Built with Astro.
              </p>
            </div>
          </div>
        </footer>
      </section>
    </main>

    <ScrollToTop />

    <script>
      // Bundled client entrypoint to avoid route-relative 404s on nested pages.
      import "../scripts/client.ts";
    </script>
    <script is:inline>
      if (typeof window !== "undefined") {
        const mask = document.querySelector("[data-topbar-mask]");
        const list = mask?.querySelector("[data-topbar-list]");

        const updateEdges = () => {
          if (!mask) return;
          const atStart = mask.scrollLeft <= 1;
          const atEnd = mask.scrollLeft + mask.clientWidth >= mask.scrollWidth - 1;
          mask.dataset.edgeStart = atStart ? "true" : "false";
          mask.dataset.edgeEnd = atEnd ? "true" : "false";
        };

        const centerActive = () => {
          if (!mask || !list) return;
          if (!window.matchMedia("(max-width: 1023px)").matches) return;
          const active = list.querySelector('a[aria-current="page"]');
          if (!active) return;
          const reduceMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)"
          ).matches;
          requestAnimationFrame(() => {
            const activeRect = active.getBoundingClientRect();
            const maskRect = mask.getBoundingClientRect();
            const offset = activeRect.left - maskRect.left;
            const scrollLeft =
              mask.scrollLeft + offset - (mask.clientWidth - active.clientWidth) / 2;
            mask.scrollTo({
              left: Math.max(scrollLeft, 0),
              behavior: reduceMotion ? "auto" : "smooth",
            });
          });
        };

        if (mask) {
          updateEdges();
          centerActive();
          mask.addEventListener("scroll", updateEdges, { passive: true });
          window.addEventListener("resize", () => {
            updateEdges();
            centerActive();
          });
        }

        // Keyboard navigation for topbar nav links (arrow keys)
        const navLinks = list?.querySelectorAll(".topbar__navLink");
        if (navLinks && navLinks.length > 0) {
          navLinks.forEach((link, index) => {
            link.addEventListener("keydown", (e) => {
              if (e.key === "ArrowRight" || e.key === "ArrowLeft") {
                e.preventDefault();
                let nextIndex;
                if (e.key === "ArrowRight") {
                  nextIndex = (index + 1) % navLinks.length;
                } else {
                  nextIndex = (index - 1 + navLinks.length) % navLinks.length;
                }
                navLinks[nextIndex].focus();
              }
            });
          });
        }
      }
    </script>
  </body>
</html>
