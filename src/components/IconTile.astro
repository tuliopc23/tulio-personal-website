---
import BrandIcon from "./BrandIcon.astro";
import { getBrandIcon } from "./brand-icons";
import SFIcon from "./SFIcon.astro";

type IconAsset =
  | string
  | {
      light: string;
      dark?: string | null;
    };

const {
  tint = "blue",
  label = "",
  icon = null,
  asset = null,
  context = "default",
}: {
  tint?: string;
  label?: string;
  icon?: string | null;
  asset?: IconAsset | null;
  context?: "default" | "dock";
} = Astro.props;

const iconAsset = asset
  ? typeof asset === "string"
    ? { light: asset, dark: asset }
    : {
        light: asset.light,
        dark: typeof asset.dark === "string" && asset.dark.length > 0 ? asset.dark : asset.light,
      }
  : null;

const assetLight = iconAsset?.light ?? null;
const assetDarkRaw = iconAsset?.dark ?? null;
const assetDark = assetDarkRaw && assetDarkRaw !== assetLight ? assetDarkRaw : null;
const iconKey = (() => {
  if (assetLight) {
    const fileName = assetLight.split("/").pop() ?? "";
    const withoutExt = fileName.replace(/\.[^.]+$/, "");
    return withoutExt
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+/, "")
      .replace(/-+$/, "")
      .replace(/-+/g, "-");
  }

  return icon ?? null;
})();

const symbolMap: Record<string, string> = {
  blog: "notebook",
  projects: "constellation",
  home: "home",
  link: "link",
  portfolio: "briefcase",
  sparkle: "sparkle-trio",
  writing: "sparkle-trio",
  globe: "globe",
  code: "code",
};

const brandEntry = !iconAsset && icon ? getBrandIcon(icon) : null;
const sfIcon = !iconAsset && !brandEntry && icon ? symbolMap[icon] : null;
const symbolStyle =
  !iconAsset && brandEntry
    ? ({
        ...(brandEntry.ink ? { "--symbol-ink": brandEntry.ink } : {}),
        ...(brandEntry.accent ? { "--symbol-accent": brandEntry.accent } : {}),
      } as Record<string, string>)
    : undefined;

const darkVariantIcons = new Set<string>(["profile-github"]);

const hasDarkVariant = !iconAsset && icon ? darkVariantIcons.has(icon) : false;
const iconSrc = !iconAsset && icon ? `/icons/${icon}.svg` : null;
const iconDarkSrc = hasDarkVariant ? `/icons/${icon}-dark.svg` : null;
---

<span
  class={`symbol symbol--${tint} ${context === "dock" ? "symbol--dock" : ""}`}
  aria-hidden="true"
  style={symbolStyle}
  data-icon={iconKey ?? undefined}
  data-icon-source={iconAsset ? "asset" : "icon"}
>
  {
    iconAsset ? (
      <div class="symbol__media">
        {assetLight && (
          <img
            src={assetLight}
            alt={label}
            loading="lazy"
            data-variant="light"
            style="z-index:1;"
          />
        )}
        {assetDark && (
          <img
            src={assetDark}
            alt={label}
            loading="lazy"
            data-variant="dark"
            style="z-index:2;"
          />
        )}
      </div>
    ) : brandEntry ? (
      <BrandIcon name={icon} size={24} />
    ) : sfIcon ? (
      <SFIcon name={sfIcon} size={24} stroke={1.8} />
    ) : icon ? (
      <div class="symbol__media">
        {hasDarkVariant && iconSrc && iconDarkSrc ? (
          <>
            <img
              src={iconSrc}
              alt={label}
              loading="lazy"
              data-variant="light"
              style="z-index:1;"
            />
            <img
              src={iconDarkSrc}
              alt={label}
              loading="lazy"
              data-variant="dark"
              style="z-index:2;"
            />
          </>
        ) : (
          iconSrc && <img src={iconSrc} alt={label} loading="lazy" />
        )}
      </div>
    ) : (
      <SFIcon name="sparkle" size={24} stroke={1.8} />
    )
  }
</span>

<style>
  .symbol__media {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .symbol[data-icon] .symbol__media img {
    width: 112%;
    height: 112%;
    object-fit: contain;
    object-position: center;
    display: block;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 1;
    transition: opacity 0.2s ease;
  }

  .symbol--dock .symbol__media img {
    width: var(--dock-icon-scale, 126%);
    height: var(--dock-icon-scale, 126%);
  }

  .symbol--dock .symbol__media::before,
  .symbol--dock .symbol__media::after {
    content: "";
    position: absolute;
    inset: 6px;
    border-radius: 12px;
    pointer-events: none;
  }

  .symbol--dock .symbol__media::before {
    background: radial-gradient(circle at 50% 18%, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0) 70%);
    opacity: 0.5;
  }

  .symbol--dock .symbol__media::after {
    border-top: 1px solid rgba(255, 255, 255, 0.26);
    border-bottom: 1px solid rgba(0, 0, 0, 0.14);
    opacity: 0.36;
  }

  .symbol[data-icon="apple-containerization"] .symbol__media img {
    width: 100%;
    height: 100%;
  }

  .symbol--dock[data-icon="apple-containerization-upscayl-2x-digital-art-4x"] {
    --dock-icon-scale: 112%;
  }

  .symbol--dock[data-icon="ghostty-dark-upscayl-2x-digital-art-4x-wrapped"],
  .symbol--dock[data-icon="codeedit-upscayl-2x-digital-art-4x-wrapped"] {
    --dock-icon-scale: 120%;
  }

  .symbol--dock[data-icon="tower"],
  .symbol--dock[data-icon="xcodelogh-upscayl-2x-digital-art-4x"],
  .symbol--dock[data-icon="orbstack"] {
    --dock-icon-scale: 118%;
  }

  .symbol--dock[data-icon="neovimlight-upscayl-2x-digital-art-4x-wrapped"],
  .symbol--dock[data-icon="transmit-upscayl-2x-digital-art-4x"] {
    --dock-icon-scale: 122%;
  }

  .symbol--dock[data-icon="swift"],
  .symbol--dock[data-icon="typescript"],
  .symbol--dock[data-icon="react"],
  .symbol--dock[data-icon="docker"] {
    --dock-icon-scale: 119%;
  }

  .symbol--dock[data-icon="go"],
  .symbol--dock[data-icon="svelte"],
  .symbol--dock[data-icon="rust"],
  .symbol--dock[data-icon="vuejs"],
  .symbol--dock[data-icon="zig"] {
    --dock-icon-scale: 121%;
  }

  .symbol--dock[data-icon="email"],
  .symbol--dock[data-icon="location"],
  .symbol--dock[data-icon="linkedin-light"],
  .symbol--dock[data-icon="instagram-light"],
  .symbol--dock[data-icon="calendar-light"],
  .symbol--dock[data-icon="github"],
  .symbol--dock[data-icon="mastodon"],
  .symbol--dock[data-icon="profile-portfolio"] {
    --dock-icon-scale: 122%;
  }

  .symbol__media img[data-variant="dark"] {
    opacity: 0;
  }

  html.dark .symbol__media img[data-variant="light"],
  [data-theme="dark"] .symbol__media img[data-variant="light"] {
    opacity: 0;
  }

  html.dark .symbol__media img[data-variant="dark"],
  [data-theme="dark"] .symbol__media img[data-variant="dark"] {
    opacity: 1;
  }

  html.light .symbol__media img[data-variant="light"],
  [data-theme="light"] .symbol__media img[data-variant="light"] {
    opacity: 1;
  }

  html.light .symbol__media img[data-variant="dark"],
  [data-theme="light"] .symbol__media img[data-variant="dark"] {
    opacity: 0;
  }
</style>
