---
import styles from "./PageIndicator.module.css";
import pageIndicatorScriptHref from "./page-indicator-script.ts?url";

interface Props {
  containerSelector: string;
  itemSelector?: string;
  ariaLabel?: string;
}

const {
  containerSelector,
  itemSelector = ":scope > *",
  ariaLabel = "Page indicator",
} = Astro.props;
---

<div 
  class={styles.pageIndicator}
  data-page-indicator
  data-motion="normal"
  data-container={containerSelector}
  data-item={itemSelector}
  role="group"
  aria-label={ariaLabel}
>
  <div class={styles.track} data-page-indicator-track>
    <div class={styles.slider} data-page-indicator-slider></div>
    <!-- Dots will be generated dynamically -->
  </div>
</div>

<script is:inline type="module" src={pageIndicatorScriptHref}></script>
