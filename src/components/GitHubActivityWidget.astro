---
interface CommitItem {
  repo: string;
  message: string;
  date: string;
  sha: string;
  url: string;
}

interface Props {
  username?: string;
  limit?: number;
  live?: boolean;
  large?: boolean;
}

const { username = "tuliopc23", limit = 6, live = false, large = false } = Astro.props as Props;

const requestLimit = Math.max(limit * 3, 24);
const widgetId = `github-widget-${Math.random().toString(36).slice(2, 9)}`;

let commits: CommitItem[] = [];

try {
  const eventsResponse = await fetch(
    `https://api.github.com/users/${username}/events/public?per_page=${requestLimit}`,
    {
      headers: { "User-Agent": "tulio-personal-website" },
    },
  );

  if (eventsResponse.ok) {
    const events = (await eventsResponse.json()) as Array<Record<string, unknown>>;
    commits = events
      .filter((event) => event.type === "PushEvent")
      .flatMap((event) => {
        const payload = event.payload as {
          commits?: Array<{ message?: string; sha?: string; url?: string }>;
        };
        const repo = (event.repo as { name?: string })?.name ?? "unknown-repo";
        const createdAt = String(event.created_at ?? "");

        return (payload.commits ?? []).map((commit) => ({
          repo,
          message: commit.message ?? "Update",
          date: createdAt,
          sha: (commit.sha ?? "").slice(0, 7),
          url: commit.url
            ? String(commit.url)
                .replace("api.github.com/repos", "github.com")
                .replace("/commits/", "/commit/")
            : `https://github.com/${repo}`,
        }));
      })
      .slice(0, limit);
  }
} catch {
  commits = [];
}

const relativeTime = (date: string) => {
  if (!date) return "recently";
  const now = Date.now();
  const then = new Date(date).getTime();
  const diff = Math.max(0, now - then);
  const minutes = Math.floor(diff / 60000);
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
};
---

<div
  id={widgetId}
  class:list={["github-widget", large && "github-widget--large"]}
  data-username={username}
  data-limit={String(limit)}
  data-live={live ? "true" : "false"}
>
  {commits.length > 0 ? (
    <ul class="github-widget__list" role="list" aria-label="Latest GitHub commits">
      {commits.map((commit) => (
        <li class="github-widget__item" role="listitem">
          <a href={commit.url} target="_blank" rel="noopener noreferrer">
            <span class="github-widget__repo">{commit.repo}</span>
            <span class="github-widget__message">{commit.message}</span>
            <span class="github-widget__meta">{relativeTime(commit.date)} • {commit.sha}</span>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="github-widget__empty">GitHub activity unavailable right now.</p>
  )}
</div>

{live && (
  <script is:inline define:vars={{ widgetId }}>
    (() => {
      const root = document.getElementById(widgetId);
      if (!root) return;

      const username = root.dataset.username ?? "tuliopc23";
      const limit = Number.parseInt(root.dataset.limit ?? "6", 10);

      const relativeTime = (date) => {
        if (!date) return "recently";
        const now = Date.now();
        const then = new Date(date).getTime();
        const diff = Math.max(0, now - then);
        const minutes = Math.floor(diff / 60000);
        if (minutes < 60) return `${minutes}m ago`;
        const hours = Math.floor(minutes / 60);
        if (hours < 24) return `${hours}h ago`;
        const days = Math.floor(hours / 24);
        return `${days}d ago`;
      };

      const render = (commits) => {
        if (!Array.isArray(commits) || commits.length === 0) {
          root.innerHTML = '<p class="github-widget__empty">No recent commits yet.</p>';
          return;
        }

        const list = document.createElement("ul");
        list.className = "github-widget__list";
        list.setAttribute("role", "list");
        list.setAttribute("aria-label", "Latest GitHub commits");

        for (const commit of commits) {
          const item = document.createElement("li");
          item.className = "github-widget__item";
          item.setAttribute("role", "listitem");

          const link = document.createElement("a");
          link.href = commit.url;
          link.target = "_blank";
          link.rel = "noopener noreferrer";

          const repo = document.createElement("span");
          repo.className = "github-widget__repo";
          repo.textContent = commit.repo;

          const message = document.createElement("span");
          message.className = "github-widget__message";
          message.textContent = commit.message;

          const meta = document.createElement("span");
          meta.className = "github-widget__meta";
          meta.textContent = `${relativeTime(commit.date)} • ${commit.sha}`;

          link.append(repo, message, meta);
          item.append(link);
          list.append(item);
        }

        root.innerHTML = "";
        root.append(list);
      };

      const hydrate = async () => {
        try {
          const requestLimit = Math.max(limit * 3, 24);
          const response = await fetch(
            `https://api.github.com/users/${username}/events/public?per_page=${requestLimit}`,
            {
              headers: {
                Accept: "application/vnd.github+json",
              },
            },
          );

          if (!response.ok) {
            return;
          }

          const events = await response.json();
          const commits = events
            .filter((event) => event.type === "PushEvent")
            .flatMap((event) => {
              const repo = event.repo?.name ?? "unknown-repo";
              const createdAt = String(event.created_at ?? "");
              return (event.payload?.commits ?? []).map((commit) => ({
                repo,
                message: commit.message ?? "Update",
                date: createdAt,
                sha: String(commit.sha ?? "").slice(0, 7),
                url: commit.url
                  ? String(commit.url)
                      .replace("api.github.com/repos", "github.com")
                      .replace("/commits/", "/commit/")
                  : `https://github.com/${repo}`,
              }));
            })
            .slice(0, limit);

          render(commits);
        } catch {
          // Keep server-rendered fallback when live request fails.
        }
      };

      hydrate();
    })();
  </script>
)}

<style>
  .github-widget {
    min-width: 0;
  }

  .github-widget__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }

  .github-widget__item a {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
    border-radius: 16px;
    border: 1px solid var(--panel-border);
    text-decoration: none;
    color: var(--text-primary);
    background: color-mix(in srgb, var(--surface-card) 94%, transparent);
    transition:
      border-color var(--motion-duration-sm) var(--motion-ease-out),
      background var(--motion-duration-sm) var(--motion-ease-out),
      transform var(--motion-duration-sm) var(--motion-ease-out);
  }

  .github-widget__item a:hover {
    border-color: var(--panel-border-strong);
    background: var(--surface-card-hover);
    transform: translateY(-1px);
  }

  .github-widget__repo {
    font-size: var(--fs-footnote);
    color: var(--text-secondary);
    font-weight: 600;
  }

  .github-widget__message {
    font-size: var(--fs-callout);
    line-height: var(--lh-snug);
    font-weight: 560;
    text-wrap: pretty;
  }

  .github-widget__meta {
    font-size: var(--fs-caption);
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    letter-spacing: 0.01em;
  }

  .github-widget__empty {
    margin: 0;
    color: var(--text-tertiary);
    font-size: var(--fs-callout);
  }

  .github-widget--large .github-widget__list {
    gap: 14px;
  }

  .github-widget--large .github-widget__item a {
    padding: 16px 18px;
    border-radius: 18px;
    grid-template-columns: minmax(0, 1fr);
  }

  .github-widget--large .github-widget__message {
    font-size: clamp(17px, 1vw + 14px, 20px);
    line-height: 1.28;
  }
</style>
