---
import GitHubActivity from "./GitHubActivity";

interface Props {
  username?: string;
  token?: string;
  limit?: number;
  live?: boolean;
  large?: boolean;
}

const {
  username = "tuliopc23",
  token = import.meta.env.GITHUB_TOKEN,
  limit = 8,
  live = true,
  large = true,
} = Astro.props as Props;
---

<GitHubActivity
  username={username}
  token={token}
  limit={limit}
  live={live}
  large={large}
  client:load
/>
