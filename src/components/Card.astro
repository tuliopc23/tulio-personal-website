---
import IconTile from "./IconTile.astro";
import PhosphorIcon from "./PhosphorIcon.astro";

interface Props {
  href?: string;
  title?: string;
  body?: string;
  tint?: string;
  cta?: string;
  icon?: string | null;
  iconAsset?: string | null;
  revealGroup?: string;
  revealOrder?: number | string;
  revealDelay?: string;
}

const {
  href,
  title = "Card title",
  body = "",
  tint = "blue",
  cta = "Read more",
  icon = null,
  iconAsset = null,
  revealGroup,
  revealOrder,
  revealDelay,
} = Astro.props as Props;

const revealOrderAttr =
  revealOrder === undefined || revealOrder === null ? undefined : String(revealOrder);
const isInteractive = typeof href === "string" && href.trim().length > 0;
const showCTA = isInteractive && Boolean(cta);
const baseClasses = [
  "card",
  isInteractive ? "hover-elevate motion-surface-standard" : "card--static",
].join(" ");
---

{
  isInteractive ? (
    <a
      class={baseClasses}
      data-tint={tint}
      href={href}
      data-reveal
      data-reveal-group={revealGroup ?? undefined}
      data-reveal-order={revealOrderAttr}
      data-reveal-delay={revealDelay ?? undefined}
    >
      <div class="card__inner">
        <IconTile
          tint={tint}
          label={title}
          icon={iconAsset ? null : icon}
          asset={iconAsset}
        />
        <div class="card__content">
          <h3 class="card-title">{title}</h3>
          <p class="card-body">{body}</p>
          {
            showCTA && (
              <span class="card__cta cta-pill cta-pill--accent motion-cta-pill">
                <span>{cta}</span>
                <PhosphorIcon name="arrow-up-right" size={14} weight="regular" />
              </span>
            )
          }
        </div>
      </div>
    </a>
  ) : (
    <article
      class={baseClasses}
      data-tint={tint}
      data-reveal
      data-reveal-group={revealGroup ?? undefined}
      data-reveal-order={revealOrderAttr}
      data-reveal-delay={revealDelay ?? undefined}
      aria-label={title}
    >
      <div class="card__inner">
        <IconTile
          tint={tint}
          label={title}
          icon={iconAsset ? null : icon}
          asset={iconAsset}
        />
        <div class="card__content">
          <h3 class="card-title">{title}</h3>
          <p class="card-body">{body}</p>
        </div>
      </div>
    </article>
  )
}
