---
/**
 * PhosphorIcon
 * Canonical renderer for semantic UI icons across the site.
 * Uses @phosphor-icons/core and normalizes app-specific aliases to a single icon set.
 */
import styles from "./PhosphorIcon.module.css";

type IconWeight = "thin" | "light" | "regular" | "bold" | "fill" | "duotone";

interface Props {
  name: string;
  size?: number;
  weight?: IconWeight;
  stroke?: number;
  class?: string;
}

const { name, size = 24, weight = "regular", class: className = "" } = Astro.props;

const normalizedName = name.trim().toLowerCase();

// Map site-level semantic icon ids to Phosphor asset names.
const iconMap: Record<string, string> = {
  // Time & Calendar
  clock: "clock",
  calendar: "calendar-blank",
  "calendar-check": "calendar-check",

  // Arrows & Navigation
  "arrow-right": "arrow-right",
  "arrow-left": "arrow-left",
  "arrow-up": "arrow-up",
  "arrow-down": "arrow-down",
  "arrow-up-right": "arrow-up-right",
  "arrow-square-out": "arrow-square-out",
  "arrows-left-right": "arrows-left-right",
  "caret-right": "caret-right",
  "caret-left": "caret-left",
  "caret-down": "caret-down",
  "chevron-right": "caret-right",
  "chevron-left": "caret-left",

  // Social & Communication
  github: "github-logo",
  twitter: "twitter-logo",
  linkedin: "linkedin-logo",
  instagram: "instagram-logo",
  mail: "envelope",
  rss: "rss",
  phone: "phone",

  // Content
  eye: "eye",
  "eye-closed": "eye-closed",
  book: "book-open",
  "book-open": "book-open",
  article: "article",
  code: "code",
  "paint-brush": "paint-brush",
  "terminal-window": "terminal-window",
  "chart-bar": "chart-bar",
  toolbox: "toolbox",

  // UI Elements
  sparkle: "sparkle",
  star: "star",
  heart: "heart",
  share: "share-network",
  "share-network": "share-network",
  link: "link",
  "link-simple": "link-simple",
  info: "info",
  warning: "warning",
  "check-circle": "check-circle",
  "x-circle": "x-circle",
  x: "x",
  user: "user",
  "users-three": "users-three",
  hash: "hash",
  compass: "compass",

  // Location & Places
  "map-pin": "map-pin",
  globe: "globe",
  house: "house",
  home: "house",
  cube: "cube",
  "sidebar-left": "sidebar-simple",

  // Actions
  search: "magnifying-glass",
  "magnifying-glass": "magnifying-glass",
  download: "download-simple",
  upload: "upload-simple",
  copy: "copy",
  check: "check",
  plus: "plus",
  minus: "minus",
  "paper-plane-tilt": "paper-plane-tilt",
  quotes: "quotes",

  // Work & Productivity
  briefcase: "briefcase",
  notebook: "notebook",
  folder: "folder",
  file: "file",
  tag: "tag",
  "rocket-launch": "rocket-launch",
  "folder-simple": "folder-simple",
  "lock-simple": "lock-simple",
  "git-commit": "git-commit",
};

// Get the actual Phosphor icon name
const phosphorName = iconMap[normalizedName] || normalizedName;

// Import SVG dynamically from Phosphor using fs (server-side only)
import { readFileSync } from "node:fs";
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";
import { createRequire } from "node:module";

let svgContent = "";
const candidateWeights = [...new Set<IconWeight>([weight, "regular"])];

// Resolve @phosphor-icons/core package root using Node module resolution.
// pnpm symlinks packages into .pnpm/store, so we resolve the entry point
// and walk up from `dist/` to the package root where `assets/` lives.
let packageRoot = "";
try {
  const require = createRequire(import.meta.url);
  const entry = require.resolve("@phosphor-icons/core");
  packageRoot = dirname(dirname(entry)); // dist/ -> package root
} catch (e: any) {
  console.error("[PhosphorIcon] createRequire failed:", e?.message || e);
  // Fallback to heuristic path resolution
  const projectRoot = dirname(dirname(dirname(fileURLToPath(import.meta.url))));
  packageRoot = join(projectRoot, "node_modules", "@phosphor-icons", "core");
}

for (const candidateWeight of candidateWeights) {
  const iconPath = join(packageRoot, "assets", candidateWeight, `${phosphorName}.svg`);
  try {
    svgContent = readFileSync(iconPath, "utf-8");
    break;
  } catch {
    // Fall through to the next candidate weight.
  }
}

if (!svgContent) {
  console.warn(`Phosphor icon not found: ${phosphorName} (${weight}) (packageRoot=${packageRoot})`);
}
---

{
  svgContent && (
    <span
      class:list={[styles.phosphorIcon, className]}
      style={`display: inline-block; width: ${size}px; height: ${size}px;`}
      aria-hidden="true"
      set:html={svgContent}
    />
  )
}
