---
import { Image } from "astro:assets";
import styles from "./PersonalIcon.module.css";

interface Props {
  size?: number;
  class?: string;
}

const { size = 24, class: className = "" } = Astro.props;
---

<button
  type="button"
  class:list={[styles.personalIcon, className]}
  style={`--pi-size: ${size}px`}
  aria-label="Toggle theme"
  data-theme-toggle-icon
>
  <!-- Dark mode shows the light icon -->
  <Image src="/icons/IconLightMode.svg" class={styles.piDark} alt="" width={28} height={28} loading="eager" />
  
  <!-- Light mode shows the dark icon -->
  <Image src="/icons/IconDarkMode.svg" class={styles.piLight} alt="" width={28} height={28} loading="eager" />
</button>

<script is:inline type="module">
  const bindThemeToggleIcons = () => {
    if (typeof window === "undefined" || !window.themeController) {
      return;
    }

    window.themeController.init();

    const iconButtons = document.querySelectorAll("[data-theme-toggle-icon]");

    iconButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }
      if (button.dataset.themeToggleBound === "true") {
        return;
      }
      button.dataset.themeToggleBound = "true";
      button.addEventListener("click", () => {
        window.themeController.toggleTheme({ persist: true });
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bindThemeToggleIcons, { once: true });
  } else {
    bindThemeToggleIcons();
  }

  document.addEventListener("astro:page-load", bindThemeToggleIcons);
</script>
