---
import { getAllCategories } from "../lib/content/posts";
import PhosphorIcon from "./PhosphorIcon.astro";
import styles from "./CategoryList.module.css";

const _categories = await getAllCategories();
---

{
  _categories.length > 0 && (
    <section class={styles.categoryList} data-reveal data-reveal-group="categories">
      <div class={styles.header}>
        <h2 class={styles.title}>Browse by Category</h2>
      </div>
      <div class={styles.grid}>
        {_categories.map((category) => (
          <a href={`/blog/category/${category.slug}/`} class:list={[styles.card, "hover-elevate", "motion-surface-standard"]}>
            <h3 class={styles.cardTitle}>{category.title}</h3>
            {category.description && (
              <p class={styles.description}>{category.description}</p>
            )}
            <span class:list={[styles.cta, "motion-link-inline"]}>
              <span>View articles</span>
              <PhosphorIcon name="arrow-right" size={16} weight="regular" />
            </span>
          </a>
        ))}
      </div>
    </section>
  )
}
