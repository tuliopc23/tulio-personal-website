---
import PhosphorIcon from "../PhosphorIcon.astro";

interface Props {
  tags: string[];
  allLabel: string;
}

const { tags, allLabel } = Astro.props as Props;
---

<div class="blogTopicChips">
  <p class="blogTopicChips__label">
    <PhosphorIcon name="folder" size={14} weight="regular" />
    Topics
  </p>
  <div class="blogTopicChips__rail liquid-glass liquid-glass-chrome" role="toolbar" aria-label="Filter posts by tag">
    <div class="blogTopicChips__scroller">
      <button
        type="button"
        class:list={["blogTopicChips__chip", "chip-pill", "chip-pill--interactive", "motion-chip", "is-active"]}
        data-blog-filter="all"
      >
        {allLabel}
      </button>
      {
        tags.map((tag) => {
          const slug = tag.toLowerCase().replace(/\s+/g, "-");
          return (
            <button
              type="button"
              class:list={["blogTopicChips__chip", "chip-pill", "chip-pill--interactive", "motion-chip"]}
              data-blog-filter={slug}
            >
              {tag}
            </button>
          );
        })
      }
    </div>
  </div>
</div>
