---
import { generateSrcset, optimizedImageUrl } from "../sanity/lib/image";

interface Props {
  value: {
    url?: string;
    alt?: string | null;
    caption?: string | null;
    lqip?: string | null;
    width?: number;
    height?: number;
    asset?: unknown; // Sanity image asset reference
  };
}

const { value }: Props = Astro.props;

const alt = value.alt && value.alt.trim().length > 0 ? value.alt : "";
const loading = "lazy";
const placeholder = value.lqip;
const hasImage = Boolean(value.url);
const imageStyle =
  value.width && value.height ? `aspect-ratio: ${value.width} / ${value.height};` : undefined;
const placeholderStyle = [
  placeholder ? `background-image: url('${placeholder}')` : undefined,
  imageStyle,
]
  .filter(Boolean)
  .join(";");
const imageDimensions =
  value.width && value.height
    ? { width: value.width, height: value.height }
    : { inferSize: true as const };
---

{
  hasImage && (
    <figure class="articlePortable__figure">
      {placeholder && (
        <div
          aria-hidden="true"
          class="articlePortable__placeholder"
          style={placeholderStyle}
        />
      )}
      <img
        src={optimizedImageUrl(value.url!, 1280)}
        srcset={generateSrcset(value.url!, [320, 640, 768, 1024, 1280, 1920])}
        sizes="(max-width: 768px) 100vw, (max-width: 1280px) 768px, 1024px"
        alt={alt}
        loading={loading}
        decoding="async"
        style={imageStyle}
        data-image-loading
        {...(imageDimensions.inferSize ? {} : imageDimensions)}
      />
      {value.caption && (
        <figcaption class="articlePortable__caption">{value.caption}</figcaption>
      )}
    </figure>
  )
}

<script>
  const images = Array.from(document.querySelectorAll("[data-image-loading]")).filter(
    (img) => img instanceof HTMLImageElement,
  );
  images.forEach((img) => {
    const show = () => img.setAttribute("data-loaded", "true");
    if (img.complete) show();
    else img.addEventListener("load", show, { once: true });
  });
</script>
