---
import RepoRail from "./RepoRail.astro";
import RepoCard from "./RepoCard.astro";
import { getMergedGitHubData, type NormalizedRepoCard } from "../../lib/github-data";
import styles from "./github-section.module.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "GitHub",
  description = "Live momentum, active work, and the cadence behind current projects.",
} = Astro.props as Props;

let repos: NormalizedRepoCard[] = [];
let error: string | null = null;

try {
  repos = await getMergedGitHubData(import.meta.env.GITHUB_TOKEN);
} catch (e) {
  error = "Failed to load GitHub activity.";
  console.error(e);
}
---

<section class={styles.githubSection} id="section-github">
  <header class={styles.header}>
    <h2 class={styles.title}>{title}</h2>
    <p class={styles.description}>{description}</p>
  </header>

  {error ? (
    <div class={styles.errorState}>
       <p>{error}</p>
    </div>
  ) : repos.length === 0 ? (
     <div class={styles.emptyState}>
       <p>No recent repository activity found.</p>
     </div>
  ) : (
    <RepoRail repos={repos}>
      {repos.map((repo) => <RepoCard repo={repo} />)}
    </RepoRail>
  )}
</section>
