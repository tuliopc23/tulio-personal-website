---
import PhosphorIcon from "./PhosphorIcon.astro";
import type { Category } from "../sanity/lib/posts";

interface Props {
  categories?: Category[] | null;
  limit?: number;
  variant?: "pill" | "inline";
}

const { categories = [], limit, variant = "pill" } = Astro.props as Props;
const validCategories = Array.isArray(categories) ? categories : [];
const _displayCategories = limit ? validCategories.slice(0, limit) : validCategories;

// Map category slugs to icon names
const categoryIconMap: Record<string, string> = {
  "software-development": "code",
  development: "code",
  code: "code",
  design: "paint-brush",
  writing: "article",
  tutorial: "book-open",
  announcement: "sparkle",
  default: "folder",
};

const getCategoryIcon = (slug: string) => {
  return categoryIconMap[slug.toLowerCase()] || categoryIconMap.default;
};
---

{
  _displayCategories.length > 0 && (
    <div class:list={["categoryBadges", `categoryBadges--${variant}`]}>
      {_displayCategories.map((category) => (
        <a
          href={`/blog/category/${category.slug}/`}
          class:list={["categoryBadge", `categoryBadge--${variant}`]}
        >
          <PhosphorIcon name={getCategoryIcon(category.slug)} size={12} weight="bold" />
          <span>{category.title}</span>
        </a>
      ))}
    </div>
  )
}

<style>
  .categoryBadges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .categoryBadges--inline {
    gap: 0.45rem;
    align-items: center;
  }

  .categoryBadge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-2xs) var(--space-sm);
    font-size: var(--fs--2);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    background: var(--accent-surface);
    border: 1px solid var(--accent-hairline);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition:
      color 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .categoryBadge--inline {
    gap: 0.3rem;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: none;
    font-size: var(--fs--2);
    letter-spacing: 0.12em;
  }

  [data-theme="dark"] .categoryBadge--inline {
    color: rgba(235, 235, 245, 0.52);
  }

  [data-theme="light"] .categoryBadge--inline {
    color: rgba(60, 60, 67, 0.54);
  }

  .categoryBadge:hover {
    color: var(--accent-bright);
    background: var(--accent-surface-hover);
    border-color: var(--accent);
  }

  .categoryBadge--inline:hover {
    background: none;
    border-color: transparent;
  }

  [data-theme="dark"] .categoryBadge--inline:hover {
    color: rgba(235, 235, 245, 0.76);
  }

  [data-theme="light"] .categoryBadge--inline:hover {
    color: rgba(60, 60, 67, 0.8);
  }

  @media (prefers-reduced-motion: reduce) {
    .categoryBadge {
      transition: none;
    }

    .categoryBadge:hover {
      color: var(--accent-bright);
    }
  }
</style>
