---
// Reading progress indicator component
import styles from "./ReadingProgress.module.css";
---

<div class={styles.readingProgress} aria-hidden="true">
  <div class={styles.bar} data-reading-progress></div>
</div>

<script>
  import { getScrollY, subscribeScroll } from "../lib/scroll-subscribe";

  const progressBar = document.querySelector("[data-reading-progress]");

  if (progressBar instanceof HTMLElement) {
    const updateProgress = () => {
      const articleBody =
        document.querySelector("[data-reading-body] .articlePortable") ||
        document.querySelector("[data-reading-body]") ||
        document.querySelector(".articlePortable");
      if (!(articleBody instanceof HTMLElement)) return;

      const articleTop = articleBody.offsetTop;
      const articleHeight = articleBody.offsetHeight;
      const windowHeight = window.innerHeight;
      const scrollTop = getScrollY();

      const windowBottom = scrollTop + windowHeight;

      const progress = Math.min(
        Math.max((windowBottom - articleTop) / articleHeight, 0),
        1
      );

      progressBar.style.transform = `scaleX(${progress})`;
    };

    subscribeScroll(updateProgress);
    updateProgress();
  }
</script>
