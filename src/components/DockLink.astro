---
import IconTile from "./IconTile.astro";

interface Props {
  href: string;
  title: string;
  tint?: string;
  iconAsset?: string;
  revealOrder?: number | string;
  sizeVariant?: "default" | "dock-premium";
  iconContext?: "tools" | "stack";
}

const {
  href,
  title,
  tint = "blue",
  iconAsset,
  revealOrder,
  sizeVariant = "default",
  iconContext = "tools",
} = Astro.props as Props;
---

<a
  class={`dock-link dock-link--${sizeVariant} hover-elevate ${sizeVariant === "dock-premium" ? "motion-surface-premium" : "motion-surface-standard"}`}
  data-tint={tint}
  href={href}
  data-reveal
  data-reveal-order={revealOrder}
  role="listitem"
  target={href.startsWith("http") ? "_blank" : undefined}
  rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
>
  <IconTile tint={tint} label={title} asset={iconAsset} context={sizeVariant === "dock-premium" ? "dock" : "default"} iconContext={iconContext} />
  <span class="dock-link__name">{title}</span>
</a>

<style>
  .dock-link {
    --dock-accent-base: rgba(255, 255, 255, 0.08);
    --dock-accent-hover: rgba(255, 255, 255, 0.16);
    --dock-glow-rgb: 10, 132, 255;
    --hover-elevate-translate: -4px;
    --hover-elevate-scale: 1.015;
    --hover-shadow: var(--shadow-card-hover), var(--shadow-card-highlight), var(--shadow-card-glow);
    --hover-border: color-mix(in srgb, var(--panel-border-strong) 55%, transparent);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-decoration: none;
    padding: 10px 8px;
    border-radius: 16px;
    transition:
      transform var(--motion-duration-fast) var(--motion-ease-out),
      box-shadow var(--motion-duration-fast) var(--motion-ease-out),
      background-color var(--motion-duration-fast) var(--motion-ease-out),
      border-color var(--motion-duration-fast) var(--motion-ease-out);
    width: 100%;
    position: relative;
    background: color-mix(in srgb, var(--surface-card) 96%, transparent);
    border: 1px solid color-mix(in srgb, var(--panel-border) 68%, transparent);
    box-shadow:
      var(--shadow-card),
      var(--shadow-card-highlight),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 0 36px rgba(var(--dock-glow-rgb), 0.05);
    backdrop-filter: blur(var(--glass-thin-blur)) saturate(var(--glass-saturation-base));
    -webkit-backdrop-filter: blur(var(--glass-thin-blur)) saturate(var(--glass-saturation-base));
  }

  .dock-link--dock-premium {
    min-height: 104px;
    gap: 10px;
    border-radius: 18px;
    padding: 12px 10px 10px;
    box-shadow:
      var(--shadow-card),
      var(--shadow-card-highlight),
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 0 52px rgba(var(--dock-glow-rgb), 0.09);
  }

  .dock-link::before {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    background: radial-gradient(circle at 50% 14%, var(--dock-accent-base), rgba(0, 0, 0, 0) 72%);
    opacity: 0.22;
    pointer-events: none;
    transition: opacity var(--motion-duration-sm) var(--motion-ease-out);
  }

  .dock-link:hover {
    background: color-mix(in srgb, var(--surface-card) 98%, transparent);
    border-color: var(--hover-border);
    box-shadow: var(--hover-shadow);
  }

  .dock-link:hover::before {
    opacity: 0.34;
    background: radial-gradient(circle at 50% 14%, var(--dock-accent-hover), rgba(0, 0, 0, 0) 72%);
  }

  .dock-link--dock-premium:hover::before {
    opacity: 0.44;
  }

  .dock-link[data-tint="blue"] {
    --dock-glow-rgb: 10, 132, 255;
  }

  .dock-link[data-tint="indigo"] {
    --dock-glow-rgb: 94, 92, 232;
  }

  .dock-link[data-tint="cyan"] {
    --dock-glow-rgb: 0, 173, 216;
  }

  .dock-link[data-tint="green"] {
    --dock-glow-rgb: 66, 184, 131;
  }

  .dock-link[data-tint="orange"] {
    --dock-glow-rgb: 255, 120, 60;
  }

  .dock-link[data-tint="yellow"] {
    --dock-glow-rgb: 255, 214, 10;
  }

  .dock-link[data-tint="brown"] {
    --dock-glow-rgb: 183, 136, 86;
  }

  .dock-link__name {
    font-size: var(--fs-footnote);
    font-weight: var(--fw-bold);
    color: var(--text-primary);
    text-align: center;
    line-height: var(--lh-snug);
    margin: 0;
    letter-spacing: var(--ls-footnote);
  }

  .dock-link--dock-premium .dock-link__name {
    font-size: var(--fs-caption);
  }
</style>
