---
import IconTile from "./IconTile.astro";

interface Props {
  href: string;
  title: string;
  tint?: string;
  iconAsset?: string;
  revealOrder?: number | string;
}

const { href, title, tint = "blue", iconAsset, revealOrder } = Astro.props as Props;
---

<a
  class="dock-link hover-elevate"
  data-tint={tint}
  href={href}
  data-reveal
  data-reveal-order={revealOrder}
  role="listitem"
  target={href.startsWith("http") ? "_blank" : undefined}
  rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
>
  <IconTile tint={tint} label={title} asset={iconAsset} />
  <span class="dock-link__name">{title}</span>
</a>

<style>
  .dock-link {
    --dock-accent-base: rgba(255, 255, 255, 0.08);
    --dock-accent-hover: rgba(255, 255, 255, 0.16);
    --hover-elevate-translate: -4px;
    --hover-elevate-scale: 1.015;
    --hover-shadow: var(--shadow-card-hover), var(--shadow-card-highlight), var(--shadow-card-glow);
    --hover-border: color-mix(in srgb, var(--panel-border-strong) 55%, transparent);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-decoration: none;
    padding: 10px;
    border-radius: 18px;
    transition:
      transform var(--motion-duration-fast) var(--motion-ease-out),
      box-shadow var(--motion-duration-fast) var(--motion-ease-out),
      background-color var(--motion-duration-fast) var(--motion-ease-out),
      border-color var(--motion-duration-fast) var(--motion-ease-out);
    width: 100%;
    position: relative;
    background: color-mix(in srgb, var(--surface-card) 96%, transparent);
    border: 1px solid color-mix(in srgb, var(--panel-border) 68%, transparent);
    box-shadow:
      var(--shadow-card),
      var(--shadow-card-highlight),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 0 36px rgba(10, 132, 255, 0.05);
    backdrop-filter: blur(var(--glass-thin-blur)) saturate(var(--glass-saturation-base));
    -webkit-backdrop-filter: blur(var(--glass-thin-blur)) saturate(var(--glass-saturation-base));
  }

  .dock-link::before {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    background: radial-gradient(circle at 50% 14%, var(--dock-accent-base), rgba(0, 0, 0, 0) 72%);
    opacity: 0.22;
    pointer-events: none;
    transition: opacity var(--motion-duration-sm) var(--motion-ease-out);
  }

  .dock-link:hover {
    background: color-mix(in srgb, var(--surface-card) 98%, transparent);
    border-color: var(--hover-border);
    box-shadow: var(--hover-shadow);
  }

  .dock-link:hover::before {
    opacity: 0.34;
    background: radial-gradient(circle at 50% 14%, var(--dock-accent-hover), rgba(0, 0, 0, 0) 72%);
  }

  .dock-link__name {
    font-size: var(--fs-caption);
    font-weight: var(--fw-semibold);
    color: var(--text-primary);
    text-align: center;
    line-height: var(--lh-tight);
    margin: 0;
  }
</style>
