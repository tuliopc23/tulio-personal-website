---
import PhosphorIcon from "./PhosphorIcon.astro";

interface Props {
  variant?: "compact" | "panel";
  source?: string;
  title?: string;
  description?: string;
}

const {
  variant = "panel",
  source = "unknown",
  title = "Get new posts in your inbox",
  description = "One email per post. Double opt-in. Unsubscribe anytime.",
} = Astro.props as Props;

const classes =
  variant === "compact"
    ? "newsletterSignup newsletterSignup--compact"
    : "newsletterSignup surface-panel surface-panel--nested";
---

<section class={classes} aria-label="Newsletter signup">
  <div class="newsletterSignup__copy">
    <span class="newsletterSignup__eyebrow meta-chip meta-chip--eyebrow">
      <PhosphorIcon name="mail" size={14} weight="regular" />
      Newsletter
    </span>
    <h2 class="newsletterSignup__title">{title}</h2>
    <p class="newsletterSignup__lede">{description}</p>
  </div>

  <form
    class="newsletterSignup__form"
    method="post"
    action="/api/newsletter/subscribe"
    data-newsletter-form
    data-newsletter-source={source}
  >
    <label class="sr-only" for={`newsletter-email-${source}`}>Email</label>
    <input
      id={`newsletter-email-${source}`}
      class="newsletterSignup__input"
      name="email"
      type="email"
      inputmode="email"
      autocomplete="email"
      placeholder="you@domain.com"
      required
    />

    <input type="hidden" name="source" value={source} />

    <!-- Honeypot: bots will fill this, humans won't. -->
    <label class="sr-only" for={`newsletter-company-${source}`}>Company</label>
    <input
      id={`newsletter-company-${source}`}
      name="company"
      type="text"
      tabindex="-1"
      autocomplete="off"
      class="newsletterSignup__hp"
    />

    <button type="submit" class="btn newsletterSignup__button">
      <PhosphorIcon name="paper-plane-tilt" size={16} weight="regular" />
      <span>Subscribe</span>
    </button>

    <p class="newsletterSignup__status" data-newsletter-status aria-live="polite" role="status"></p>
  </form>

  <script>
    import "../scripts/newsletter-form";
  </script>
</section>

<style>
  .newsletterSignup {
    display: grid;
    gap: 14px;
    padding: clamp(18px, 2.8vw, 28px);
  }

  .newsletterSignup:not(.newsletterSignup--compact) {
    border-color: color-mix(in srgb, var(--panel-border-strong) 54%, transparent);
    background:
      radial-gradient(circle at 88% 54%, rgba(10, 132, 255, 0.10), transparent 32%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.10), rgba(255, 255, 255, 0.025)),
      color-mix(in srgb, var(--surface-panel-bg, var(--surface-card)) 86%, transparent);
    box-shadow:
      var(--shadow-card),
      0 20px 56px rgba(4, 10, 24, 0.14),
      0 0 72px rgba(10, 132, 255, 0.055);
  }

  .newsletterSignup__title {
    margin: 10px 0 0;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }

  .newsletterSignup__lede {
    margin: 8px 0 0;
    color: var(--text-secondary, rgba(255, 255, 255, 0.72));
  }

  .newsletterSignup__form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 10px;
    align-items: center;
  }

  .newsletterSignup__input {
    width: 100%;
    min-height: max(52px, var(--touch-target-min, 44px));
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--panel-border-strong) 42%, transparent);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.10), rgba(255, 255, 255, 0.02)),
      color-mix(in srgb, var(--surface-1, rgba(0, 0, 0, 0.2)) 82%, transparent);
    padding: 12px 16px;
    color: inherit;
    outline: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.10),
      0 10px 26px rgba(4, 10, 24, 0.08);
    transition:
      border-color var(--motion-duration-sm) var(--motion-ease-out),
      box-shadow var(--motion-duration-sm) var(--motion-ease-out),
      background var(--motion-duration-sm) var(--motion-ease-out);
  }

  .newsletterSignup__input::placeholder {
    color: color-mix(in srgb, var(--text-tertiary, currentColor) 62%, transparent);
  }

  .newsletterSignup__input:focus {
    border-color: color-mix(in srgb, var(--accent, #0a84ff) 54%, transparent);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--accent, #0a84ff) 18%, transparent),
      0 16px 36px rgba(10, 132, 255, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
  }

  .newsletterSignup__button {
    min-height: max(52px, var(--touch-target-min, 44px));
    border-color: color-mix(in srgb, var(--accent, #0a84ff) 42%, white 10%);
    background:
      radial-gradient(circle at 32% 18%, rgba(255, 255, 255, 0.54), transparent 30%),
      linear-gradient(180deg, color-mix(in srgb, var(--accent, #0a84ff) 78%, #7cc7ff 22%), color-mix(in srgb, var(--accent, #0a84ff) 86%, #0057d9 14%));
    color: #fff;
    box-shadow:
      0 18px 42px color-mix(in srgb, var(--accent, #0a84ff) 34%, transparent),
      0 0 34px color-mix(in srgb, var(--accent, #0a84ff) 26%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.42),
      inset 0 -1px 0 rgba(0, 38, 105, 0.22);
  }

  .newsletterSignup__button:hover {
    transform: translateY(-1px);
    box-shadow:
      0 22px 52px color-mix(in srgb, var(--accent, #0a84ff) 42%, transparent),
      0 0 46px color-mix(in srgb, var(--accent, #0a84ff) 34%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      inset 0 -1px 0 rgba(0, 38, 105, 0.24);
  }

  .newsletterSignup__button:focus-visible {
    outline: none;
    box-shadow:
      var(--focus-ring),
      0 18px 42px color-mix(in srgb, var(--accent, #0a84ff) 34%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.42);
  }

  .newsletterSignup__status {
    grid-column: 1 / -1;
    margin: 0;
    min-height: 1.2em;
    font-size: 0.95rem;
    color: var(--text-secondary, rgba(255, 255, 255, 0.72));
  }

  .newsletterSignup__status[data-kind="success"] {
    color: rgba(110, 231, 183, 0.95);
  }

  .newsletterSignup__status[data-kind="error"] {
    color: rgba(252, 165, 165, 0.95);
  }

  .newsletterSignup__hp {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  @media (max-width: 520px) {
    .newsletterSignup__form {
      grid-template-columns: 1fr;
    }
  }
</style>
