---
/**
 * Brand logo: theme-aware high-quality WebP.
 * - Dark mode: Brand-icon-light.webp (light logo on dark background)
 * - Light mode: Brand-icon-dark.webp (dark logo on light background)
 * Sizing: use `size` for display dimensions (header 32px, footer 20px, favicon via link tags).
 */
interface Props {
  size?: number;
  class?: string;
}

const { size = 24, class: className = "" } = Astro.props;
---

<span
  class={`brand-logo ${className}`}
  style={`--brand-logo-size: ${size}px`}
  role="img"
  aria-label="Tulio Cunha"
>
  <!-- Dark mode: show light icon -->
  <img
    src="/Brand-icon-light.webp"
    alt=""
    class="brand-logo__light"
    width={size}
    height={size}
    decoding="async"
    fetchpriority="high"
  />
  <!-- Light mode: show dark icon -->
  <img
    src="/Brand-icon-dark.webp"
    alt=""
    class="brand-logo__dark"
    width={size}
    height={size}
    decoding="async"
    fetchpriority="high"
  />
</span>

<style>
  .brand-logo {
    display: inline-grid;
    place-items: center;
    width: var(--brand-logo-size, 24px);
    height: var(--brand-logo-size, 24px);
    position: relative;
    isolation: isolate;
    /* Tahoe 26 - Fixed radius for better sub-pixel rendering */
    border-radius: 10px; 
    /* Subtle background to ground the icon */
    background: var(--surface-raised);
    /* Multilayer shadow system - optimized for small scale */
    box-shadow: 
      /* Inner border/highlight */
      inset 0 0 0 1px var(--hairline),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      /* Depth shadows */
      0 1px 2px rgba(0, 0, 0, 0.15),
      0 4px 12px rgba(0, 0, 0, 0.12),
      0 8px 24px rgba(0, 0, 0, 0.1);
    transition: transform 260ms var(--motion-ease-out), box-shadow 260ms var(--motion-ease-out);
  }

  .brand-logo:hover {
    transform: translateY(-1px) scale(1.04);
    box-shadow: 
      inset 0 0 0 1px var(--panel-border-strong),
      0 2px 4px rgba(0, 0, 0, 0.18),
      0 8px 24px rgba(0, 0, 0, 0.15),
      0 16px 48px rgba(0, 0, 0, 0.12);
  }

  .brand-logo img {
    grid-area: 1 / 1;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    pointer-events: none;
    transition: opacity 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* Theme visibility: Inverted logic for matching theme colors */
  /* Light Mode (pi-dark=1): Show Light/Blue Icon */
  .brand-logo__light {
    opacity: var(--pi-dark, 1);
  }

  /* Dark Mode (pi-light=1): Show Dark/Black Icon */
  .brand-logo__dark {
    opacity: var(--pi-light, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-logo img {
      transition: none;
    }
  }
</style>
