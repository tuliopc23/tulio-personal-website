---
/**
 * Brand logo: theme-aware high-quality WebP.
 * - Dark mode: brand-glyph-dark.png
 * - Light mode: brand-glyph-light.png
 * Sizing: use `size` for display dimensions (header 32px, footer 20px, favicon via link tags).
 */
import { Image } from "astro:assets";
import styles from "./BrandLogo.module.css";

interface Props {
  size?: number;
  class?: string;
  priority?: boolean;
  variant?: "default" | "bare";
}

const { size = 24, class: className = "", priority = false, variant = "default" } = Astro.props;
---

<span
  class:list={[styles.brandLogo, variant === "bare" && styles.bare, className]}
  style={`--brand-logo-size: ${size}px`}
  role="img"
  aria-label="Tulio Cunha"
>
  <!-- Light mode -->
  <Image
    src="/brand-glyph-light.png"
    alt=""
    class={styles.light}
    width={size * 2}
    height={size * 2}
    priority={priority}
  />
  <!-- Dark mode -->
  <Image
    src="/brand-glyph-dark.png"
    alt=""
    class={styles.dark}
    width={size * 2}
    height={size * 2}
    priority={priority}
  />
</span>
