---
/**
 * Brand logo: theme-aware high-quality WebP.
 * - Dark mode: Brand-icon-light.webp (light logo on dark background)
 * - Light mode: Brand-icon-dark.webp (dark logo on light background)
 * Sizing: use `size` for display dimensions (header 32px, footer 20px, favicon via link tags).
 */
import { Image } from "astro:assets";
import styles from "./BrandLogo.module.css";

interface Props {
  size?: number;
  class?: string;
}

const { size = 24, class: className = "" } = Astro.props;
---

<span
  class:list={[styles.brandLogo, className]}
  style={`--brand-logo-size: ${size}px`}
  role="img"
  aria-label="Tulio Cunha"
>
  <!-- Dark mode: show light icon -->
  <Image
    src="/Brand-icon-light.webp"
    alt=""
    class={styles.light}
    width={size}
    height={size}
    priority
  />
  <!-- Light mode: show dark icon -->
  <Image
    src="/Brand-icon-dark.webp"
    alt=""
    class={styles.dark}
    width={size}
    height={size}
    priority
  />
</span>
