---
interface Props {
  value: string;
  label: string;
  caption?: string;
  trend?: "up" | "down" | "flat";
}

const { value, label, caption = "", trend } = Astro.props as Props;
---

<aside class:list={["articleStat", trend && `articleStat--${trend}`]}>
  <span class="articleStat__value">
    <span class="articleStat__valueText">{value}</span>
  </span>
  <span class="articleStat__label">{label}</span>
  {caption && <span class="articleStat__caption">{caption}</span>}
</aside>
