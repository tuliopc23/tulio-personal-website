---
import type { PortableTextBlock } from "@portabletext/types";
import { PortableText } from "astro-portabletext";
import PhosphorIcon from "../PhosphorIcon.astro";
import styles from "./Callout.module.css";

interface Props {
  value: {
    variant: "info" | "tip" | "warning" | "success" | "error";
    title?: string;
    body: PortableTextBlock[];
  };
}

const { value } = Astro.props;
const { variant, title, body } = value;

const iconName: Record<string, string> = {
  info: "info",
  tip: "lightbulb",
  warning: "warning",
  success: "check-circle",
  error: "x-circle",
};

const variantClassMap = {
  info: styles.calloutInfo,
  tip: styles.calloutTip,
  warning: styles.calloutWarning,
  success: styles.calloutSuccess,
  error: styles.calloutError,
} as const;
---

<div class:list={[styles.callout, variantClassMap[variant]]} role="note" aria-label={`${variant} callout`}>
  <div class={styles.calloutIcon} aria-hidden="true">
    <PhosphorIcon name={iconName[variant]} size={20} weight="regular" />
  </div>
  <div class={styles.calloutContent}>
    {title && <div class={styles.calloutTitle}>{title}</div>}
    <div class={styles.calloutBody}>
      <PortableText value={body} />
    </div>
  </div>
</div>
