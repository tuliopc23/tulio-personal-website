---
import styles from "./Divider.module.css";

interface Props {
  value: {
    style: "line" | "dots" | "asterisks" | "space";
  };
}

const input = (Astro.props.value ?? Astro.props) as Partial<Props["value"]>;
const _style = input.style ?? "line";
---

<div class={styles.divider} role="separator" aria-hidden="true">
  {_style === "line" && <hr class={styles.line} />}
  {_style === "dots" && <div class={styles.dots}>• • •</div>}
  {_style === "asterisks" && <div class={styles.asterisks}>* * *</div>}
  {_style === "space" && <div class={styles.space} />}
</div>
