---
import styles from "./ScrollIndicator.module.css";

interface Props {
  containerClass?: string;
  ariaLabel?: string;
}

const { containerClass = "", ariaLabel = "Scroll for more content" } = Astro.props;
---

<div
  class:list={[styles.scrollIndicator, containerClass]}
  data-scroll-indicator
  data-motion="normal"
  aria-label={ariaLabel}
>
  <button 
    class:list={[styles.arrow, styles.left]}
    data-scroll-arrow="left"
    data-visible="false"
    aria-hidden="true"
    tabindex="-1"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <button 
    class:list={[styles.arrow, styles.right]}
    data-scroll-arrow="right"
    data-visible="false"
    aria-hidden="true"
    tabindex="-1"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <div class={styles.hint} data-scroll-hint data-visible="false" aria-live="polite" role="status">
    <span>Scroll for more →</span>
  </div>
</div>

<script>
  (() => {
    const cleanupKey = '__scrollIndicatorCleanups';

    const getCleanups = () => {
      if (!Array.isArray(window[cleanupKey])) {
        window[cleanupKey] = [];
      }

      return window[cleanupKey];
    };

    const cleanupAll = () => {
      getCleanups().splice(0).forEach((cleanup) => {
        cleanup();
      });
    };

    const initScrollIndicators = () => {
      cleanupAll();

      const indicators = document.querySelectorAll('[data-scroll-indicator]');

      indicators.forEach((indicator) => {
        if (!(indicator instanceof HTMLElement)) return;

        let scrollContainer = indicator.parentElement;
        while (scrollContainer && scrollContainer !== document.body) {
          const style = window.getComputedStyle(scrollContainer);
          if (style.overflowX === 'auto' || style.overflowX === 'scroll') {
            break;
          }
          scrollContainer = scrollContainer.parentElement;
        }

        if (!(scrollContainer instanceof HTMLElement) || scrollContainer === document.body) {
          return;
        }

        const leftArrow = indicator.querySelector('[data-scroll-arrow="left"]');
        const rightArrow = indicator.querySelector('[data-scroll-arrow="right"]');
        const hint = indicator.querySelector('[data-scroll-hint]');
        const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

        let hasInteracted = false;
        try {
          hasInteracted = sessionStorage.getItem('carousel-interacted') === 'true';
        } catch {
          hasInteracted = false;
        }

        let showHintTimeout = 0;
        let hideHintTimeout = 0;

        const clearHintTimers = () => {
          if (showHintTimeout) {
            window.clearTimeout(showHintTimeout);
            showHintTimeout = 0;
          }
          if (hideHintTimeout) {
            window.clearTimeout(hideHintTimeout);
            hideHintTimeout = 0;
          }
        };

        const prefersReducedMotion = () => {
          const rootMotion = document.documentElement.dataset.motion;
          return rootMotion === 'reduced' || (rootMotion !== 'normal' && motionQuery.matches);
        };

        const updateMotionState = () => {
          const reduced = prefersReducedMotion();
          indicator.dataset.motion = reduced ? 'reduced' : 'normal';

          if (reduced) {
            clearHintTimers();
            hint?.setAttribute('data-visible', 'false');
          }

          return reduced;
        };

        const updateArrows = () => {
          updateMotionState();

          if (window.innerWidth >= 1024) {
            leftArrow?.setAttribute('data-visible', 'false');
            rightArrow?.setAttribute('data-visible', 'false');
            return;
          }

          const { scrollLeft, scrollWidth, clientWidth } = scrollContainer;
          const atStart = scrollLeft <= 10;
          const atEnd = scrollLeft + clientWidth >= scrollWidth - 10;

          leftArrow?.setAttribute('data-visible', String(!atStart));
          rightArrow?.setAttribute('data-visible', String(!atEnd));
        };

        const markInteracted = () => {
          if (!hasInteracted) {
            hasInteracted = true;
            try {
              sessionStorage.setItem('carousel-interacted', 'true');
            } catch {
              // ignore storage errors
            }
          }

          clearHintTimers();
          hint?.setAttribute('data-visible', 'false');
        };

        const showHintIfNeeded = () => {
          const reduced = updateMotionState();
          clearHintTimers();

          if (
            hasInteracted ||
            reduced ||
            !(hint instanceof HTMLElement) ||
            window.innerWidth >= 1024
          ) {
            return;
          }

          showHintTimeout = window.setTimeout(() => {
            hint.setAttribute('data-visible', 'true');
            hideHintTimeout = window.setTimeout(() => {
              hint.setAttribute('data-visible', 'false');
            }, 3000);
          }, 500);
        };

        const handleLeftClick = () => {
          const scrollAmount = scrollContainer.clientWidth * 0.8;
          scrollContainer.scrollBy({
            left: -scrollAmount,
            behavior: updateMotionState() ? 'auto' : 'smooth',
          });
          markInteracted();
        };

        const handleRightClick = () => {
          const scrollAmount = scrollContainer.clientWidth * 0.8;
          scrollContainer.scrollBy({
            left: scrollAmount,
            behavior: updateMotionState() ? 'auto' : 'smooth',
          });
          markInteracted();
        };

        const handleScroll = () => {
          updateArrows();
          markInteracted();
        };

        const handleResize = () => {
          updateArrows();
          showHintIfNeeded();
        };

        const handleMotionChange = () => {
          updateArrows();
          showHintIfNeeded();
        };

        leftArrow?.addEventListener('click', handleLeftClick);
        rightArrow?.addEventListener('click', handleRightClick);
        scrollContainer.addEventListener('scroll', handleScroll, { passive: true });
        window.addEventListener('resize', handleResize, { passive: true });

        if (typeof motionQuery.addEventListener === 'function') {
          motionQuery.addEventListener('change', handleMotionChange);
        } else if (typeof motionQuery.addListener === 'function') {
          motionQuery.addListener(handleMotionChange);
        }

        getCleanups().push(() => {
          clearHintTimers();
          leftArrow?.removeEventListener('click', handleLeftClick);
          rightArrow?.removeEventListener('click', handleRightClick);
          scrollContainer.removeEventListener('scroll', handleScroll);
          window.removeEventListener('resize', handleResize);

          if (typeof motionQuery.removeEventListener === 'function') {
            motionQuery.removeEventListener('change', handleMotionChange);
          } else if (typeof motionQuery.removeListener === 'function') {
            motionQuery.removeListener(handleMotionChange);
          }
        });

        updateArrows();
        showHintIfNeeded();
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScrollIndicators, { once: true });
    } else {
      initScrollIndicators();
    }

    document.addEventListener('astro:page-load', initScrollIndicators);
  })();
</script>
