---
import PhosphorIcon from "./PhosphorIcon.astro";
import type { SanityProject } from "../sanity/lib/projects";

interface Props {
  project: SanityProject;
  revealGroup?: string;
  revealOrder?: number | string;
}

const { project, revealGroup = "projects-grid", revealOrder }: Props = Astro.props as Props;

const _categoriesAttr = (project.categories ?? []).join(",");
const _hasImage = !!project.coverImage?.url;
const _statusKey = project.status?.toLowerCase() ?? "exploration";

const _categoryColors: Record<string, string> = {
  native: "#5e5ce8",
  web: "#0a84ff",
  tooling: "#30d948",
  "design-system": "#ff3861",
  experience: "#c25bf4",
};
const _fallbackColor = _categoryColors[(project.categories ?? [])[0] ?? ""] ?? "#0a84ff";
---

<a
  class="card projectCard hover-elevate"
  href={project.href}
  target="_blank"
  rel="noreferrer noopener"
  data-analytics-event={`project:${project.slug}`}
  data-reveal
  data-reveal-group={revealGroup}
  data-reveal-order={revealOrder === undefined || revealOrder === null
    ? undefined
    : String(revealOrder)}
  data-project-categories={_categoriesAttr}
  data-project-card
>
  <div class="projectCard__media">
    {
      _hasImage ? (
        <img
          src={project.coverImage!.url!}
          alt={project.coverImage?.alt ?? project.title}
          class="projectCard__image"
          loading="lazy"
          decoding="async"
          style={
            project.coverImage?.lqip
              ? `background-image: url('${project.coverImage.lqip}'); background-size: cover;`
              : undefined
          }
        />
      ) : (
        <div
          class="projectCard__fallback"
          style={`background: linear-gradient(135deg, ${_fallbackColor}33 0%, ${_fallbackColor}18 100%);`}
          aria-hidden="true"
        >
          <PhosphorIcon name="cube" size={36} weight="duotone" />
        </div>
      )
    }
  </div>

  <div class="projectCard__body">
    <div class="projectCard__heading">
      <p class="projectCard__eyebrow">
        <span>{project.role}</span>
        <span class="projectCard__statusDot" data-status={_statusKey} aria-hidden="true"></span>
      </p>
      <h3 class="projectCard__title">{project.title}</h3>
    </div>
    <p class="projectCard__summary">{project.summary}</p>
    <span class="projectCard__cta">
      <span>{project.cta}</span>
      <PhosphorIcon name="arrow-up-right" size={16} weight="regular" />
    </span>
  </div>
</a>

<style>
  .projectCard {
    --tilt-x: 0deg;
    --tilt-y: 0deg;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: var(--space-xs);
    height: 100%;
  }

  .projectCard__media {
    position: relative;
    border-radius: 12px;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface-elevated);
  }

  .projectCard__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-size: cover;
    background-position: center;
    transition: transform var(--motion-duration-md) var(--motion-ease-out);
  }

  .projectCard:hover .projectCard__image,
  .projectCard:focus-visible .projectCard__image {
    transform: scale(1.03);
  }

  .projectCard__fallback {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: var(--text-tertiary);
  }

  .projectCard__body {
    display: grid;
    gap: var(--space-xxs);
    align-content: start;
  }

  .projectCard__heading {
    display: grid;
    gap: 4px;
  }

  .projectCard__eyebrow {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--fs--2);
    font-weight: 600;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .projectCard__statusDot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--text-tertiary);
  }

  .projectCard__statusDot[data-status="live"] {
    background: var(--green);
  }

  .projectCard__statusDot[data-status="maintained"] {
    background: var(--yellow);
  }

  .projectCard__statusDot[data-status="exploration"] {
    background: var(--text-tertiary);
  }

  .projectCard__title {
    margin: 0;
    font-size: clamp(18px, 0.8vw + 16px, 22px);
    font-weight: 700;
    letter-spacing: var(--ls-h3);
    line-height: 1.2;
  }

  .projectCard__summary {
    margin: 0;
    font-size: var(--fs--1);
    font-weight: 400;
    line-height: 1.52;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .projectCard__cta {
    margin-top: var(--space-xxs);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    justify-self: start;
    width: fit-content;
    font-weight: var(--fw-medium);
    font-size: var(--fs-footnote);
    letter-spacing: var(--ls-footnote);
    color: var(--text-strong-on-primary, #fefefe);
    border: 1px solid color-mix(in srgb, var(--blue) 46%, transparent);
    border-radius: 999px;
    padding: 10px 14px;
    min-width: 44px;
    min-height: 44px;
    background: color-mix(in srgb, var(--blue) 26%, var(--surface-card) 74%);
    box-shadow:
      0 6px 16px rgba(10, 132, 255, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.24);
    transition:
      border-color var(--motion-duration-sm) var(--motion-ease-out),
      background var(--motion-duration-sm) var(--motion-ease-out),
      transform var(--motion-duration-sm) var(--motion-ease-out),
      box-shadow var(--motion-duration-sm) var(--motion-ease-out);
  }

  .projectCard:hover .projectCard__cta,
  .projectCard:focus-visible .projectCard__cta {
    transform: translateY(-1px);
    box-shadow:
      0 10px 24px rgba(10, 132, 255, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.28);
  }

  .projectCard__cta :global(svg) {
    transition: transform var(--motion-duration-sm) var(--motion-spring-out);
    display: inline-block;
  }

  .projectCard:hover .projectCard__cta :global(svg),
  .projectCard:focus-visible .projectCard__cta :global(svg) {
    transform: translateX(4px);
  }
</style>
