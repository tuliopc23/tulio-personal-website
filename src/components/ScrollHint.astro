---
import PhosphorIcon from "./PhosphorIcon.astro";
import styles from "./ScrollHint.module.css";

interface Props {
  target: string;
  text?: string;
  storageKey?: string;
  variant?: "mobile" | "desktop" | "all";
  className?: string;
  ctaLabel?: string;
  ctaIcon?: string;
  persist?: boolean;
  ctaOnly?: boolean;
}

const {
  target,
  text = "Scroll left",
  storageKey,
  variant = "mobile",
  className,
  ctaLabel,
  ctaIcon = "arrow-left",
  persist = true,
  ctaOnly = false,
} = Astro.props as Props;

if (!target || typeof target !== "string") {
  throw new Error("ScrollHint requires a `target` selector pointing to the scroll container.");
}

const baseKey = storageKey ?? target;
const sanitizedKey = `scroll-hint:${baseKey.replace(/[^\w:-]+/g, "_")}`;
const id = `scroll-hint-${sanitizedKey.split(":").at(-1) ?? "hint"}`;
const variantClass =
  variant === "desktop" ? styles.desktop : variant === "all" ? styles.all : styles.mobile;
---

<div
  id={id}
  class:list={[styles.scrollHint, variantClass, className]}
  data-scroll-hint
  data-scroll-hint-target={target}
  data-scroll-hint-key={sanitizedKey}
  data-scroll-hint-variant={variant}
  data-scroll-hint-persist={persist ? "true" : "false"}
  data-scroll-hint-mode={ctaOnly ? "cta-only" : "default"}
  role="note"
  data-scroll-hint-state="visible"
>
  <div class={styles.content}>
    {
      !ctaOnly && (
        <span class={styles.label}>
          {text}
          <span aria-hidden="true" class={styles.glyph}>→</span>
        </span>
      )
    }
    {
      ctaLabel && (
        <span
          class:list={[styles.cta, "cta-pill", "cta-pill--accent", "motion-cta-pill"]}
          aria-hidden="true"
        >
          <span>{ctaLabel}</span>
          <PhosphorIcon name={ctaIcon} size={16} weight="regular" />
        </span>
      )
    }
  </div>
</div>

<script is:inline>
  (() => {
    const cleanupKey = '__scrollHintCleanups';

    const getCleanups = () => {
      if (!Array.isArray(window[cleanupKey])) {
        window[cleanupKey] = [];
      }

      return window[cleanupKey];
    };

    const cleanupAll = () => {
      getCleanups().splice(0).forEach((cleanup) => {
        cleanup();
      });
    };

    const initHints = () => {
      cleanupAll();

      const hints = Array.from(document.querySelectorAll('[data-scroll-hint]'));
      if (hints.length === 0) return;

      hints.forEach((hint) => {
        if (hint.dataset.scrollHintReady === "true") return;

        const targetSelector = hint.dataset.scrollHintTarget;
        const storageKey = hint.dataset.scrollHintKey ?? "";
        const shouldPersist = hint.dataset.scrollHintPersist !== "false";

        if (!targetSelector) return;

        const scrollContainer = document.querySelector(targetSelector);
        if (!scrollContainer) return;

        const persistKey = storageKey || `scroll-hint:${targetSelector}`;

        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        const hideHint = () => {
          if (hint.dataset.scrollHintState === "hidden") return;
          hint.dataset.scrollHintState = "hidden";
          if (shouldPersist) {
            try {
              sessionStorage.setItem(persistKey, "dismissed");
            } catch (error) {
              console.warn("Unable to persist scroll hint dismissal", error);
            }
          }
          detach();
        };

        const handleInteraction = () => {
          hideHint();
        };

        const handleKeyDown = () => {
          const active = document.activeElement;
          if (active && scrollContainer.contains(active)) {
            hideHint();
          }
        };

        const detach = () => {
          scrollContainer.removeEventListener("scroll", handleInteraction);
          scrollContainer.removeEventListener("pointerdown", handleInteraction);
          scrollContainer.removeEventListener("touchstart", handleInteraction);
          document.removeEventListener("keydown", handleKeyDown);
        };

        getCleanups().push(detach);

        const dismissed = (() => {
          if (!shouldPersist) {
            return false;
          }
          try {
            return sessionStorage.getItem(persistKey) === "dismissed";
          } catch {
            return false;
          }
        })();

        if (dismissed || prefersReducedMotion) {
          hint.dataset.scrollHintState = "hidden";
          hint.setAttribute("aria-hidden", "true");
          hint.dataset.scrollHintReady = "true";
          return;
        }

        hint.dataset.scrollHintState = "visible";
        hint.removeAttribute("aria-hidden");
        hint.dataset.scrollHintReady = "true";

        scrollContainer.addEventListener("scroll", handleInteraction, { passive: true });
        scrollContainer.addEventListener("pointerdown", handleInteraction, { passive: true });
        scrollContainer.addEventListener("touchstart", handleInteraction, { passive: true });
        document.addEventListener("keydown", handleKeyDown);

      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHints, { once: true });
    } else {
      initHints();
    }

    document.addEventListener("astro:page-load", initHints);
  })();
</script>
