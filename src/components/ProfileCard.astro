---
import IconTile from "./IconTile.astro";
import PhosphorIcon from "./PhosphorIcon.astro";

const {
  name = "Tulio Cunha",
  title = "Full Stack Developer",
  location = "Brazil",
  email = "contact@tuliocunha.dev",
} = Astro.props;

const encodedLocation = encodeURIComponent(location);
const locationHref = `https://maps.apple.com/?q=${encodedLocation}`;
const profilePhotoSrc = import.meta.env.DEV
  ? "/profile-photo.png"
  : "/cdn-cgi/image/width=384,height=384,fit=cover,quality=90,format=auto/profile-photo.png";

const contactCards = [
  {
    label: "Contact",
    value: "Open form",
    href: "/contact",
    tint: "indigo",
    asset: "/icons/Socials/Email.webp",
    ariaLabel: `Open contact form for ${name}`,
    external: false,
  },
  {
    label: "Location",
    value: location,
    href: locationHref,
    tint: "cyan",
    asset: "/icons/Socials/Location.svg",
    ariaLabel: `Open ${name}'s location in Maps`,
    external: true,
  },
];

const socialCards = [
  {
    title: "GitHub",
    href: "https://github.com/tuliopc23",
    tint: "indigo",
    icon: "github",
    ariaLabel: "Explore Tulio projects on GitHub",
    external: true,
  },
  {
    title: "My Portfolio",
    href: "https://portfolio.tuliocunha.dev",
    tint: "cyan",
    icon: "profile-portfolio",
    ariaLabel: "Explore Tulio portfolio work",
    external: true,
  },
  {
    title: "LinkedIn",
    href: "https://linkedin.com/in/tuliopinheirocunha",
    tint: "blue",
    asset: "/icons/Socials/linkedin-light.svg",
    ariaLabel: "Connect with Tulio on LinkedIn",
    external: true,
  },
  {
    title: "Instagram",
    href: "https://instagram.com/tuliopinheirocunha",
    tint: "pink",
    asset: "/icons/Socials/instagram-light.svg",
    ariaLabel: "Follow Tulio on Instagram",
    external: true,
  },
  {
    title: "Mastodon",
    href: "https://mastodon.social/@tuliocunhadev",
    tint: "purple",
    icon: "mastodon",
    ariaLabel: "Follow Tulio on Mastodon",
    external: true,
  },
  {
    title: "Book meeting",
    href: "https://fantastical.app/tuliopinheirocunha",
    tint: "orange",
    asset: "/icons/Socials/calendar-light.svg",
    ariaLabel: "Book a meeting with Tulio",
    external: true,
  },
];
---

<section class="profileCard" aria-label={`Profile information for ${name}`} data-reveal>
  <div class="profileCard__hero">
    <article
      class="profileCard__identity hover-elevate motion-surface-premium"
      data-reveal
      data-reveal-order="0"
      data-parallax-card
    >
      <figure class="profileCard__photo">
        <img src={profilePhotoSrc} alt={name} width={192} height={192} loading="eager" decoding="async" />
      </figure>

      <div class="profileCard__copy">
        <p class="profileCard__eyebrow">Hello</p>
        <h2 class="profileCard__name">{name}</h2>
        <p class="profileCard__title">{title}</p>
        <p class="profileCard__summary">
          . Command Line Junkie . Mac Head . Unix Enthusiast . Tool Addict..
        </p>
      </div>

      <div class="profileCard__contactList" role="navigation" aria-label="Primary contact methods">
        {
          contactCards.map((card) => (
            <a
              class="profileCard__contact motion-chip"
              data-tint={card.tint}
              data-parallax-card
              href={card.href}
              target={card.external ? "_blank" : undefined}
              rel={card.external ? "noreferrer noopener" : undefined}
              aria-label={card.ariaLabel}
            >
              <IconTile
                tint={card.tint}
                label={card.label}
                asset={card.asset}
              />
              <span class="profileCard__contactCopy">
                <strong>{card.label}</strong>
                <span>{card.value}</span>
              </span>
            </a>
          ))
        }
      </div>
    </article>

    <article
      class="profileCard__social hover-elevate motion-surface-premium"
      data-reveal
      data-reveal-order="1"
      data-parallax-card
    >
      <header class="profileCard__socialHeader">
        <p class="profileCard__eyebrow">
          <PhosphorIcon name="share" size={14} weight="regular" />
          <span>Connect</span>
        </p>
        <h3>
          <span>Socials</span>
          <PhosphorIcon name="users-three" size={18} weight="regular" />
        </h3>
        <p>Direct channels for consulting and collaboration.</p>
      </header>
      <div class="profileCard__socialGrid" role="list" aria-label="Social channels">
        {
          socialCards.map((card) => (
            <a
              class="profileCard__socialCard hover-elevate motion-surface-standard"
              data-tint={card.tint}
              data-parallax-card
              href={card.href}
              target={card.external ? "_blank" : undefined}
              rel={card.external ? "noreferrer noopener" : undefined}
              aria-label={card.ariaLabel}
              role="listitem"
            >
              <IconTile
                tint={card.tint}
                label={card.title}
                icon={card.icon ?? null}
                asset={card.asset ?? null}
                context="dock"
              />
              <span>{card.title}</span>
            </a>
          ))
        }
      </div>
    </article>
  </div>
</section>

<style>
  .profileCard {
    --profile-radius: clamp(28px, 3.2vw, 36px);
    position: relative;
    border-radius: var(--profile-radius);
    border: 1px solid var(--panel-border);
    background: color-mix(in srgb, var(--surface-elevated) 96%, transparent);
    box-shadow:
      var(--shadow-card),
      var(--shadow-card-highlight),
      0 0 0 1px rgba(255, 255, 255, 0.05),
      0 20px 56px rgba(44, 74, 132, 0.2);
    backdrop-filter: blur(var(--glass-regular-blur)) saturate(var(--glass-saturation-base));
    -webkit-backdrop-filter: blur(var(--glass-regular-blur)) saturate(var(--glass-saturation-base));
    padding: clamp(18px, 2.2vw, 28px);
    overflow: hidden;
    width: 100%;
    max-width: 100%;
  }

  .profileCard::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), transparent 76%);
    opacity: 0.55;
  }

  .profileCard__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(300px, 0.92fr);
    gap: clamp(18px, 2vw, 28px);
    align-items: stretch;
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .profileCard__identity,
  .profileCard__social {
    --hover-elevate-translate: -6px;
    --hover-elevate-scale: 1.012;
    --hover-shadow:
      var(--shadow-card-hover),
      var(--shadow-card-highlight),
      0 26px 44px rgba(4, 9, 20, 0.42),
      0 0 50px rgba(77, 166, 255, 0.1);
    --hover-border: var(--panel-border-strong);
    border-radius: clamp(22px, 2vw, 28px);
    border: 1px solid var(--panel-border);
    background: color-mix(in srgb, var(--surface-card) 95%, transparent);
    padding: clamp(16px, 1.8vw, 22px);
    box-shadow:
      var(--shadow-card),
      var(--shadow-card-highlight),
      0 18px 36px rgba(6, 10, 22, 0.32);
    min-width: 0;
  }

  .profileCard__identity {
    display: grid;
    grid-template-columns: minmax(156px, 208px) 1fr;
    gap: clamp(12px, 1.4vw, 18px);
    align-items: start;
  }

  .profileCard__photo {
    margin: 0;
    width: min(100%, 196px);
    aspect-ratio: 1 / 1;
    border-radius: 28px;
    overflow: hidden;
    border: 1px solid var(--panel-border);
    box-shadow: var(--shadow-card);
  }

  .profileCard__photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .profileCard__copy {
    display: grid;
    gap: 8px;
    align-content: start;
  }

  .profileCard__eyebrow {
    margin: 0;
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    font-weight: var(--fw-medium);
    color: var(--text-secondary);
  }

  .profileCard__name {
    margin: 0;
    font-size: clamp(32px, 2vw, 44px);
    letter-spacing: -0.025em;
    line-height: 1.02;
  }

  .profileCard__title {
    margin: 0;
    font-size: var(--fs-title-3);
    color: var(--text-secondary);
  }

  .profileCard__summary {
    margin: 6px 0 0;
    max-width: 48ch;
    color: var(--text-secondary);
    line-height: var(--lh-snug);
    font-size: var(--fs-callout);
    font-weight: var(--fw-medium);
  }

  .profileCard__contactList {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(2, minmax(200px, 1fr));
    gap: 12px;
    margin-top: 4px;
  }

  .profileCard__contact {
    --parallax-rotate-x: 0deg;
    --parallax-rotate-y: 0deg;
    --parallax-translate: 0px;
    position: relative;
    isolation: isolate;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    border-radius: 16px;
    border: 1px solid rgba(108, 168, 255, 0.28);
    background: var(--surface-translucent-2);
    background: color-mix(in srgb, var(--surface-translucent-2) 96%, rgba(70, 124, 220, 0.06));
    padding: 8px 12px;
    text-decoration: none;
    color: var(--text-primary);
    min-height: 44px;
    min-width: 0;
    box-shadow: inset 0 0 0 1px rgba(120, 180, 255, 0.1);
    backdrop-filter: blur(var(--glass-regular-blur)) saturate(150%);
    -webkit-backdrop-filter: blur(var(--glass-regular-blur)) saturate(150%);
    transform:
      perspective(900px)
      rotateX(var(--parallax-rotate-x))
      rotateY(var(--parallax-rotate-y))
      translateY(var(--parallax-translate));
    transition:
      transform var(--motion-duration-spring-xs) var(--spring-responsive),
      border-color var(--motion-duration-sm) var(--motion-ease-out),
      background-color var(--motion-duration-sm) var(--motion-ease-out);
  }

  .profileCard__contact::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      circle at 24% 28%,
      rgba(10, 132, 255, 0.26) 0%,
      rgba(10, 132, 255, 0.12) 42%,
      rgba(10, 132, 255, 0) 76%
    );
    opacity: 0;
    transition: opacity var(--motion-duration-sm) var(--motion-ease-out);
    z-index: -1;
  }

  .profileCard__contact:hover,
  .profileCard__contact:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(128, 184, 255, 0.4);
    background: color-mix(in srgb, var(--blue) 16%, var(--surface-translucent-2));
    box-shadow:
      0 6px 16px rgba(10, 132, 255, 0.24),
      inset 0 0 0 1px rgba(120, 180, 255, 0.18);
  }

  .profileCard__contact:hover::after,
  .profileCard__contact:focus-visible::after {
    opacity: 1;
  }

  .profileCard__contact:focus-visible {
    box-shadow: var(--focus-ring);
  }

  .profileCard__contactCopy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1.15;
  }

  .profileCard__contact :global(.symbol) {
    width: 36px;
    height: 36px;
    border-radius: 11px;
  }

  .profileCard__contactCopy strong {
    font-size: var(--fs-footnote);
    font-weight: var(--fw-semibold);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .profileCard__contactCopy span {
    font-size: 10px;
    color: var(--text-tertiary);
    letter-spacing: 0.02em;
    line-height: 1.3;
    font-weight: var(--fw-regular);
    opacity: 0.8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .profileCard__social {
    display: grid;
    gap: clamp(14px, 1.5vw, 18px);
    align-content: start;
  }

  .profileCard__socialHeader {
    display: grid;
    gap: 6px;
  }

  .profileCard__socialHeader .profileCard__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .profileCard__socialHeader h3 {
    margin: 0;
    font-size: clamp(26px, 1.4vw, 34px);
    letter-spacing: -0.025em;
    line-height: 1.05;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .profileCard__socialHeader p {
    margin: 0;
    color: var(--text-tertiary);
    font-size: var(--fs-subheadline);
    max-width: 30ch;
  }

  .profileCard__socialGrid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .profileCard__socialCard {
    --tile-accent-base: rgba(255, 255, 255, 0.08);
    --tile-accent-hover: rgba(255, 255, 255, 0.16);
    --tile-glow-rgb: 10, 132, 255;
    --tile-hover-shadow: var(--shadow-card-hover), var(--shadow-card-highlight), var(--shadow-card-glow);
    --parallax-rotate-x: 0deg;
    --parallax-rotate-y: 0deg;
    --parallax-translate: 0px;
    position: relative;
    overflow: hidden;
    border-radius: 20px;
    border: 1px solid color-mix(in srgb, var(--panel-border) 68%, transparent);
    background: color-mix(in srgb, var(--surface-card) 96%, transparent);
    text-decoration: none;
    color: var(--text-primary);
    padding: 14px 12px 12px;
    min-height: 96px;
    box-shadow:
      var(--shadow-card),
      var(--shadow-card-highlight),
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 0 48px rgba(var(--tile-glow-rgb), 0.09);
    transform:
      perspective(900px)
      rotateX(var(--parallax-rotate-x))
      rotateY(var(--parallax-rotate-y))
      translateY(var(--parallax-translate));
    display: grid;
    justify-items: center;
    align-content: center;
    text-align: center;
    gap: 10px;
    transition:
      transform var(--motion-duration-sm) var(--motion-ease-out),
      border-color var(--motion-duration-sm) var(--motion-ease-out),
      background var(--motion-duration-sm) var(--motion-ease-out),
      box-shadow var(--motion-duration-sm) var(--motion-ease-out);
  }

  .profileCard__socialCard::before {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    background: radial-gradient(circle at 50% 14%, var(--tile-accent-base), rgba(0, 0, 0, 0) 72%);
    opacity: 0.22;
    pointer-events: none;
    transition: opacity var(--motion-duration-sm) var(--motion-ease-out);
  }

  .profileCard__socialCard span:last-child {
    font-size: var(--fs-caption);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-footnote);
  }

  .profileCard__socialCard:hover {
    transform: translateY(-2px);
    border-color: var(--panel-border-strong);
    background: color-mix(in srgb, var(--surface-card) 98%, transparent);
    box-shadow: var(--tile-hover-shadow);
  }

  .profileCard__socialCard:hover::before {
    opacity: 0.44;
    background: radial-gradient(circle at 50% 14%, var(--tile-accent-hover), rgba(0, 0, 0, 0) 72%);
  }

  .profileCard__socialCard[data-tint="blue"] {
    --tile-glow-rgb: 10, 132, 255;
  }

  .profileCard__socialCard[data-tint="indigo"] {
    --tile-glow-rgb: 94, 92, 232;
  }

  .profileCard__socialCard[data-tint="cyan"] {
    --tile-glow-rgb: 0, 173, 216;
  }

  .profileCard__socialCard[data-tint="green"] {
    --tile-glow-rgb: 66, 184, 131;
  }

  .profileCard__socialCard[data-tint="orange"] {
    --tile-glow-rgb: 255, 120, 60;
  }

  .profileCard__socialCard[data-tint="pink"] {
    --tile-glow-rgb: 255, 56, 97;
  }

  .profileCard__socialCard[data-tint="purple"] {
    --tile-glow-rgb: 194, 91, 244;
  }

  @media (max-width: 1240px) {
    .profileCard__hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .profileCard {
      padding: 16px;
      border-radius: 24px;
    }

    .profileCard__identity {
      grid-template-columns: 1fr;
    }

    .profileCard__photo {
      width: 164px;
    }

    .profileCard__contactList {
      grid-template-columns: 1fr 1fr;
    }

    .profileCard__socialGrid {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .profileCard__socialCard {
      min-height: 88px;
    }
  }

  @media (max-width: 520px) {
    .profileCard__contactList,
    .profileCard__socialGrid {
      grid-template-columns: 1fr 1fr;
    }

    .profileCard__name {
      font-size: clamp(28px, 9vw, 36px);
    }

    .profileCard__socialHeader h3 {
      font-size: clamp(26px, 9vw, 34px);
    }
  }
</style>
