---
import IconTile from "./IconTile.astro";
import PhosphorIcon from "./PhosphorIcon.astro";
import styles from "./ProfileCard.module.css";

const { name = "Tulio Cunha", title = "Full stack developer", location = "Brazil" } = Astro.props;

const encodedLocation = encodeURIComponent(location);
const locationHref = `https://maps.apple.com/?q=${encodedLocation}`;
const profilePhotoSrc = "/profile-photo.webp";

type ContactCard = {
  label: string;
  value: string;
  href: string;
  tint: string;
  ariaLabel: string;
  external: boolean;
  icon?: string;
  asset?: string;
};

type SocialCard = {
  title: string;
  href: string;
  tint: string;
  ariaLabel: string;
  external: boolean;
  icon?: string;
  asset?: string;
};

const contactCards: ContactCard[] = [
  {
    label: "Contact",
    value: "Email and project context",
    href: "/contact",
    tint: "indigo",
    asset: "/icons/Socials/Email.webp",
    ariaLabel: `Open contact form for ${name}`,
    external: false,
  },
  {
    label: "Location",
    value: location,
    href: locationHref,
    tint: "cyan",
    asset: "/icons/Socials/Location.svg",
    ariaLabel: `Open ${name}'s location in Maps`,
    external: true,
  },
];

const socialCards: SocialCard[] = [
  {
    title: "GitHub",
    href: "https://github.com/tuliopc23",
    tint: "indigo",
    icon: "github",
    ariaLabel: "Open Tulio's GitHub",
    external: true,
  },
  {
    title: "Portfolio",
    href: "https://portfolio.tuliocunha.dev",
    tint: "cyan",
    asset: "/icons/Socials/www.webp",
    ariaLabel: "Open Tulio's portfolio",
    external: true,
  },
  {
    title: "LinkedIn",
    href: "https://linkedin.com/in/tuliopinheirocunha",
    tint: "blue",
    icon: "linkedin",
    ariaLabel: "Open Tulio's LinkedIn",
    external: true,
  },
  {
    title: "Instagram",
    href: "https://instagram.com/tuliopinheirocunha",
    tint: "pink",
    icon: "instagram",
    ariaLabel: "Open Tulio's Instagram",
    external: true,
  },
  {
    title: "Mastodon",
    href: "https://mastodon.social/@tuliocunhadev",
    tint: "purple",
    icon: "mastodon",
    ariaLabel: "Open Tulio's Mastodon",
    external: true,
  },
  {
    title: "Schedule time",
    href: "https://fantastical.app/tuliopinheirocunha",
    tint: "orange",
    asset: "/icons/Socials/calendar.webp",
    ariaLabel: "Schedule time with Tulio",
    external: true,
  },
];
---

<section
  class:list={[styles.profileCard, "surface-panel", "surface-panel--premium"]}
  aria-label={`Profile information for ${name}`}
  data-reveal
>
  <div class={styles.profileCardHero}>
    <article
      class:list={[
        styles.profileCardIdentity,
        "surface-panel",
        "surface-panel--nested",
        "hover-elevate",
        "motion-surface-premium",
      ]}
      data-reveal
      data-reveal-order="0"
      data-parallax-card
    >
      <figure class={styles.profileCardPhoto}>
        <img src={profilePhotoSrc} alt={name} width="192" height="192" loading="eager" decoding="async" />
      </figure>

      <div class={styles.profileCardCopy}>
        <p class:list={[styles.profileCardEyebrow, "surface-eyebrow"]}>
          <PhosphorIcon name="terminal-window" size={14} weight="regular" />
          <span>Hello</span>
        </p>
        <h2 class={styles.profileCardName}>{name}</h2>
        <p class={styles.profileCardTitle}>{title}</p>
        <p class={styles.profileCardLead}>
          Swift, Apple platforms, web, backend, and systems work, with a bias for clear interfaces and reliable internals.
        </p>
      </div>

      <div class={styles.profileCardContactList} role="navigation" aria-label="Primary contact methods">
        {
          contactCards.map((card) => (
            <a
              class:list={[styles.profileCardContact, "motion-chip"]}
              data-tint={card.tint}
              data-parallax-card
              href={card.href}
              target={card.external ? "_blank" : undefined}
              rel={card.external ? "noreferrer noopener" : undefined}
              aria-label={card.ariaLabel}
            >
                <IconTile
                  tint={card.tint}
                  asset={card.asset ?? null}
                  loading="eager"
                />
              <span class={styles.profileCardContactCopy}>
                <strong>{card.label}</strong>
                <span>{card.value}</span>
              </span>
            </a>
          ))
        }
      </div>
    </article>

    <article
      class:list={[
        styles.profileCardSocial,
        "surface-panel",
        "surface-panel--nested",
        "hover-elevate",
        "motion-surface-premium",
      ]}
      data-reveal
      data-reveal-order="1"
      data-parallax-card
    >
      <header class:list={[styles.profileCardSocialHeader, "surface-header"]}>
        <p class:list={[styles.profileCardEyebrow, "surface-eyebrow"]}>
          <PhosphorIcon name="share" size={14} weight="regular" />
          <span>Profiles</span>
        </p>
        <h3 class="surface-title">
          <span>Links</span>
          <PhosphorIcon name="users-three" size={18} weight="regular" />
        </h3>
        <p class="surface-caption">Public profiles, portfolio links, and a direct way to reach me.</p>
      </header>
      <ul class={styles.profileCardSocialGrid} aria-label="Social channels">
        {
          socialCards.map((card) => (
            <li>
              <a
                class:list={[
                  styles.profileCardSocialCard,
                  "surface-tile",
                  "surface-tile--centered",
                  "surface-tile--premium",
                  "hover-elevate",
                  "motion-surface-standard",
                ]}
                data-tint={card.tint}
                data-parallax-card
                href={card.href}
                target={card.external ? "_blank" : undefined}
                rel={card.external ? "noreferrer noopener" : undefined}
                aria-label={card.ariaLabel}
              >
                <IconTile
                  tint={card.tint}
                  label={card.title}
                  icon={card.icon ?? null}
                  asset={card.asset ?? null}
                  context="dock"
                  loading="eager"
                />
                <span>{card.title}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </article>
  </div>
</section>
