---
import { Image } from "astro:assets";
import IconTile from "./IconTile.astro";
import AvatarSrc from "../assets/avatar.png";

const {
  name = "Tulio Cunha",
  title = "Full Stack Developer",
  location = "Brazil",
  email = "contact@tuliocunha.dev",
} = Astro.props;

const encodedLocation = encodeURIComponent(location);
const locationHref = `https://maps.apple.com/?q=${encodedLocation}`;

const contactCards = [
  {
    label: "Email",
    value: "Tap to write",
    href: `mailto:${email}`,
    tint: "indigo",
    asset: "/icons/Socials/Email.webp",
    ariaLabel: `Email ${name}`,
    external: false,
  },
  {
    label: "Location",
    value: location,
    href: locationHref,
    tint: "cyan",
    asset: "/icons/Socials/Location.svg",
    ariaLabel: `Open ${name}'s location in Maps`,
    external: true,
  },
];

const socialCards = [
  {
    title: "GitHub",
    href: "https://github.com/tuliopc23",
    tint: "indigo",
    icon: "github",
    ariaLabel: "Explore Tulio projects on GitHub",
    external: true,
  },
  {
    title: "My Portfolio",
    href: "https://portfolio.tuliocunha.dev",
    tint: "cyan",
    icon: "profile-portfolio",
    ariaLabel: "Explore Tulio portfolio work",
    external: true,
  },
  {
    title: "LinkedIn",
    href: "https://linkedin.com/in/tuliopinheirocunha",
    tint: "blue",
    asset: "/icons/Socials/linkedin-light.svg",
    ariaLabel: "Connect with Tulio on LinkedIn",
    external: true,
  },
  {
    title: "Instagram",
    href: "https://instagram.com/tuliopinheirocunha",
    tint: "pink",
    asset: "/icons/Socials/instagram-light.svg",
    ariaLabel: "Follow Tulio on Instagram",
    external: true,
  },
  {
    title: "Mastodon",
    href: "https://mastodon.social/@tuliocunhadev",
    tint: "purple",
    icon: "mastodon",
    ariaLabel: "Follow Tulio on Mastodon",
    external: true,
  },
  {
    title: "Book meeting",
    href: "https://fantastical.app/tuliopinheirocunha",
    tint: "orange",
    asset: "/icons/Socials/calendar-light.svg",
    ariaLabel: "Book a meeting with Tulio",
    external: true,
  },
];
---

<section class="profileCard" aria-label={`Profile information for ${name}`} data-reveal>
  <div class="profileCard__hero">
    <article class="profileCard__identity" data-reveal data-reveal-order="0">
      <figure class="profileCard__photo">
        <Image
          src={AvatarSrc}
          alt={name}
          width={160}
          height={160}
          loading="eager"
          decoding="async"
        />
      </figure>

      <div class="profileCard__copy">
        <p class="profileCard__eyebrow">Hello</p>
        <h2 class="profileCard__name">{name}</h2>
        <p class="profileCard__title">{title}</p>
        <p class="profileCard__summary">
          Full stack engineer for high-quality native and web products with Apple-inspired
          detail and delivery discipline.
        </p>
      </div>

      <div class="profileCard__contactList" role="navigation" aria-label="Primary contact methods">
        {
          contactCards.map((card) => (
            <a
              class="profileCard__contact"
              data-parallax-card
              href={card.href}
              target={card.external ? "_blank" : undefined}
              rel={card.external ? "noreferrer noopener" : undefined}
              aria-label={card.ariaLabel}
            >
              <IconTile tint={card.tint} label={card.label} asset={card.asset} />
              <span class="profileCard__contactCopy">
                <strong>{card.label}</strong>
                <span>{card.value}</span>
              </span>
            </a>
          ))
        }
      </div>
    </article>

    <article class="profileCard__social" data-reveal data-reveal-order="1">
      <header class="profileCard__socialHeader">
        <p class="profileCard__eyebrow">Connect</p>
        <h3>Socials</h3>
        <p>Direct channels for consulting and collaboration.</p>
      </header>
      <div class="profileCard__socialGrid" role="list" aria-label="Social channels">
        {
          socialCards.map((card) => (
            <a
              class="profileCard__socialCard"
              data-parallax-card
              href={card.href}
              target={card.external ? "_blank" : undefined}
              rel={card.external ? "noreferrer noopener" : undefined}
              aria-label={card.ariaLabel}
              role="listitem"
            >
              <IconTile
                tint={card.tint}
                label={card.title}
                icon={card.icon ?? null}
                asset={card.asset ?? null}
              />
              <span>{card.title}</span>
            </a>
          ))
        }
      </div>
    </article>
  </div>
</section>

<style>
  .profileCard {
    --profile-radius: clamp(28px, 3.2vw, 36px);
    position: relative;
    border-radius: var(--profile-radius);
    border: 1px solid var(--panel-border);
    background: color-mix(in srgb, var(--surface-elevated) 96%, transparent);
    box-shadow:
      var(--shadow-card),
      var(--shadow-card-highlight),
      0 0 0 1px rgba(255, 255, 255, 0.05),
      0 20px 56px rgba(44, 74, 132, 0.2);
    backdrop-filter: blur(var(--glass-regular-blur)) saturate(var(--glass-saturation-base));
    -webkit-backdrop-filter: blur(var(--glass-regular-blur)) saturate(var(--glass-saturation-base));
    padding: clamp(22px, 2.8vw, 34px);
    overflow: hidden;
    width: 100%;
    max-width: 100%;
  }

  .profileCard::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), transparent 76%);
    opacity: 0.55;
  }

  .profileCard__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    gap: clamp(18px, 2vw, 28px);
    align-items: stretch;
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .profileCard__identity,
  .profileCard__social {
    border-radius: clamp(22px, 2vw, 28px);
    border: 1px solid var(--panel-border);
    background: color-mix(in srgb, var(--surface-card) 95%, transparent);
    padding: clamp(18px, 2.2vw, 28px);
    box-shadow: var(--shadow-card), var(--shadow-card-highlight);
    min-width: 0;
  }

  .profileCard__identity {
    display: grid;
    grid-template-columns: minmax(108px, 140px) 1fr;
    gap: clamp(14px, 2vw, 24px);
    align-items: start;
  }

  .profileCard__photo {
    margin: 0;
    width: min(100%, 140px);
    aspect-ratio: 1 / 1;
    border-radius: 26px;
    overflow: hidden;
    border: 1px solid var(--panel-border);
    box-shadow: var(--shadow-card);
  }

  .profileCard__photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .profileCard__copy {
    display: grid;
    gap: 8px;
    align-content: start;
  }

  .profileCard__eyebrow {
    margin: 0;
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    font-weight: var(--fw-medium);
    color: var(--text-secondary);
  }

  .profileCard__name {
    margin: 0;
    font-size: clamp(34px, 2.4vw, 52px);
    letter-spacing: -0.025em;
    line-height: 1.02;
  }

  .profileCard__title {
    margin: 0;
    font-size: var(--fs-title-3);
    color: var(--text-secondary);
  }

  .profileCard__summary {
    margin: 6px 0 0;
    max-width: 48ch;
    color: var(--text-secondary);
    line-height: var(--lh-snug);
    font-size: var(--fs-callout);
  }

  .profileCard__contactList {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(2, minmax(220px, 1fr));
    gap: 12px;
    margin-top: 4px;
  }

  .profileCard__contact {
    --parallax-rotate-x: 0deg;
    --parallax-rotate-y: 0deg;
    --parallax-translate: 0px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    border-radius: 16px;
    border: 1px solid var(--panel-border);
    background:
      linear-gradient(
        140deg,
        color-mix(in srgb, var(--blue) 16%, var(--surface-muted)) 0%,
        var(--surface-muted) 62%
      ),
      var(--surface-muted);
    padding: 10px 12px;
    text-decoration: none;
    color: var(--text-primary);
    min-width: 0;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.24),
      0 8px 20px rgba(14, 28, 60, 0.22);
    transform:
      perspective(900px)
      rotateX(var(--parallax-rotate-x))
      rotateY(var(--parallax-rotate-y))
      translateY(var(--parallax-translate));
    transition:
      border-color var(--motion-duration-sm) var(--motion-ease-out),
      background var(--motion-duration-sm) var(--motion-ease-out),
      transform var(--motion-duration-sm) var(--motion-ease-out),
      box-shadow var(--motion-duration-sm) var(--motion-ease-out);
  }

  .profileCard__contact:hover {
    border-color: var(--panel-border-strong);
    background:
      linear-gradient(
        140deg,
        color-mix(in srgb, var(--blue) 24%, var(--surface-card-hover)) 0%,
        var(--surface-card-hover) 62%
      ),
      var(--surface-card-hover);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.3),
      0 12px 28px rgba(14, 28, 60, 0.3);
    transform: translateY(-2px);
  }

  .profileCard__contactCopy {
    min-width: 0;
    display: grid;
    line-height: 1.15;
    gap: 4px;
  }

  .profileCard__contactCopy strong {
    font-size: var(--fs-footnote);
    font-weight: var(--fw-semibold);
  }

  .profileCard__contactCopy span {
    font-size: var(--fs-caption);
    color: var(--text-tertiary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .profileCard__social {
    display: grid;
    gap: clamp(14px, 1.5vw, 18px);
    align-content: start;
  }

  .profileCard__socialHeader {
    display: grid;
    gap: 6px;
  }

  .profileCard__socialHeader h3 {
    margin: 0;
    font-size: clamp(34px, 2.1vw, 44px);
    letter-spacing: -0.025em;
    line-height: 1.05;
  }

  .profileCard__socialHeader p {
    margin: 0;
    color: var(--text-tertiary);
    font-size: var(--fs-subheadline);
  }

  .profileCard__socialGrid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .profileCard__socialCard {
    --parallax-rotate-x: 0deg;
    --parallax-rotate-y: 0deg;
    --parallax-translate: 0px;
    border-radius: 16px;
    border: 1px solid var(--panel-border);
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--surface-muted) 92%, rgba(255, 255, 255, 0.06)) 0%,
        var(--surface-muted) 70%
      ),
      var(--surface-muted);
    text-decoration: none;
    color: var(--text-primary);
    padding: 14px;
    min-height: 118px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 8px 22px rgba(14, 28, 60, 0.2);
    transform:
      perspective(900px)
      rotateX(var(--parallax-rotate-x))
      rotateY(var(--parallax-rotate-y))
      translateY(var(--parallax-translate));
    display: grid;
    justify-items: start;
    align-content: space-between;
    gap: 8px;
    transition:
      transform var(--motion-duration-sm) var(--motion-ease-out),
      border-color var(--motion-duration-sm) var(--motion-ease-out),
      background var(--motion-duration-sm) var(--motion-ease-out),
      box-shadow var(--motion-duration-sm) var(--motion-ease-out);
  }

  .profileCard__socialCard span:last-child {
    font-size: var(--fs-footnote);
    font-weight: var(--fw-semibold);
  }

  .profileCard__socialCard:hover {
    transform: translateY(-2px);
    border-color: var(--panel-border-strong);
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--surface-card-hover) 90%, rgba(255, 255, 255, 0.12)) 0%,
        var(--surface-card-hover) 70%
      ),
      var(--surface-card-hover);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.24),
      0 14px 30px rgba(14, 28, 60, 0.28);
  }

  @media (max-width: 1240px) {
    .profileCard__hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .profileCard {
      padding: 18px;
      border-radius: 24px;
    }

    .profileCard__identity {
      grid-template-columns: 1fr;
    }

    .profileCard__photo {
      width: 128px;
    }

    .profileCard__contactList {
      grid-template-columns: 1fr 1fr;
    }

    .profileCard__socialGrid {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .profileCard__socialCard {
      min-height: 112px;
    }
  }

  @media (max-width: 520px) {
    .profileCard__contactList,
    .profileCard__socialGrid {
      grid-template-columns: 1fr 1fr;
    }

    .profileCard__name {
      font-size: clamp(30px, 10vw, 42px);
    }

    .profileCard__socialHeader h3 {
      font-size: clamp(30px, 10vw, 40px);
    }
  }
</style>
