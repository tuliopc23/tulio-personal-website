---
import PhosphorIcon from "./PhosphorIcon.astro";
import styles from "./Breadcrumbs.module.css";

interface BreadcrumbItem {
  label: string;
  href?: string;
  icon?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props as Props;
---

<nav class={styles.breadcrumbs} aria-label="Breadcrumb navigation">
  <ol class={styles.list}>
    {
      items.map((item, index) => (
        <li class={styles.item}>
          {index > 0 && (
            <PhosphorIcon
              name="chevron-right"
              size={14}
              weight="regular"
              class={styles.separator}
            />
          )}
          {item.href ? (
            <a href={item.href} class={styles.link}>
              {item.icon && (
                <span class={styles.icon} aria-hidden="true">
                  <PhosphorIcon name={item.icon} size={16} weight="regular" />
                </span>
              )}
              <span>{item.label}</span>
            </a>
          ) : (
            <span class={styles.current} aria-current="page">
              {item.icon && (
                <span class={styles.icon} aria-hidden="true">
                  <PhosphorIcon name={item.icon} size={16} weight="regular" />
                </span>
              )}
              <span>{item.label}</span>
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
