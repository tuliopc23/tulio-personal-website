---
import PhosphorIcon from "./PhosphorIcon.astro";
import styles from "./FeatureWritingWidget.module.css";

interface PostItem {
  title: string;
  summary: string;
  href: string;
  dateLabel?: string;
  readingTimeMinutes?: number;
}

const { posts = [] } = Astro.props as { posts: PostItem[] };
---

<div class={styles.featureWritingWidget} role="list" aria-label="Featured writing articles">
  {posts.length > 0 ? (
    posts.slice(0, 3).map((post) => (
      <article
        class:list={[
          styles.card,
          "surface-panel",
          "surface-panel--nested",
          "hover-elevate",
          "motion-surface-standard",
        ]}
        role="listitem"
        data-parallax-card
      >
        <p class={styles.eyebrow}>
          <PhosphorIcon name="article" size={12} weight="regular" />
          <span>Recent post</span>
        </p>
        <h3 class={styles.title}>{post.title}</h3>
        <p class={styles.summary}>{post.summary}</p>
        <div class={styles.meta}>
          {post.dateLabel && (
            <span class="chip-pill">
              <PhosphorIcon name="calendar" size={13} weight="regular" />
              {post.dateLabel}
            </span>
          )}
          {typeof post.readingTimeMinutes === "number" && (
            <span class="chip-pill">
              <PhosphorIcon name="clock" size={13} weight="regular" />
              {post.readingTimeMinutes} min read
            </span>
          )}
        </div>
        <a class:list={[styles.cta, "cta-pill", "cta-pill--accent", "motion-cta-pill"]} href={post.href}>
          <span>Read post</span>
          <PhosphorIcon name="arrow-up-right" size={14} weight="regular" />
        </a>
      </article>
    ))
  ) : (
    <p class={styles.empty}>New notes are in draft.</p>
  )}
</div>
