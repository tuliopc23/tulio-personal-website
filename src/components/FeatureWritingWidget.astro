---
import ArticleCard from "./ArticleCard.astro";
import ScrollHint from "./ScrollHint.astro";
import styles from "./FeatureWritingWidget.module.css";
import type { Category, SanityImageWithMetadata } from "../sanity/lib/posts";

interface PostItem {
  title: string;
  summary: string;
  href: string;
  dateLabel?: string;
  dateISO?: string;
  readingTimeMinutes?: number;
  tags?: string[];
  categories?: Category[] | null;
  heroImage?: SanityImageWithMetadata | null;
  coverVariant?: "default" | "cinematic" | "minimal" | null;
  isNew?: boolean;
}

const { posts = [] } = Astro.props as { posts: PostItem[] };
---

<div class={styles.carouselWrap} data-at-start="true" data-at-end="false">
  <ScrollHint target={`.${styles.featureWritingWidget}`} variant="mobile" />
  <ul class={styles.featureWritingWidget} aria-label="Featured writing articles">
    {posts.length > 0 ? (
      posts.slice(0, 3).map((post) => (
        <li class={styles.card}>
          <ArticleCard
            href={post.href}
            title={post.title}
            summary={post.summary}
            dateISO={post.dateISO ?? new Date().toISOString()}
            dateLabel={post.dateLabel ?? "Recent post"}
            ctaLabel="Read post"
            tags={post.tags ?? []}
            categories={post.categories}
            readingTimeMinutes={post.readingTimeMinutes}
            isNew={post.isNew ?? false}
            heroImage={post.heroImage}
            coverVariant={post.coverVariant}
            editorialLayout="featured-editorial"
            editorialSize="standard"
            revealGroup="home-writing"
          />
        </li>
      ))
    ) : (
      <li class={styles.empty}>New notes are in draft.</li>
    )}
  </ul>
</div>

<script is:inline define:vars={{ wrapClass: styles.carouselWrap, listClass: styles.featureWritingWidget }}>
  function initCarouselEdges() {
    const wraps = document.querySelectorAll(`.${wrapClass}`);
    wraps.forEach((wrap) => {
      const list = wrap.querySelector(`.${listClass}`);
      if (!list) return;

      if (typeof list.__featureWritingCleanup === "function") {
        list.__featureWritingCleanup();
      }

      const update = () => {
        const atStart = list.scrollLeft <= 2;
        const atEnd = list.scrollLeft + list.clientWidth >= list.scrollWidth - 2;
        wrap.setAttribute("data-at-start", String(atStart));
        wrap.setAttribute("data-at-end", String(atEnd));
      };

      list.addEventListener("scroll", update, { passive: true });
      list.__featureWritingCleanup = () => {
        list.removeEventListener("scroll", update);
      };
      update();
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCarouselEdges, { once: true });
  } else {
    initCarouselEdges();
  }
  document.addEventListener("astro:page-load", initCarouselEdges);
  document.addEventListener(
    "astro:before-swap",
    () => {
      document.querySelectorAll(`.${listClass}`).forEach((list) => {
        if (typeof list.__featureWritingCleanup === "function") {
          list.__featureWritingCleanup();
          delete list.__featureWritingCleanup;
        }
      });
    },
    { once: true },
  );
</script>
