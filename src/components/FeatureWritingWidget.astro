---
import PhosphorIcon from "./PhosphorIcon.astro";

interface PostItem {
  title: string;
  summary: string;
  href: string;
  dateLabel?: string;
  readingTimeMinutes?: number;
}

const { posts = [] } = Astro.props as { posts: PostItem[] };
---

<div class="feature-writing-widget" role="list" aria-label="Featured writing articles">
  {posts.length > 0 ? (
    posts.slice(0, 3).map((post) => (
      <article class="feature-writing-widget__card hover-elevate" role="listitem" data-parallax-card>
        <p class="feature-writing-widget__eyebrow">
          <PhosphorIcon name="article" size={12} weight="regular" />
          <span>Article</span>
        </p>
        <h3 class="feature-writing-widget__title">{post.title}</h3>
        <p class="feature-writing-widget__summary">{post.summary}</p>
        <div class="feature-writing-widget__meta">
          {post.dateLabel && (
            <span>
              <PhosphorIcon name="calendar" size={13} weight="regular" />
              {post.dateLabel}
            </span>
          )}
          {typeof post.readingTimeMinutes === "number" && (
            <span>
              <PhosphorIcon name="clock" size={13} weight="regular" />
              {post.readingTimeMinutes} min read
            </span>
          )}
        </div>
        <a class="feature-writing-widget__cta" href={post.href}>
          <span>Read</span>
          <PhosphorIcon name="arrow-up-right" size={14} weight="regular" />
        </a>
      </article>
    ))
  ) : (
    <p class="feature-writing-widget__empty">New long-form entries are being prepared.</p>
  )}
</div>

<style>
  .feature-writing-widget {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 1fr;
    gap: 14px;
    align-items: stretch;
  }

  .feature-writing-widget__card {
    --parallax-rotate-x: 0deg;
    --parallax-rotate-y: 0deg;
    --parallax-translate: 0px;
    --hover-elevate-translate: -4px;
    --hover-elevate-scale: 1.01;
    --hover-shadow: var(--shadow-card-hover), var(--shadow-card-highlight);
    --hover-border: var(--panel-border-strong);
    display: grid;
    grid-template-rows: auto auto 1fr auto auto;
    gap: 10px;
    padding: clamp(18px, 1.7vw, 24px);
    border-radius: clamp(22px, 2vw, 28px);
    border: 1px solid var(--panel-border);
    background: color-mix(in srgb, var(--surface-card) 95%, transparent);
    box-shadow: var(--shadow-card), var(--shadow-card-highlight);
    min-height: clamp(290px, 30vw, 380px);
    overflow: hidden;
    transform-style: preserve-3d;
    transform:
      perspective(1100px)
      rotateX(var(--parallax-rotate-x))
      rotateY(var(--parallax-rotate-y))
      translateY(var(--parallax-translate));
    touch-action: pan-y;
  }

  .feature-writing-widget__card[data-parallax-card].is-tilting {
    will-change: transform;
  }

  .feature-writing-widget__eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--fs-caption);
    color: var(--text-tertiary);
    font-weight: var(--fw-medium);
  }

  .feature-writing-widget__title {
    margin: 0;
    font-size: clamp(26px, 1.8vw, 42px);
    letter-spacing: -0.02em;
    font-weight: 700;
    line-height: 1.06;
    text-wrap: balance;
  }

  .feature-writing-widget__summary {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--fs-callout);
    line-height: var(--lh-snug);
    max-width: 36ch;
  }

  .feature-writing-widget__meta {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 8px;
    font-size: var(--fs-caption);
    color: var(--text-tertiary);
  }

  .feature-writing-widget__meta span {
    gap: 6px;
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    border: 1px solid var(--panel-border);
    background: var(--surface-muted);
    padding: 4px 10px;
    white-space: nowrap;
    min-height: 32px;
    color: var(--text-secondary);
  }

  .feature-writing-widget__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    text-decoration: none;
    font-size: var(--fs-footnote);
    font-weight: var(--fw-semibold);
    color: var(--text-primary);
    border: 1px solid color-mix(in srgb, var(--blue) 42%, var(--panel-border));
    border-radius: 999px;
    padding: 8px 14px;
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--blue) 24%, var(--surface-translucent-1)) 0%,
        var(--surface-translucent-1) 72%
      ),
      var(--surface-translucent-1);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.24),
      0 8px 18px rgba(10, 132, 255, 0.3);
    transition:
      border-color var(--motion-duration-sm) var(--motion-ease-out),
      background var(--motion-duration-sm) var(--motion-ease-out),
      transform var(--motion-duration-sm) var(--motion-ease-out),
      box-shadow var(--motion-duration-sm) var(--motion-ease-out);
  }

  .feature-writing-widget__cta:hover {
    border-color: var(--panel-border-strong);
    background:
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--blue) 34%, var(--surface-card-hover)) 0%,
        var(--surface-card-hover) 72%
      ),
      var(--surface-card-hover);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.3),
      0 12px 26px rgba(10, 132, 255, 0.36);
    transform: translateY(-1px);
  }

  .feature-writing-widget__empty {
    margin: 0;
    color: var(--text-tertiary);
  }

  @media (max-width: 1180px) {
    .feature-writing-widget {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .feature-writing-widget {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }

    .feature-writing-widget__card {
      min-height: clamp(250px, 48vw, 340px);
    }
  }
</style>
