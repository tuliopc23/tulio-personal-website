---
import PhosphorIcon from "./PhosphorIcon.astro";

interface PostItem {
  title: string;
  summary: string;
  href: string;
  dateLabel?: string;
  readingTimeMinutes?: number;
}

const { posts = [] } = Astro.props as { posts: PostItem[] };
---

<div class="feature-writing-widget" role="list" aria-label="Featured writing articles">
  {posts.length > 0 ? (
    posts.slice(0, 3).map((post) => (
      <article class="feature-writing-widget__card hover-elevate motion-surface-standard" role="listitem" data-parallax-card>
        <p class="feature-writing-widget__eyebrow">
          <PhosphorIcon name="article" size={12} weight="regular" />
          <span>Latest note</span>
        </p>
        <h3 class="feature-writing-widget__title">{post.title}</h3>
        <p class="feature-writing-widget__summary">{post.summary}</p>
        <div class="feature-writing-widget__meta">
          {post.dateLabel && (
            <span>
              <PhosphorIcon name="calendar" size={13} weight="regular" />
              {post.dateLabel}
            </span>
          )}
          {typeof post.readingTimeMinutes === "number" && (
            <span>
              <PhosphorIcon name="clock" size={13} weight="regular" />
              {post.readingTimeMinutes} min read
            </span>
          )}
        </div>
        <a class="feature-writing-widget__cta motion-cta-pill" href={post.href}>
          <span>Open note</span>
          <PhosphorIcon name="arrow-up-right" size={14} weight="regular" />
        </a>
      </article>
    ))
  ) : (
    <p class="feature-writing-widget__empty">Fresh long-form notes are being edited and prepared.</p>
  )}
</div>

<style>
  .feature-writing-widget {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 1fr;
    gap: 10px;
    align-items: stretch;
  }

  .feature-writing-widget__card {
    --parallax-rotate-x: 0deg;
    --parallax-rotate-y: 0deg;
    --parallax-translate: 0px;
    --hover-elevate-translate: -4px;
    --hover-elevate-scale: 1.01;
    --hover-shadow: var(--shadow-card-hover), var(--shadow-card-highlight);
    --hover-border: var(--panel-border-strong);
    display: grid;
    grid-template-rows: auto auto 1fr auto auto;
    gap: 6px;
    padding: clamp(12px, 1.2vw, 16px);
    border-radius: clamp(18px, 1.4vw, 22px);
    border: 1px solid var(--panel-border);
    background: color-mix(in srgb, var(--surface-card) 95%, transparent);
    box-shadow: var(--shadow-card), var(--shadow-card-highlight);
    min-height: clamp(198px, 20vw, 250px);
    overflow: hidden;
    transform-style: preserve-3d;
    transform:
      perspective(1100px)
      rotateX(var(--parallax-rotate-x))
      rotateY(var(--parallax-rotate-y))
      translateY(calc((var(--reveal-translate, 0px)) + var(--hover-translate, 0px) + var(--parallax-translate)))
      scale(var(--hover-scale, 1));
    touch-action: pan-y;
  }

  .feature-writing-widget__card[data-parallax-card].is-tilting {
    will-change: transform;
  }

  .feature-writing-widget__eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--fs-caption);
    color: var(--text-tertiary);
    font-weight: var(--fw-medium);
  }

  .feature-writing-widget__title {
    margin: 0;
    font-size: clamp(20px, 0.8vw + 16px, 25px);
    letter-spacing: -0.02em;
    font-weight: 800;
    line-height: 1.06;
    text-wrap: balance;
  }

  .feature-writing-widget__summary {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--fs-callout);
    line-height: var(--lh-snug);
    max-width: 34ch;
  }

  .feature-writing-widget__meta {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 6px;
    font-size: var(--fs-caption);
    color: var(--text-tertiary);
  }

  .feature-writing-widget__meta span {
    gap: 6px;
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    border: 1px solid var(--panel-border);
    background: var(--surface-muted);
    padding: 3px 9px;
    white-space: nowrap;
    min-height: 28px;
    color: var(--text-secondary);
  }

  .feature-writing-widget__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    text-decoration: none;
    font-size: var(--fs-footnote);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-footnote);
    color: var(--text-strong-on-primary, #fefefe);
    border: 1px solid color-mix(in srgb, var(--blue) 46%, transparent);
    border-radius: 999px;
    padding: 10px 14px;
    min-width: 44px;
    min-height: 44px;
    background: color-mix(in srgb, var(--blue) 26%, var(--surface-card) 74%);
    box-shadow:
      0 6px 16px rgba(10, 132, 255, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.24);
    transition:
      border-color var(--motion-duration-sm) var(--motion-ease-out),
      background var(--motion-duration-sm) var(--motion-ease-out),
      transform var(--motion-duration-sm) var(--motion-ease-out),
      box-shadow var(--motion-duration-sm) var(--motion-ease-out),
      color var(--motion-duration-sm) var(--motion-ease-out);
  }

  .feature-writing-widget__cta:hover {
    border-color: color-mix(in srgb, var(--blue) 46%, transparent);
    background: color-mix(in srgb, var(--blue) 26%, var(--surface-card) 74%);
    box-shadow:
      0 10px 24px rgba(10, 132, 255, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.28);
    transform: translateY(-1px);
  }

  .feature-writing-widget__empty {
    margin: 0;
    color: var(--text-tertiary);
  }

  @media (max-width: 1180px) {
    .feature-writing-widget {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .feature-writing-widget {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }

    .feature-writing-widget__card {
      min-height: clamp(188px, 40vw, 230px);
    }
  }
</style>
