---
import { Image } from "astro:assets";
import PhosphorIcon from "./PhosphorIcon.astro";
import CategoryBadges from "./CategoryBadges.astro";
import type { Category, SanityImageWithMetadata } from "../sanity/lib/posts";

interface Props {
  href: string;
  title: string;
  summary: string;
  hook?: string | null;
  dateISO: string;
  dateLabel: string;
  ctaLabel?: string;
  tags?: string[];
  categories?: Category[] | null;
  featured?: boolean;
  revealGroup?: string;
  revealOrder?: number | string;
  revealDelay?: string;
  readingTimeMinutes?: number;
  isNew?: boolean;
  heroImage?: SanityImageWithMetadata | null;
  coverVariant?: "default" | "cinematic" | "minimal" | null;
  imagePriority?: boolean;
  editorialLayout?: "default" | "featured-editorial";
  editorialSize?: "hero" | "standard";
  context?: "default" | "reader-related";
}

const {
  href,
  title,
  summary,
  hook = null,
  dateISO,
  dateLabel,
  tags = [],
  categories = [],
  featured = false,
  ctaLabel = "Read post",
  revealGroup = "articles",
  revealOrder,
  revealDelay,
  readingTimeMinutes,
  isNew = false,
  heroImage = null,
  coverVariant = "default",
  imagePriority = false,
  editorialLayout = "default",
  editorialSize = "standard",
  context = "default",
}: Props = Astro.props;
const _revealOrderAttr =
  revealOrder === undefined || revealOrder === null ? undefined : String(revealOrder);
const _tags = Array.isArray(tags) ? tags : [];
const _categories = Array.isArray(categories) ? categories : [];
const _displayTags = _tags.slice(0, 2);
const _hasTaxonomy = _categories.length > 0 || _displayTags.length > 0;
const _isFeaturedEditorial = editorialLayout === "featured-editorial";
const _heroImageUrl = heroImage?.url ?? null;
const _hasHeroImage = !!_heroImageUrl;
const _editorialSource = _categories[0]?.title ?? _displayTags[0] ?? "Essay";
const _editorialContext =
  _categories[1]?.title ?? (_categories.length > 0 ? _displayTags[0] : _displayTags[1]) ?? null;
const _readingTimeLabel =
  typeof readingTimeMinutes === "number" && Number.isFinite(readingTimeMinutes)
    ? `${Math.max(1, Math.round(readingTimeMinutes))} min`
    : null;
const _imageWidths =
  editorialSize === "hero" ? [640, 960, 1280, 1440, 1920] : [480, 640, 840, 1080];
const _imageSizes =
  editorialSize === "hero"
    ? "(max-width: 480px) calc(100vw - 32px), (max-width: 820px) calc(100vw - 48px), 760px"
    : "(max-width: 480px) calc(100vw - 32px), (max-width: 900px) calc(100vw - 48px), (max-width: 1280px) min(42vw, 420px), 420px";
const _imageAlt = (heroImage?.alt ?? "")
  .replace(/\b(?:image|photo|picture)\b(?:\s+of)?/gi, "")
  .replace(/\s{2,}/g, " ")
  .replace(/\s+([,.;:!?])/g, "$1")
  .trim();
const _imagePlaceholderStyle = heroImage?.lqip
  ? `background-image: url('${heroImage.lqip}'); background-size: cover; background-position: center;`
  : undefined;
const _imageDimensions =
  heroImage?.width && heroImage?.height
    ? { width: heroImage.width, height: heroImage.height }
    : { inferSize: true as const };
const _placeholderIcons =
  coverVariant === "cinematic"
    ? ["planet", "cube", "sparkle"]
    : coverVariant === "minimal"
      ? ["article", "terminal-window", "arrow-square-out"]
      : ["laptop", "stack", "toolbox"];
---

<article
  class:list={[
    "articleCard",
    "hover-elevate",
    featured ? "motion-surface-premium articleCard--featured" : "motion-surface-standard",
    _hasHeroImage && "articleCard--hasMedia",
    _isFeaturedEditorial && "articleCard--featuredEditorial",
    _isFeaturedEditorial && `articleCard--cover-${coverVariant ?? "default"}`,
    _isFeaturedEditorial && `articleCard--editorial-${editorialSize}`,
    context === "reader-related" && "articleCard--readerRelated",
  ]}
  data-parallax-card
  data-reveal
  data-reveal-group={revealGroup}
  data-reveal-order={_revealOrderAttr}
  data-reveal-delay={revealDelay ?? undefined}
>
  <a class="articleCard__link" href={href}>
    {
      _hasHeroImage && _heroImageUrl && (
        <figure class="articleCard__media" style={_imagePlaceholderStyle}>
          <Image
            src={_heroImageUrl}
            sizes={_imageSizes}
            widths={_imageWidths}
            alt={_imageAlt || title}
            priority={imagePriority}
            loading={imagePriority ? undefined : "lazy"}
            {..._imageDimensions}
          />
        </figure>
      )
    }
    {
      _isFeaturedEditorial && !_hasHeroImage && (
        <figure class="articleCard__media articleCard__media--placeholder" aria-hidden="true">
          <div class="articleCard__placeholderCluster">
            {_placeholderIcons.map((iconName, index) => (
              <span
                class="articleCard__placeholderOrb"
                data-placeholder-index={index}
              >
                <PhosphorIcon name={iconName} size={editorialSize === "hero" ? 28 : 22} weight="regular" />
              </span>
            ))}
          </div>
        </figure>
      )
    }
    <div class="articleCard__body">
      <header class="articleCard__header">
        {
          _isFeaturedEditorial && (
            <div class="articleCard__sourceRow" aria-label="Article context">
              <span class="articleCard__source">
                <PhosphorIcon name="article" size={13} weight="regular" />
                <span>{_editorialSource}</span>
              </span>
              {
                _editorialContext && (
                  <>
                    <span class="articleCard__sourceDot" aria-hidden="true"></span>
                    <span class="articleCard__sourceContext">{_editorialContext}</span>
                  </>
                )
              }
            </div>
          )
        }
        {
          _hasTaxonomy && (
            <div class="articleCard__taxonomy" aria-label="Topics and categories">
              <CategoryBadges categories={_categories} limit={2} variant="inline" linked={false} />
              {
                _displayTags.length > 0 && (
                  <ul class:list={["articleCard__tags", "taxonomy-labels"]} aria-label="Tags">
                    {_displayTags.map((tag) => (
                      <li class:list={["articleCard__tag", "taxonomy-label"]}>{tag}</li>
                    ))}
                  </ul>
                )
              }
            </div>
          )
        }
        <h3 class="articleCard__title">{title}</h3>
      </header>
      <p class="articleCard__summary">{summary}</p>
      {
        hook && (
          <p class="articleCard__hook">{hook}</p>
        )
      }
      <div class="articleCard__footer">
        <div class="articleCard__meta" aria-label="Post metadata">
          <span class:list={["articleCard__metaItem", "meta-chip", "meta-chip--compact"]}>
            <PhosphorIcon name="calendar" size={14} weight="regular" />
            <time datetime={dateISO}>{dateLabel}</time>
          </span>
          {
            _readingTimeLabel && (
              <span class:list={["articleCard__metaItem", "meta-chip", "meta-chip--compact"]}>
                <PhosphorIcon name="clock" size={14} weight="regular" />
                {_readingTimeLabel}
              </span>
            )
          }
          {isNew && <span class:list={["articleCard__metaItem", "articleCard__newBadge", "meta-chip", "meta-chip--compact", "meta-chip--accent"]}>New</span>}
        </div>
        <span class="articleCard__cta cta-pill cta-pill--accent motion-cta-pill">
          <span>{ctaLabel}</span>
          <PhosphorIcon name="arrow-up-right" size={16} weight="regular" />
        </span>
      </div>
    </div>
  </a>
</article>
