---
import PhosphorIcon from "./PhosphorIcon.astro";
import CategoryBadges from "./CategoryBadges.astro";
import type { Category } from "../sanity/lib/posts";

interface Props {
  href: string;
  title: string;
  summary: string;
  hook?: string | null;
  dateISO: string;
  dateLabel: string;
  tags?: string[];
  categories?: Category[] | null;
  featured?: boolean;
  revealGroup?: string;
  revealOrder?: number | string;
  revealDelay?: string;
  readingTimeMinutes?: number;
  isNew?: boolean;
}

const {
  href,
  title,
  summary,
  hook = null,
  dateISO,
  dateLabel,
  tags = [],
  categories = [],
  featured = false,
  revealGroup = "articles",
  revealOrder,
  revealDelay,
  readingTimeMinutes,
  isNew = false,
}: Props = Astro.props;
const _revealOrderAttr =
  revealOrder === undefined || revealOrder === null ? undefined : String(revealOrder);
const _tags = Array.isArray(tags) ? tags : [];
const _categories = Array.isArray(categories) ? categories : [];
const _displayTags = _tags.slice(0, featured ? 3 : 2);
const _hasTaxonomy = _categories.length > 0 || _displayTags.length > 0;
const _readingTimeLabel =
  typeof readingTimeMinutes === "number" && Number.isFinite(readingTimeMinutes)
    ? `${Math.max(1, Math.round(readingTimeMinutes))} min`
    : null;
const _ctaLabel = featured ? "Read entry" : "Open entry";
---

<article
  class={`articleCard hover-elevate ${featured ? "motion-surface-premium articleCard--featured" : "motion-surface-standard"}`}
  data-parallax-card
  data-reveal
  data-reveal-group={revealGroup}
  data-reveal-order={_revealOrderAttr}
  data-reveal-delay={revealDelay ?? undefined}
>
  <a class="articleCard__link" href={href}>
    <header class="articleCard__header">
      {
        _hasTaxonomy && (
          <div class="articleCard__taxonomy" aria-label="Topics and categories">
            <CategoryBadges categories={_categories} limit={2} variant="inline" />
            {
              _displayTags.length > 0 && (
                <ul class="articleCard__tags" aria-label="Tags">
                  {_displayTags.map((tag) => (
                    <li class="articleCard__tag">{tag}</li>
                  ))}
                </ul>
              )
            }
          </div>
        )
      }
      <h3 class="articleCard__title">{title}</h3>
    </header>
    <p class="articleCard__summary">{summary}</p>
    {
      hook && (
        <p class="articleCard__hook">{hook}</p>
      )
    }
    <div class="articleCard__footer">
      <div class="articleCard__meta" aria-label="Post metadata">
        <span class="articleCard__metaItem">
          <PhosphorIcon name="calendar" size={14} weight="regular" />
          <time datetime={dateISO}>{dateLabel}</time>
        </span>
        {
          _readingTimeLabel && (
            <span class="articleCard__metaItem">
              <PhosphorIcon name="clock" size={14} weight="regular" />
              {_readingTimeLabel}
            </span>
          )
        }
        {isNew && <span class="articleCard__metaItem articleCard__newBadge">New</span>}
      </div>
      <span class="articleCard__cta">
        <span>{_ctaLabel}</span>
        <PhosphorIcon name="arrow-up-right" size={16} weight="regular" />
      </span>
    </div>
  </a>
</article>

<style>
  .articleCard__hook {
    margin: 0;
    font-size: var(--fs--2);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--blue);
  }
</style>
